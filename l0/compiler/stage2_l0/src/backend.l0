module backend;

import std.assert;
import std.hashmap;
import std.hashset;
import std.string;
import std.text;
import std.vector;

import ast;
import c_emitter;
import codegen_options;
import driver;
import name_resolver;
import sem_context;
import signatures;
import scope_context;
import symbols;
import type_resolve;
import types;
import util.log;

/**
 * Represents one Stage 2 backend generation session.
 */
struct Backend {
    result: AnalysisResult*;
    opts: CodegenOptions*;
    cfg: LogConfig*;
    emitter: CEmitter*;
    current_module: string?;
    current_unit: DriverUnit*?;
    current_env: ModuleEnv*?;
    current_func_result: Type*?;
    current_scope: ScopeContext*?;
    scope_stack: VectorBase*;          // ScopeContext* (for final cleanup)
    current_loop_labels: LoopLabels*?;
    current_loop_cleanup_scopes: LoopCleanupScopes*?;
    scope_counter: int;
    label_counter: int;
    next_stmt_unreachable: bool;
}

/**
 * Represents one active loop label pair.
 */
struct LoopLabels {
    parent: LoopLabels*?;
    break_label: string;
    continue_label: string;
}

/**
 * Represents the cleanup targets for one active loop.
 */
struct LoopCleanupScopes {
    parent: LoopCleanupScopes*?;
    continue_scope: ScopeContext*;
    break_scope: ScopeContext*;
    continue_scope_id: int;
    break_scope_id: int;
}

/**
 * Abort on an internal backend error.
 *
 * @param message ICE message to report.
 */
func be_ice(message: string) {
    assert(false, message);
}

/**
 * Abort on an internal backend error from a string-returning helper.
 *
 * @param message ICE message to report.
 * @return Dummy return used only to satisfy control-flow typing.
 */
func be_ice_string(message: string) -> string {
    assert(false, message);
    return "";
}

/**
 * Create a backend state for one code-generation pass.
 *
 * @param result Borrowed semantic analysis result.
 * @param opts Borrowed codegen options.
 * @param cfg Borrowed log configuration.
 * @return New backend state.
 */
func be_create(result: AnalysisResult*, opts: CodegenOptions*, cfg: LogConfig*) -> Backend* {
    let emitter = cem_create();
    cem_set_analysis(emitter, result);
    return new Backend(result, opts, cfg, emitter, null, null, null, null, null, ptr_vec_create(8), null, null, 0, 0,
        false);
}

/**
 * Free a backend state.
 *
 * @param self Backend state to free.
 */
func be_free(self: Backend*) {
    for (let i = 0; i < vec_size(self.scope_stack); i = i + 1) {
        sc_free(ptr_vec_get(self.scope_stack, i) as ScopeContext*);
    }
    let labels = self.current_loop_labels;
    while (labels != null) {
        let cur = labels as LoopLabels*;
        labels = cur.parent;
        drop cur;
    }
    let cleanup_scopes = self.current_loop_cleanup_scopes;
    while (cleanup_scopes != null) {
        let cur2 = cleanup_scopes as LoopCleanupScopes*;
        cleanup_scopes = cur2.parent;
        drop cur2;
    }
    vec_free(self.scope_stack);
    cem_free(self.emitter);
    drop self;
}

/**
 * Build a stable key for one user-defined type.
 *
 * @param module_name Defining module name.
 * @param type_name Struct or enum name.
 * @return Key in `module::type` form.
 */
func be_type_key(module_name: string, type_name: string) -> string {
    return concat3_s(module_name, "::", type_name);
}

/**
 * Return the module portion of a type key.
 *
 * @param key Type key in `module::type` form.
 * @return Module-name portion of the key.
 */
func be_type_key_module(key: string) -> string {
    let n = len_s(key);
    for (let i = 0; i < n - 1; i = i + 1) {
        if (char_at_s(key, i) == ':' && char_at_s(key, i + 1) == ':') {
            return slice_s(key, 0, i);
        }
    }
    return "";
}

/**
 * Return the type-name portion of a type key.
 *
 * @param key Type key in `module::type` form.
 * @return Type-name portion of the key.
 */
func be_type_key_name(key: string) -> string {
    let n = len_s(key);
    for (let i = 0; i < n - 1; i = i + 1) {
        if (char_at_s(key, i) == ':' && char_at_s(key, i + 1) == ':') {
            return slice_s(key, i + 2, n);
        }
    }
    return "";
}

/**
 * Return the current module environment.
 *
 * @param self Backend state to inspect.
 * @return Borrowed module environment.
 */
func be_current_env(self: Backend*) -> ModuleEnv* {
    if (self.current_env == null) {
        be_ice("[ICE-9301] backend requires current module environment");
    }
    return self.current_env as ModuleEnv*;
}

/**
 * Return the current unit.
 *
 * @param self Backend state to inspect.
 * @return Borrowed driver unit.
 */
func be_current_unit(self: Backend*) -> DriverUnit* {
    if (self.current_unit == null) {
        be_ice("[ICE-9302] backend requires current driver unit");
    }
    return self.current_unit as DriverUnit*;
}

/**
 * Return the current expression arena.
 *
 * @param self Backend state to inspect.
 * @return Borrowed expression arena.
 */
func be_current_expr_arena(self: Backend*) -> ExprArena* {
    return be_current_unit(self).parse_result.expr_arena;
}

/**
 * Return the current statement arena.
 *
 * @param self Backend state to inspect.
 * @return Borrowed statement arena.
 */
func be_current_stmt_arena(self: Backend*) -> StmtArena* {
    return be_current_unit(self).parse_result.stmt_arena;
}

/**
 * Return a loaded driver unit by module name.
 *
 * @param self Backend state to inspect.
 * @param module_name Module to look up.
 * @return Matching loaded unit, or `null` if absent.
 */
func be_find_unit(self: Backend*, module_name: string) -> DriverUnit*? {
    return driver_find_unit(self.result.driver_state, module_name);
}

/**
 * Return a module environment by name.
 *
 * @param self Backend state to inspect.
 * @param module_name Module to look up.
 * @return Matching module environment, or `null` if absent.
 */
func be_find_env(self: Backend*, module_name: string) -> ModuleEnv*? {
    if (self.result.names == null) {
        return null;
    }
    return nr_env_find(self.result.names as NameResolution*, module_name);
}

/**
 * Resolve one parsed type reference in the current module environment.
 *
 * @param self Backend state to inspect.
 * @param tref Parsed type reference.
 * @return Resolved type, or `null` if resolution fails.
 */
func be_resolve_type_ref(self: Backend*, tref: TypeRef*) -> Type*? {
    if (self.result.signatures == null || self.result.names == null) {
        return null;
    }
    with (let seen = ss_create() => ss_free(seen)) {
        return tr_resolve_type_ref(
            self.result.signatures as SignatureTables*,
            self.result.names as NameResolution*,
            be_current_env(self),
            tref,
            self.result.diags,
            seen
        );
    }
}

/**
 * Look up a visible symbol from the current module.
 *
 * @param self Backend state to inspect.
 * @param name Symbol name.
 * @param module_path Optional explicit module path.
 * @param name_qualifier Optional enum-name qualifier.
 * @return Matching symbol, or `null` if absent.
 */
func be_lookup_symbol(self: Backend*, name: string, module_path: VectorString*?, name_qualifier: VectorString*?) -> Symbol*? {
    if (self.result.names == null) {
        return null;
    }
    return tr_symbol_lookup(self.result.names as NameResolution*, be_current_env(self), name, module_path, name_qualifier);
}

/**
 * Return the inferred type of an expression.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression id to query.
 * @return Cloned inferred type, or `null` if missing.
 */
func be_expr_type(self: Backend*, expr_id: ExprId) -> Type*? {
    if (self.current_module == null) {
        return null;
    }
    return analysis_get_expr_type(self.result, self.current_module as string, expr_id);
}

/**
 * Free a temporary vector of optional owned `Type*` values.
 *
 * @param items Vector to free. Null entries are ignored.
 */
func be_type_ptr_vec_temp_free(items: VectorBase*?) {
    if (items == null) {
        return;
    }
    let vec = items as VectorBase*;
    for (let i = 0; i < vec_size(vec); i = i + 1) {
        let item = ptr_vec_get(vec, i);
        if (item != null) {
            type_free(item as Type*);
        }
    }
    vec_free(vec);
}

/**
 * Free a temporary map of owned `Type*` values.
 *
 * @param items Map to free.
 */
func be_type_ptr_map_temp_free(items: StringPtrMap*?) {
    if (items == null) {
        return;
    }
    let map = items as StringPtrMap*;
    for (let i = 0; i < spm_capacity(map); i = i + 1) {
        if (spm_slot_occupied(map, i)) {
            type_free(spm_slot_value(map, i) as Type*);
        }
    }
    spm_free(map);
}

/**
 * Resolve the type of one local `let` declaration.
 *
 * @param self Backend state to inspect.
 * @param stmt Parsed `let` statement.
 * @return Resolved type.
 */
func be_resolve_let_type(self: Backend*, stmt: StmtNode*) -> Type* {
    let var_ty: Type*? = null;
    if (stmt.type_ref != null) {
        var_ty = be_resolve_type_ref(self, stmt.type_ref as TypeRef*);
    }
    if (var_ty == null) {
        var_ty = be_expr_type(self, stmt.expr_a);
    }
    if (var_ty == null) {
        be_ice(concat3_s("[ICE-1170] missing inferred type for let initializer '", stmt.name, "'"));
    }
    return var_ty as Type*;
}

/**
 * Predeclare a nullable cleanup-block header let to its null literal.
 *
 * @param self Backend state to update.
 * @param stmt Parsed `let` statement from a `with` header.
 * @return Resolved nullable type when predeclared, otherwise `null`.
 */
func be_emit_with_cleanup_header_let_predecl(self: Backend*, stmt: StmtNode*) -> Type*? {
    let var_ty = be_resolve_let_type(self, stmt);
    if (ord(var_ty.kind) != ord(TY_NULLABLE)) {
        type_free(var_ty);
        return null;
    }

    let c_var_name = cem_mangle_identifier(stmt.name);
    let c_type = cem_emit_type(var_ty);
    let c_zero = cem_emit_null_literal(var_ty, true);
    cem_emit_let_decl(self.emitter, c_type, c_var_name, c_zero);

    if (self.current_scope != null) {
        sc_add_owned(self.current_scope as ScopeContext*, c_var_name, var_ty);
    }

    return var_ty;
}

/**
 * Emit the initializer assignment for a predeclared cleanup-block header let.
 *
 * @param self Backend state to update.
 * @param stmt Parsed `let` statement from a `with` header.
 * @param var_ty Resolved type of the predeclared variable.
 */
func be_emit_with_cleanup_header_let_assign(self: Backend*, stmt: StmtNode*, var_ty: Type*) {
    let c_var_name = cem_mangle_identifier(stmt.name);
    let c_value = be_emit_owned_expr_with_expected_type(self, stmt.expr_a, var_ty);
    cem_emit_assignment(self.emitter, c_var_name, c_value);
}

/**
 * Return a fresh backend label name.
 *
 * @param self Backend state to update.
 * @param prefix Label prefix.
 * @return Unique label string.
 */
func be_fresh_label(self: Backend*, prefix: string) -> string {
    self.label_counter = self.label_counter + 1;
    return concat4_s("__", prefix, "_", int_to_string(self.label_counter));
}

/**
 * Push one lexical scope and make it current.
 *
 * @param self Backend state to update.
 * @return New current scope.
 */
func be_push_scope(self: Backend*) -> ScopeContext* {
    let scope = sc_create(self.current_scope);
    self.scope_counter = self.scope_counter + 1;
    scope.scope_id = self.scope_counter;
    ptr_vec_push(self.scope_stack, scope as void*);
    self.current_scope = scope;
    return scope;
}

/**
 * Pop the current lexical scope.
 *
 * @param self Backend state to update.
 */
func be_pop_scope(self: Backend*) {
    if (self.current_scope == null) {
        be_ice("[ICE-1330] scope underflow");
    }
    self.current_scope = (self.current_scope as ScopeContext*).parent;
}

/**
 * Push one active loop-label frame.
 *
 * @param self Backend state to update.
 * @param break_label Break target label.
 * @param continue_label Continue target label.
 */
func be_push_loop_labels(self: Backend*, break_label: string, continue_label: string) {
    self.current_loop_labels = new LoopLabels(self.current_loop_labels, break_label, continue_label);
}

/**
 * Pop one active loop-label frame.
 *
 * @param self Backend state to update.
 */
func be_pop_loop_labels(self: Backend*) {
    if (self.current_loop_labels == null) {
        be_ice("[ICE-1020] break/continue outside of loop");
    }
    let top = self.current_loop_labels as LoopLabels*;
    self.current_loop_labels = top.parent;
    drop top;
}

/**
 * Push one active loop-cleanup frame.
 *
 * @param self Backend state to update.
 * @param continue_scope Scope to clean for `continue`.
 * @param break_scope Scope to clean for `break`.
 */
func be_push_loop_cleanup_scopes(self: Backend*, continue_scope: ScopeContext*, break_scope: ScopeContext*) {
    self.current_loop_cleanup_scopes = new LoopCleanupScopes(self.current_loop_cleanup_scopes, continue_scope, break_scope,
        continue_scope.scope_id, break_scope.scope_id);
}

/**
 * Pop one active loop-cleanup frame.
 *
 * @param self Backend state to update.
 */
func be_pop_loop_cleanup_scopes(self: Backend*) {
    if (self.current_loop_cleanup_scopes == null) {
        be_ice("[ICE-1020] break/continue outside of loop");
    }
    let top = self.current_loop_cleanup_scopes as LoopCleanupScopes*;
    self.current_loop_cleanup_scopes = top.parent;
    drop top;
}

/**
 * Return the type of a declared local binding when present.
 *
 * @param self Backend state to inspect.
 * @param var_name Source-level variable name.
 * @return Borrowed declared type, or `null` if absent.
 */
func be_lookup_local_var_type(self: Backend*, var_name: string) -> Type*? {
    return sc_lookup_declared_type(self.current_scope, cem_mangle_identifier(var_name));
}

/**
 * Return the mangled name when a local variable is currently tracked as owned.
 *
 * @param self Backend state to inspect.
 * @param expr_id Variable-reference expression id.
 * @return Mangled local name, or `null` when not owned by the current scope chain.
 */
func be_lookup_owned_local_name(self: Backend*, expr_id: ExprId) -> string? {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) != ord(EX_VAR_REF)) {
        return null;
    }

    let resolution = analysis_get_var_ref_resolution(self.result, self.current_module as string, expr_id);
    if (resolution == null || (resolution as int) != ord(VAR_RES_LOCAL)) {
        return null;
    }

    let mangled_name = cem_mangle_identifier(expr.text_value);
    let scope = self.current_scope;
    while (scope != null) {
        let cur = scope as ScopeContext*;
        for (let i = 0; i < vec_size(cur.owned_vars); i = i + 1) {
            let item = ptr_vec_get(cur.owned_vars, i) as ScopeVar*;
            if (eq_s(item.name, mangled_name)) {
                return mangled_name;
            }
        }
        scope = cur.parent;
    }
    return null;
}

/**
 * Report whether an expression refers to an existing place.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to classify.
 * @return `true` for local/module places, dereferences, indexes, and fields.
 */
func be_is_place_expr(self: Backend*, expr_id: ExprId) -> bool {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) == ord(EX_VAR_REF) || ord(expr.kind) == ord(EX_INDEX) || ord(expr.kind) == ord(EX_FIELD)) {
        return true;
    }
    if (ord(expr.kind) == ord(EX_UNARY) && eq_s(expr.text_value, "*")) {
        return true;
    }
    if (ord(expr.kind) == ord(EX_PAREN)) {
        return be_is_place_expr(self, expr.expr_a);
    }
    return false;
}

/**
 * Report whether an expression may have side effects when evaluated.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to classify.
 * @return `true` when the expression should be cached before reuse.
 */
func be_has_side_effects(self: Backend*, expr_id: ExprId) -> bool {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    match (expr.kind) {
        EX_INT => { return false; }
        EX_BYTE => { return false; }
        EX_STRING => { return false; }
        EX_BOOL => { return false; }
        EX_NULL => { return false; }
        EX_VAR_REF => { return false; }
        EX_CALL => { return true; }
        EX_NEW => { return true; }
        EX_UNARY => { return be_has_side_effects(self, expr.expr_a); }
        EX_BINARY => { return be_has_side_effects(self, expr.expr_a) || be_has_side_effects(self, expr.expr_b); }
        EX_CAST => { return be_has_side_effects(self, expr.expr_a); }
        EX_PAREN => { return be_has_side_effects(self, expr.expr_a); }
        EX_FIELD => { return be_has_side_effects(self, expr.expr_a); }
        EX_INDEX => { return be_has_side_effects(self, expr.expr_a) || be_has_side_effects(self, expr.expr_b); }
        EX_TRY => { return be_has_side_effects(self, expr.expr_a); }
        EX_TYPE => { return false; }
    }
}

/**
 * Report whether an expression is a nullable unwrap cast from a place.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to classify.
 * @return `true` when the cast is `T? as T` and the source is a place expression.
 */
func be_is_unwrap_cast_from_place(self: Backend*, expr_id: ExprId) -> bool {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) != ord(EX_CAST)) {
        return false;
    }

    with (let src_ty = be_expr_type(self, expr.expr_a) => type_free_opt(src_ty),
          let dst_ty = be_expr_type(self, expr_id) => type_free_opt(dst_ty)) {
        if (src_ty == null || dst_ty == null) {
            return false;
        }
        if (ord((src_ty as Type*).kind) != ord(TY_NULLABLE)) {
            return false;
        }
        if (!type_equals((dst_ty as Type*), ((src_ty as Type*).inner as Type*))) {
            return false;
        }
        return be_is_place_expr(self, expr.expr_a);
    }
}

/**
 * Report whether a non-place ARC rvalue needs temporary materialization.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to classify.
 * @return `true` when the expression should be hoisted into a cleanup temp.
 */
func be_needs_arc_temp(self: Backend*, expr_id: ExprId) -> bool {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    return ord(expr.kind) != ord(EX_STRING);
}

/**
 * Report whether an expression should be materialized into a scope-owned temp.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to classify.
 * @param expr_type Inferred type of the expression.
 * @return `true` when the expression carries ARC data and is not already a place.
 */
func be_should_materialize_arc_temp(self: Backend*, expr_id: ExprId, expr_type: Type*) -> bool {
    return analysis_has_arc_data(self.result, expr_type) &&
           !be_is_place_expr(self, expr_id) &&
           !be_is_unwrap_cast_from_place(self, expr_id) &&
           be_needs_arc_temp(self, expr_id);
}

/**
 * Materialize one ARC rvalue into a scope-owned temporary.
 *
 * @param self Backend state to update.
 * @param c_expr Lowered expression to store.
 * @param expr_type Type of the stored expression.
 * @return Temporary variable name.
 */
func be_materialize_arc_temp(self: Backend*, c_expr: string, expr_type: Type*) -> string {
    if (self.current_scope == null) {
        be_ice("[ICE-1311] ARC temp materialization requires an active scope");
    }
    let temp = cem_fresh_tmp(self.emitter, "arc");
    cem_emit_temp_decl(self.emitter, cem_emit_type(expr_type), temp, c_expr);
    sc_add_owned(self.current_scope as ScopeContext*, temp, expr_type);
    return temp;
}

/**
 * Report whether any scope in the current chain has pending cleanup work.
 *
 * @param self Backend state to inspect.
 * @return `true` when owned values or `with` cleanup are present.
 */
func be_scope_chain_has_cleanup(self: Backend*) -> bool {
    let scope = self.current_scope;
    while (scope != null) {
        let cur = scope as ScopeContext*;
        if (((cur.with_cleanup_block >= 0) || sc_has_inline_cleanup(cur)) && !cur.with_cleanup_in_progress) {
            return true;
        }
        for (let i = 0; i < vec_size(cur.owned_vars); i = i + 1) {
            let item = ptr_vec_get(cur.owned_vars, i) as ScopeVar*;
            if (analysis_has_arc_data(self.result, item.var_type)) {
                return true;
            }
        }
        scope = cur.parent;
    }
    return false;
}

/**
 * Emit retain operations for one copied owned value.
 *
 * @param self Backend state to update.
 * @param c_expr Lowered expression containing the copied value.
 * @param ty Type of the copied value.
 */
func be_emit_retain_for_copied_value(self: Backend*, c_expr: string, ty: Type*) {
    if (analysis_is_arc_type(ty)) {
        cem_emit_string_retain(self.emitter, c_expr);
        return;
    }

    if (ord(ty.kind) == ord(TY_NULLABLE)) {
        if (cem_is_niche_nullable(ty) || !analysis_has_arc_data(self.result, ty.inner as Type*)) {
            return;
        }
        cem_emit_if_header(self.emitter, cem_emit_optional_has_value(c_expr));
        cem_emit_block_start(self.emitter);
        be_emit_retain_for_copied_value(self, cem_emit_optional_value(c_expr), ty.inner as Type*);
        cem_emit_block_end(self.emitter);
        return;
    }

    if (ord(ty.kind) == ord(TY_STRUCT)) {
        let info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, ty.module_name, ty.name);
        if (info == null) {
            return;
        }
        for (let i = 0; i < vec_size((info as StructInfo*).fields); i = i + 1) {
            let field = ptr_vec_get((info as StructInfo*).fields, i) as StructFieldInfo*;
            be_emit_retain_for_copied_value(self, cem_emit_field_access(c_expr, field.name, false), field.field_type);
        }
        return;
    }

    if (ord(ty.kind) == ord(TY_ENUM)) {
        let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, ty.module_name, ty.name);
        let decl = be_find_enum_decl(self, ty.module_name, ty.name);
        if (enum_info == null || decl == null) {
            return;
        }

        cem_emit_switch_start(self.emitter, cem_emit_enum_tag_access(c_expr));
        for (let i = 0; i < vec_size((decl as EnumDecl*).variants); i = i + 1) {
            let variant = ptr_vec_get((decl as EnumDecl*).variants, i) as EnumVariant*;
            let info2 = cem_find_enum_variant_info(enum_info as EnumInfo*, variant.name);
            if (info2 == null) {
                continue;
            }
            cem_emit_case_label(self.emitter, cem_emit_enum_tag(ty, variant.name));
            cem_emit_block_start(self.emitter);
            for (let j = 0; j < vec_size((info2 as EnumVariantInfo*).field_types); j = j + 1) {
                let field_decl = ptr_vec_get(variant.fields, j) as FieldDecl*;
                let field_ty = ptr_vec_get((info2 as EnumVariantInfo*).field_types, j) as Type*;
                be_emit_retain_for_copied_value(self, cem_emit_enum_payload_field_access(c_expr, variant.name, field_decl.name), field_ty);
            }
            cem_emit_exit_switch(self.emitter);
            cem_emit_block_end(self.emitter);
        }
        cem_emit_unreachable_marker(self.emitter, "retain");
        cem_emit_switch_end(self.emitter);
    }
}

/**
 * Materialize one copied value into a temp and retain any owned fields.
 *
 * @param self Backend state to update.
 * @param c_expr Lowered source expression.
 * @param ty Type of the copied value.
 * @return Lowered expression or new temp name when retain logic is needed.
 */
func be_emit_copy_expr_with_retains(self: Backend*, c_expr: string, ty: Type*) -> string {
    if (!analysis_has_arc_data(self.result, ty)) {
        return c_expr;
    }

    let temp = cem_fresh_tmp(self.emitter, "copy");
    cem_emit_temp_decl(self.emitter, cem_emit_type(ty), temp, c_expr);
    be_emit_retain_for_copied_value(self, temp, ty);
    return temp;
}

/**
 * Return whether a type behaves like an integer.
 *
 * @param ty Type to inspect.
 * @return `true` for `int` and `byte`.
 */
func be_is_int_assignable(ty: Type*?) -> bool {
    if (ty == null) {
        return false;
    }
    return type_is_builtin(ty as Type*, "int") || type_is_builtin(ty as Type*, "byte");
}

/**
 * Return the byte width of an integer builtin.
 *
 * @param ty Type to inspect.
 * @return Byte width for supported integer types.
 */
func be_int_type_size(ty: Type*) -> int {
    if (type_is_builtin(ty, "byte")) {
        return 1;
    }
    if (type_is_builtin(ty, "int")) {
        return 4;
    }
    return 0;
}

/**
 * Convert a lowered expression to an expected type when required.
 *
 * @param c_expr Lowered source expression.
 * @param natural_ty Natural source type.
 * @param expected Expected destination type.
 * @return Lowered expression converted as needed.
 */
func be_convert_expr_with_expected_type(c_expr: string, natural_ty: Type*?, expected: Type*) -> string {
    if (natural_ty == null) {
        return c_expr;
    }

    let natural = natural_ty as Type*;
    if (type_equals(natural, expected)) {
        return c_expr;
    }

    if (ord(expected.kind) == ord(TY_NULLABLE) && type_equals(expected.inner as Type*, natural)) {
        if (cem_is_niche_nullable(expected)) {
            return c_expr;
        }
        return cem_emit_some_value_for_nullable(expected, c_expr);
    }

    if (type_is_builtin(natural, "byte") && type_is_builtin(expected, "int")) {
        return cem_emit_widen_int(c_expr, natural, expected);
    }

    return c_expr;
}

/**
 * Emit one expression with implicit conversion to an expected type.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to lower.
 * @param expected Expected destination type.
 * @return Lowered expression string.
 */
func be_emit_expr_with_expected_type(self: Backend*, expr_id: ExprId, expected: Type*) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) == ord(EX_NULL)) {
        return cem_emit_null_literal(expected, false);
    }

    with (let natural_ty = be_expr_type(self, expr_id) => type_free_opt(natural_ty)) {
        let c_expr = be_emit_expr(self, expr_id);
        return be_convert_expr_with_expected_type(c_expr, natural_ty, expected);
    }
}

/**
 * Emit one expression for a context that creates a new owner.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression to lower.
 * @param expected Expected destination type.
 * @return Lowered expression string, with retain-on-copy when required.
 */
func be_emit_owned_expr_with_expected_type(self: Backend*, expr_id: ExprId, expected: Type*) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) == ord(EX_NULL)) {
        return be_emit_expr_with_expected_type(self, expr_id, expected);
    }

    with (let natural_ty = be_expr_type(self, expr_id) => type_free_opt(natural_ty)) {
        let c_expr = be_emit_expr(self, expr_id);
        let place_like = be_is_place_expr(self, expr_id) || be_is_unwrap_cast_from_place(self, expr_id);
        if (natural_ty == null || !place_like) {
            return be_convert_expr_with_expected_type(c_expr, natural_ty, expected);
        }
        if (type_equals(natural_ty as Type*, expected)) {
            return be_emit_copy_expr_with_retains(self, c_expr, expected);
        }
        if (ord(expected.kind) == ord(TY_NULLABLE) && type_equals(expected.inner as Type*, natural_ty as Type*)) {
            if (cem_is_niche_nullable(expected)) {
                return c_expr;
            }
            return cem_emit_some_value_for_nullable(expected,
                be_emit_copy_expr_with_retains(self, c_expr, natural_ty as Type*));
        }
        return be_convert_expr_with_expected_type(c_expr, natural_ty, expected);
    }
}

/**
 * Free an optional cloned type.
 *
 * @param ty Optional type to free.
 */
func type_free_opt(ty: Type*?) {
    if (ty != null) {
        type_free(ty as Type*);
    }
}

/**
 * Look up a top-level struct declaration.
 *
 * @param self Backend state to inspect.
 * @param module_name Defining module name.
 * @param struct_name Struct name.
 * @return Matching declaration, or `null` if absent.
 */
func be_find_struct_decl(self: Backend*, module_name: string, struct_name: string) -> StructDecl*? {
    let unit = be_find_unit(self, module_name);
    if (unit == null || (unit as DriverUnit*).parse_result.root_module == null) {
        return null;
    }

    let root = ((unit as DriverUnit*).parse_result.root_module as Module*);
    for (let i = 0; i < vec_size(root.decls); i = i + 1) {
        let top = ptr_vec_get(root.decls, i) as TopLevelDecl*;
        if (ord(top.kind) == ord(TD_STRUCT)) {
            let decl = top.data as StructDecl*;
            if (eq_s(decl.name, struct_name)) {
                return decl;
            }
        }
    }
    return null;
}

/**
 * Look up a top-level enum declaration.
 *
 * @param self Backend state to inspect.
 * @param module_name Defining module name.
 * @param enum_name Enum name.
 * @return Matching declaration, or `null` if absent.
 */
func be_find_enum_decl(self: Backend*, module_name: string, enum_name: string) -> EnumDecl*? {
    let unit = be_find_unit(self, module_name);
    if (unit == null || (unit as DriverUnit*).parse_result.root_module == null) {
        return null;
    }

    let root = ((unit as DriverUnit*).parse_result.root_module as Module*);
    for (let i = 0; i < vec_size(root.decls); i = i + 1) {
        let top = ptr_vec_get(root.decls, i) as TopLevelDecl*;
        if (ord(top.kind) == ord(TD_ENUM)) {
            let decl = top.data as EnumDecl*;
            if (eq_s(decl.name, enum_name)) {
                return decl;
            }
        }
    }
    return null;
}

/**
 * Look up an enum variant declaration.
 *
 * @param self Backend state to inspect.
 * @param module_name Defining module name.
 * @param enum_name Enum name.
 * @param variant_name Variant name.
 * @return Matching variant declaration, or `null` if absent.
 */
func be_find_variant_decl(self: Backend*, module_name: string, enum_name: string, variant_name: string) -> EnumVariant*? {
    let enum_decl = be_find_enum_decl(self, module_name, enum_name);
    if (enum_decl == null) {
        return null;
    }

    let decl = enum_decl as EnumDecl*;
    for (let i = 0; i < vec_size(decl.variants); i = i + 1) {
        let variant = ptr_vec_get(decl.variants, i) as EnumVariant*;
        if (eq_s(variant.name, variant_name)) {
            return variant;
        }
    }
    return null;
}

/**
 * Add value-type dependencies for one field type.
 *
 * @param ty Type to inspect.
 * @param deps Dependency set to update.
 */
func be_collect_value_type_dependencies(ty: Type*, deps: StringSet*) {
    if (ord(ty.kind) == ord(TY_POINTER)) {
        return;
    }
    if (ord(ty.kind) == ord(TY_NULLABLE)) {
        let inner = ty.inner as Type*;
        if (ord(inner.kind) == ord(TY_POINTER)) {
            return;
        }
        be_collect_value_type_dependencies(inner, deps);
        return;
    }
    if (ord(ty.kind) == ord(TY_STRUCT) || ord(ty.kind) == ord(TY_ENUM)) {
        ss_add(deps, be_type_key(ty.module_name, ty.name));
        return;
    }
}

/**
 * Collect the value-type dependencies for one user-defined type.
 *
 * @param self Backend state to inspect.
 * @param type_key Type key to inspect.
 * @param deps Destination set to populate.
 * @return `true` when the type metadata was found.
 */
func be_collect_type_dependencies(self: Backend*, type_key: string, deps: StringSet*) -> bool {
    if (self.result.signatures == null) {
        return true;
    }

    let module_name = be_type_key_module(type_key);
    let type_name = be_type_key_name(type_key);
    if (is_empty_s(module_name) || is_empty_s(type_name)) {
        return false;
    }

    let struct_info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, module_name, type_name);
    if (struct_info != null) {
        let info = struct_info as StructInfo*;
        for (let i = 0; i < vec_size(info.fields); i = i + 1) {
            let field = ptr_vec_get(info.fields, i) as StructFieldInfo*;
            be_collect_value_type_dependencies(field.field_type, deps);
        }
        return true;
    }

    let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, module_name, type_name);
    if (enum_info == null) {
        return false;
    }

    let info2 = enum_info as EnumInfo*;
    for (let i = 0; i < vec_size(info2.variants); i = i + 1) {
        let variant = ptr_vec_get(info2.variants, i) as EnumVariantInfo*;
        for (let j = 0; j < vec_size(variant.field_types); j = j + 1) {
            be_collect_value_type_dependencies(ptr_vec_get(variant.field_types, j) as Type*, deps);
        }
    }
    return true;
}

/**
 * Free a vector of dependency sets.
 *
 * @param sets Optional vector holding `StringSet*` entries.
 */
func be_dependency_sets_free(sets: VectorBase*?) {
    if (sets == null) {
        return;
    }

    let dep_sets = sets as VectorBase*;
    for (let i = 0; i < vec_size(dep_sets); i = i + 1) {
        ss_free(ptr_vec_get(dep_sets, i) as StringSet*);
    }
    vec_free(dep_sets);
}

/**
 * Collect all user-defined types in stable source order.
 *
 * @param self Backend state to inspect.
 * @return Ordered vector of type keys.
 */
func be_collect_type_keys(self: Backend*) -> VectorString* {
    let out = vs_create(8);

    for (let enum_unit_i = 0; enum_unit_i < driver_unit_count(self.result.driver_state); enum_unit_i = enum_unit_i + 1) {
        let unit = driver_unit_get(self.result.driver_state, enum_unit_i);
        if (unit.parse_result.root_module == null) {
            continue;
        }

        let root = unit.parse_result.root_module as Module*;
        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) == ord(TD_STRUCT)) {
                let decl = top.data as StructDecl*;
                vs_push(out, be_type_key(root.name, decl.name));
            }
        }
    }

    for (let i = 0; i < driver_unit_count(self.result.driver_state); i = i + 1) {
        let unit = driver_unit_get(self.result.driver_state, i);
        if (unit.parse_result.root_module == null) {
            continue;
        }

        let root = unit.parse_result.root_module as Module*;
        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) == ord(TD_ENUM)) {
                let decl2 = top.data as EnumDecl*;
                vs_push(out, be_type_key(root.name, decl2.name));
            }
        }
    }
    return out;
}

/**
 * Emit user-defined types in dependency order.
 *
 * @param self Backend state to update.
 */
func be_emit_type_definitions(self: Backend*) {
    if (self.result.signatures == null) {
        return;
    }

    with (let keys = be_collect_type_keys(self) => vs_free(keys),
          let ordered = vs_create(vs_size(keys)) => vs_free(ordered),
          let queue = vs_create(vs_size(keys)) => vs_free(queue),
          let dep_sets: VectorBase*? = ptr_vec_create(vs_size(keys)) => be_dependency_sets_free(dep_sets),
          let in_degrees: VectorBase*? = id_vec_create(vs_size(keys)) => id_vec_free(in_degrees)) {
        cem_emit_section_comment(self.emitter, "Type definitions (dependency-ordered)");

        for (let i = 0; i < vs_size(keys); i = i + 1) {
            let key = vs_get(keys, i);
            let deps = ss_create();
            if (!be_collect_type_dependencies(self, key, deps)) {
                be_ice(concat3_s("[ICE-1341] missing dependency metadata for type key ", key, ""));
            }
            ptr_vec_push(dep_sets as VectorBase*, deps as void*);

            let in_degree = 0;
            for (let j = 0; j < ss_capacity(deps); j = j + 1) {
                if (ss_slot_occupied(deps, j)) {
                    in_degree = in_degree + 1;
                }
            }
            id_vec_push(in_degrees as VectorBase*, in_degree);
            if (in_degree == 0) {
                vs_push(queue, key);
            }
        }

        let queue_index = 0;
        while (queue_index < vs_size(queue)) {
            let emitted_key = vs_get(queue, queue_index);
            queue_index = queue_index + 1;
            vs_push(ordered, emitted_key);

            for (let i = 0; i < vs_size(keys); i = i + 1) {
                let degree_ptr = vec_get(in_degrees as VectorBase*, i) as int*;
                if (*degree_ptr <= 0) {
                    continue;
                }
                let deps2 = ptr_vec_get(dep_sets as VectorBase*, i) as StringSet*;
                if (!ss_has(deps2, emitted_key)) {
                    continue;
                }
                *degree_ptr = *degree_ptr - 1;
                if (*degree_ptr == 0) {
                    vs_push(queue, vs_get(keys, i));
                }
            }
        }

        if (vs_size(ordered) != vs_size(keys)) {
            be_ice("[ICE-1340] value-type cycle detected in type definitions");
        }

        for (let ordered_i = 0; ordered_i < vs_size(ordered); ordered_i = ordered_i + 1) {
            let key = vs_get(ordered, ordered_i);
            let module_name = be_type_key_module(key);
            let type_name = be_type_key_name(key);

            let struct_info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, module_name, type_name);
            if (struct_info != null) {
                let decl = be_find_struct_decl(self, module_name, type_name);
                if (decl == null) {
                    be_ice(concat4_s("[ICE-1040] missing StructDecl for ", module_name, ".", type_name));
                }
                self.current_module = module_name;
                cem_emit_struct(self.emitter, module_name, decl as StructDecl*, struct_info as StructInfo*);
            } else {
                let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, module_name, type_name);
                let enum_decl = be_find_enum_decl(self, module_name, type_name);
                if (enum_info == null || enum_decl == null) {
                    be_ice(concat4_s("[ICE-1050] missing EnumDecl/EnumInfo for ", module_name, ".", type_name));
                }
                self.current_module = module_name;
                cem_emit_enum(self.emitter, module_name, enum_decl as EnumDecl*, enum_info as EnumInfo*);
            }
        }
    }
}

/**
 * Emit a `#line` directive for a declaration or statement when enabled.
 *
 * @param self Backend state to update.
 * @param span Source span to report.
 */
func be_emit_line_directive(self: Backend*, span: Span) {
    if (self.current_module == null) {
        return;
    }
    cem_emit_line_directive(self.emitter, span.start_line, self.current_module as string, self.opts);
}

/**
 * Emit a constant initializer for a top-level `let`.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression id to lower.
 * @param expected_type Resolved `let` type.
 * @return Constant initializer expression.
 */
func be_emit_let_initializer(self: Backend*, expr_id: ExprId, expected_type: Type*) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    match (expr.kind) {
        EX_INT => { return cem_emit_int_literal(expr.int_value); }
        EX_BYTE => { return cem_emit_byte_literal(expr.int_value as byte); }
        EX_BOOL => { return cem_emit_const_bool_literal(expr.bool_value); }
        EX_STRING => { return cem_emit_const_string_literal(expr.text_value); }
        EX_NULL => { return cem_emit_null_literal(expected_type, true); }
        EX_CALL => { return be_emit_const_constructor(self, expr_id, expected_type); }
        _ => {
            return be_ice_string("[ICE-1181] unsupported top-level let initializer");
        }
    }
}

/**
 * Emit a constant constructor initializer for a top-level `let`.
 *
 * @param self Backend state to inspect.
 * @param expr_id Call expression id.
 * @param expected_type Expected constructed type.
 * @return Constant initializer expression.
 */
func be_emit_const_constructor(self: Backend*, expr_id: ExprId, expected_type: Type*) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord(expr.kind) != ord(EX_CALL)) {
        return be_ice_string("[ICE-1034] constant constructor helper requires call expression");
    }
    let call = expr;
    let callee = expr_arena_get(be_current_expr_arena(self), call.expr_a);
    if (ord(callee.kind) != ord(EX_VAR_REF)) {
        return be_ice_string("[ICE-1034] constant constructor callee must be a name");
    }

    let sym = be_lookup_symbol(self, callee.text_value, callee.module_path, callee.name_qualifier);
    if (sym == null) {
        return be_ice_string("[ICE-1031] unknown constant constructor name");
    }

    if (ord((sym as Symbol*).kind) == ord(SYM_STRUCT)) {
        if (ord(expected_type.kind) != ord(TY_STRUCT)) {
            return be_ice_string("[ICE-1032] struct constructor expected struct type");
        }
        let info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, expected_type.module_name, expected_type.name);
        if (info == null) {
            return be_ice_string("[ICE-1040] missing StructInfo for constant constructor");
        }
        with (let field_inits = vs_create(8) => vs_free(field_inits)) {
            let struct_info = info as StructInfo*;
            for (let i = 0; i < vec_size(struct_info.fields); i = i + 1) {
                let field = ptr_vec_get(struct_info.fields, i) as StructFieldInfo*;
                vs_push(field_inits, field.name);
                vs_push(field_inits,
                    be_emit_let_initializer(self, id_vec_get(call.ids as VectorBase*, i), field.field_type));
            }
            return cem_emit_struct_static_initializer_for_type(expected_type, field_inits);
        }
    }

    if (ord((sym as Symbol*).kind) == ord(SYM_ENUM_VARIANT)) {
        if (ord(expected_type.kind) != ord(TY_ENUM)) {
            return be_ice_string("[ICE-1033] enum variant constructor expected enum type");
        }
        let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, expected_type.module_name, expected_type.name);
        if (enum_info == null) {
            return be_ice_string("[ICE-1050] missing EnumInfo for constant constructor");
        }
        let variant_name = (sym as Symbol*).name;
        let variant_info = cem_find_enum_variant_info(enum_info as EnumInfo*, variant_name);
        if (variant_info == null) {
            return be_ice_string("[ICE-1051] missing VariantInfo for constant constructor");
        }
        let variant_decl = be_find_variant_decl(self, expected_type.module_name, expected_type.name, variant_name);
        if (variant_decl == null) {
            return be_ice_string("[ICE-1052] missing EnumVariant decl for constant constructor");
        }
        with (let payload_inits = vs_create(8) => vs_free(payload_inits)) {
            let info2 = variant_info as EnumVariantInfo*;
            for (let i = 0; i < vec_size(info2.field_types); i = i + 1) {
                let field_decl = ptr_vec_get((variant_decl as EnumVariant*).fields, i) as FieldDecl*;
                vs_push(payload_inits, field_decl.name);
                vs_push(payload_inits,
                    be_emit_let_initializer(self, id_vec_get(call.ids as VectorBase*, i), ptr_vec_get(info2.field_types, i) as Type*));
            }
            return cem_emit_variant_static_initializer_for_type(expected_type, variant_name, payload_inits);
        }
    }

    return be_ice_string("[ICE-1034] call expression is not a supported constant constructor");
}

/**
 * Emit all top-level `let` declarations.
 *
 * @param self Backend state to update.
 */
func be_emit_let_declarations(self: Backend*) {
    if (self.result.signatures == null) {
        return;
    }

    let any_lets = false;
    for (let unit_i = 0; unit_i < driver_unit_count(self.result.driver_state); unit_i = unit_i + 1) {
        let unit = driver_unit_get(self.result.driver_state, unit_i);
        if (unit.parse_result.root_module == null) {
            continue;
        }
        let root = unit.parse_result.root_module as Module*;
        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) == ord(TD_LET)) {
                any_lets = true;
                break;
            }
        }
    }
    if (!any_lets) {
        return;
    }

    cem_emit_section_comment(self.emitter, "Top-level let declarations");
    for (let i = 0; i < driver_unit_count(self.result.driver_state); i = i + 1) {
        let unit = driver_unit_get(self.result.driver_state, i);
        if (unit.parse_result.root_module == null) {
            continue;
        }

        let root = unit.parse_result.root_module as Module*;
        self.current_module = root.name;
        self.current_unit = unit;
        self.current_env = be_find_env(self, root.name);

        let module_has_lets = false;
        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) != ord(TD_LET)) {
                continue;
            }
            if (!module_has_lets) {
                cem_emit_module_comment(self.emitter, root.name);
                module_has_lets = true;
            }

            let decl = top.data as LetDecl*;
            let let_type = sig_lookup_let_type(self.result.signatures as SignatureTables*, root.name, decl.name);
            if (let_type == null) {
                be_ice(concat4_s("[ICE-1151] missing Let type for ", root.name, ".", decl.name));
            }
            let c_init = be_emit_let_initializer(self, decl.value, let_type as Type*);
            cem_emit_let_declaration(self.emitter, root.name, decl, let_type as Type*, c_init);
        }
    }
}

/**
 * Emit all function declarations.
 *
 * @param self Backend state to update.
 */
func be_emit_function_declarations(self: Backend*) {
    if (self.result.signatures == null) {
        return;
    }

    cem_emit_section_comment(self.emitter, "Function declarations");
    for (let i = 0; i < driver_unit_count(self.result.driver_state); i = i + 1) {
        let unit = driver_unit_get(self.result.driver_state, i);
        if (unit.parse_result.root_module == null) {
            continue;
        }

        let root = unit.parse_result.root_module as Module*;
        cem_emit_module_comment(self.emitter, root.name);
        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) != ord(TD_FUNC)) {
                continue;
            }
            let decl = top.data as FuncDecl*;
            let func_type = sig_lookup_func_type(self.result.signatures as SignatureTables*, root.name, decl.name);
            if (func_type == null) {
                be_ice(concat4_s("[ICE-1150] missing FuncType for ", root.name, ".", decl.name));
            }
            cem_emit_function_declaration(self.emitter, root.name, decl, func_type as Type*);
        }
    }
}

/**
 * Emit one local or module lvalue.
 *
 * @param self Backend state to inspect.
 * @param expr_id Target expression id.
 * @return Lowered lvalue expression.
 */
func be_emit_lvalue(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    match (expr.kind) {
        EX_UNARY => {
            if (eq_s(expr.text_value, "*") && be_has_side_effects(self, expr.expr_a)) {
                with (let ptr_ty = be_expr_type(self, expr.expr_a) => type_free_opt(ptr_ty)) {
                    if (ptr_ty == null) {
                        return be_ice_string("[ICE-1242] missing type for dereference operand");
                    }
                    let ptr_temp = cem_fresh_tmp(self.emitter, "ptr");
                    let c_ptr_expr = be_emit_expr(self, expr.expr_a);
                    cem_emit_temp_decl(self.emitter, cem_emit_type(ptr_ty as Type*), ptr_temp, c_ptr_expr);
                    return cem_emit_deref_lvalue(ptr_temp);
                }
            }
        }
        EX_FIELD => {
            if (be_has_side_effects(self, expr.expr_a)) {
                with (let obj_ty = be_expr_type(self, expr.expr_a) => type_free_opt(obj_ty)) {
                    if (obj_ty == null) {
                        return be_ice_string("[ICE-1243] missing type for field access object");
                    }
                    let obj_temp = cem_fresh_tmp(self.emitter, "obj");
                    let c_obj_expr = be_emit_expr(self, expr.expr_a);
                    cem_emit_temp_decl(self.emitter, cem_emit_type(obj_ty as Type*), obj_temp, c_obj_expr);
                    let is_pointer = ord((obj_ty as Type*).kind) == ord(TY_POINTER);
                    return cem_emit_field_lvalue(obj_temp, expr.text_value, is_pointer);
                }
            }
        }
        EX_INDEX => {
            let base_has_effects = be_has_side_effects(self, expr.expr_a);
            let index_has_effects = be_has_side_effects(self, expr.expr_b);
            if (base_has_effects || index_has_effects) {
                let final_base = be_emit_expr(self, expr.expr_a);
                let final_index = be_emit_expr(self, expr.expr_b);

                if (base_has_effects) {
                    with (let base_ty = be_expr_type(self, expr.expr_a) => type_free_opt(base_ty)) {
                        if (base_ty == null) {
                            return be_ice_string("[ICE-1244] missing type for index base");
                        }
                        let base_temp = cem_fresh_tmp(self.emitter, "base");
                        cem_emit_temp_decl(self.emitter, cem_emit_type(base_ty as Type*), base_temp, final_base);
                        final_base = base_temp;
                    }
                }

                if (index_has_effects) {
                    let idx_temp = cem_fresh_tmp(self.emitter, "idx");
                    cem_emit_temp_decl(self.emitter, "l0_int", idx_temp, final_index);
                    final_index = idx_temp;
                }

                return cem_emit_index_lvalue(final_base, final_index);
            }
        }
        EX_PAREN => {
            return be_emit_lvalue(self, expr.expr_a);
        }
        _ => {}
    }
    return be_emit_expr(self, expr_id);
}

/**
 * Emit one binary operation.
 *
 * @param self Backend state to inspect.
 * @param expr_id Binary expression id.
 * @return Lowered binary expression.
 */
func be_emit_binary_op(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    let left = expr_arena_get(be_current_expr_arena(self), expr.expr_a);
    let right = expr_arena_get(be_current_expr_arena(self), expr.expr_b);

    if (eq_s(expr.text_value, "&&") || eq_s(expr.text_value, "||")) {
        return be_emit_condition_value(self, expr_id);
    }

    if ((eq_s(expr.text_value, "==") || eq_s(expr.text_value, "!=")) &&
        (ord(left.kind) == ord(EX_NULL) || ord(right.kind) == ord(EX_NULL))) {
        let other_id = expr.expr_a;
        if (ord(left.kind) == ord(EX_NULL)) {
            other_id = expr.expr_b;
        }

        with (let other_ty = be_expr_type(self, other_id) => type_free_opt(other_ty)) {
            let c_other = be_emit_expr(self, other_id);
            if (other_ty != null && ord((other_ty as Type*).kind) == ord(TY_NULLABLE) &&
                !cem_is_niche_nullable(other_ty as Type*)) {
                if (eq_s(expr.text_value, "==")) {
                    return cem_emit_null_check_eq(c_other);
                }
                return cem_emit_null_check_ne(c_other);
            }
            return cem_emit_pointer_null_check(c_other, expr.text_value);
        }
    }

    let c_left = be_emit_expr(self, expr.expr_a);
    let c_right = be_emit_expr(self, expr.expr_b);
    if (eq_s(expr.text_value, "/")) {
        return cem_emit_checked_int_div(c_left, c_right);
    }
    if (eq_s(expr.text_value, "%")) {
        return cem_emit_checked_int_mod(c_left, c_right);
    }
    if (eq_s(expr.text_value, "*")) {
        return cem_emit_checked_int_mul(c_left, c_right);
    }
    if (eq_s(expr.text_value, "+")) {
        return cem_emit_checked_int_add(c_left, c_right);
    }
    if (eq_s(expr.text_value, "-")) {
        return cem_emit_checked_int_sub(c_left, c_right);
    }
    return cem_emit_binary_op(expr.text_value, c_left, c_right);
}

/**
 * Emit one struct or enum-variant constructor.
 *
 * @param self Backend state to inspect.
 * @param expr_id Call expression id.
 * @param sym Resolved constructor symbol.
 * @param result_ty Inferred result type of the call.
 * @return Lowered constructor expression.
 */
func be_emit_constructor_call(self: Backend*, expr_id: ExprId, sym: Symbol*, result_ty: Type*) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    if (ord((sym as Symbol*).kind) == ord(SYM_STRUCT)) {
        let info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, result_ty.module_name, result_ty.name);
        if (info == null) {
            return be_ice_string("[ICE-1040] missing StructInfo for constructor");
        }
        with (let field_inits = vs_create(8) => vs_free(field_inits)) {
            let struct_info = info as StructInfo*;
            for (let i = 0; i < vec_size(struct_info.fields); i = i + 1) {
                let field = ptr_vec_get(struct_info.fields, i) as StructFieldInfo*;
                vs_push(field_inits, field.name);
                vs_push(field_inits,
                    be_emit_owned_expr_with_expected_type(self, id_vec_get(expr.ids as VectorBase*, i), field.field_type));
            }
            return cem_emit_struct_constructor_for_type(result_ty, field_inits);
        }
    }

    if (ord((sym as Symbol*).kind) == ord(SYM_ENUM_VARIANT)) {
        let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, result_ty.module_name, result_ty.name);
        if (enum_info == null) {
            return be_ice_string("[ICE-1050] missing EnumInfo for constructor");
        }
        let variant_name = sym.name;
        let variant_info = cem_find_enum_variant_info(enum_info as EnumInfo*, variant_name);
        if (variant_info == null) {
            return be_ice_string("[ICE-1051] missing VariantInfo for constructor");
        }
        let variant_decl = be_find_variant_decl(self, result_ty.module_name, result_ty.name, variant_name);
        if (variant_decl == null) {
            return be_ice_string("[ICE-1052] missing EnumVariant decl for constructor");
        }
        with (let payload_inits = vs_create(8) => vs_free(payload_inits)) {
            let info2 = variant_info as EnumVariantInfo*;
            for (let i = 0; i < vec_size(info2.field_types); i = i + 1) {
                let field_decl = ptr_vec_get((variant_decl as EnumVariant*).fields, i) as FieldDecl*;
                vs_push(payload_inits, field_decl.name);
                vs_push(payload_inits,
                    be_emit_owned_expr_with_expected_type(self, id_vec_get(expr.ids as VectorBase*, i),
                        ptr_vec_get(info2.field_types, i) as Type*));
            }
            return cem_emit_variant_constructor_for_type(result_ty, variant_name, payload_inits);
        }
    }

    return be_ice_string("[ICE-1100] unsupported constructor symbol");
}

/**
 * Emit one call expression.
 *
 * @param self Backend state to inspect.
 * @param expr_id Call expression id.
 * @return Lowered call expression.
 */
func be_emit_call(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    let callee = expr_arena_get(be_current_expr_arena(self), expr.expr_a);

    if (ord(callee.kind) == ord(EX_VAR_REF)) {
        if (eq_s(callee.text_value, "sizeof") && expr.ids != null && vec_size(expr.ids as VectorBase*) == 1) {
            let arg = expr_arena_get(be_current_expr_arena(self), id_vec_get(expr.ids as VectorBase*, 0));
            if (ord(arg.kind) == ord(EX_TYPE) && arg.type_ref != null) {
                with (let target_ty = be_resolve_type_ref(self, arg.type_ref as TypeRef*) => type_free_opt(target_ty)) {
                    if (target_ty == null) {
                        return be_ice_string("[ICE-2268] failed to resolve sizeof target type");
                    }
                    return cem_emit_sizeof_type(target_ty as Type*);
                }
            }
            with (let target_ty2 = analysis_get_intrinsic_target(self.result, self.current_module as string, expr_id)
                    => type_free_opt(target_ty2)) {
                if (target_ty2 == null) {
                    return be_ice_string("[ICE-2268] failed to resolve sizeof target type");
                }
                return cem_emit_sizeof_type(target_ty2 as Type*);
            }
        }

        if (eq_s(callee.text_value, "ord") && expr.ids != null && vec_size(expr.ids as VectorBase*) == 1) {
            return cem_emit_ord(be_emit_expr(self, id_vec_get(expr.ids as VectorBase*, 0)));
        }

        let sym = be_lookup_symbol(self, callee.text_value, callee.module_path, callee.name_qualifier);
        if (sym != null) {
            with (let result_ty = be_expr_type(self, expr_id) => type_free_opt(result_ty)) {
                if (result_ty != null && (ord((sym as Symbol*).kind) == ord(SYM_STRUCT) ||
                    ord((sym as Symbol*).kind) == ord(SYM_ENUM_VARIANT))) {
                    return be_emit_constructor_call(self, expr_id, sym as Symbol*, result_ty as Type*);
                }
            }

            if (ord((sym as Symbol*).kind) == ord(SYM_FUNC)) {
                let c_func_name = "";
                let decl = (sym as Symbol*).decl_ptr as FuncDecl*;
                if (decl.is_extern) {
                    c_func_name = (sym as Symbol*).name;
                } else {
                    c_func_name = cem_mangle_function_name((sym as Symbol*).module_name, (sym as Symbol*).name);
                }

                let func_ty = sig_lookup_func_type(self.result.signatures as SignatureTables*, (sym as Symbol*).module_name,
                    (sym as Symbol*).name);
                with (let sb = sb_create() => sb_free(sb)) {
                    let arg_count = 0;
                    if (expr.ids != null) {
                        arg_count = vec_size(expr.ids as VectorBase*);
                    }
                    for (let i = 0; i < arg_count; i = i + 1) {
                        if (i > 0) {
                            sb_append(sb, ", ");
                        }
                        let arg_id = id_vec_get(expr.ids as VectorBase*, i);
                        if (func_ty != null && vec_size((func_ty as Type*).params as VectorBase*) == arg_count) {
                            let param_ty = ptr_vec_get((func_ty as Type*).params as VectorBase*, i) as Type*;
                            let c_arg = be_emit_expr_with_expected_type(self, arg_id, param_ty);
                            with (let arg_ty = be_expr_type(self, arg_id) => type_free_opt(arg_ty)) {
                                if (arg_ty != null && be_should_materialize_arc_temp(self, arg_id, arg_ty as Type*)) {
                                    c_arg = be_materialize_arc_temp(self, c_arg, arg_ty as Type*);
                                }
                                sb_append(sb, c_arg);
                            }
                        } else {
                            let c_arg2 = be_emit_expr(self, arg_id);
                            with (let arg_ty2 = be_expr_type(self, arg_id) => type_free_opt(arg_ty2)) {
                                if (arg_ty2 != null && be_should_materialize_arc_temp(self, arg_id, arg_ty2 as Type*)) {
                                    c_arg2 = be_materialize_arc_temp(self, c_arg2, arg_ty2 as Type*);
                                }
                                sb_append(sb, c_arg2);
                            }
                        }
                    }
                    return cem_emit_function_call(c_func_name, sb_to_string(sb));
                }
            }
        }
    }

    with (let sb2 = sb_create() => sb_free(sb2)) {
        let arg_count2 = 0;
        if (expr.ids != null) {
            arg_count2 = vec_size(expr.ids as VectorBase*);
        }
        for (let i = 0; i < arg_count2; i = i + 1) {
            if (i > 0) {
                sb_append(sb2, ", ");
            }
            let arg_id2 = id_vec_get(expr.ids as VectorBase*, i);
            let c_arg3 = be_emit_expr(self, arg_id2);
            with (let arg_ty3 = be_expr_type(self, arg_id2) => type_free_opt(arg_ty3)) {
                if (arg_ty3 != null && be_should_materialize_arc_temp(self, arg_id2, arg_ty3 as Type*)) {
                    c_arg3 = be_materialize_arc_temp(self, c_arg3, arg_ty3 as Type*);
                }
                sb_append(sb2, c_arg3);
            }
        }
        return cem_emit_function_call(cem_emit_paren_expr(be_emit_expr(self, expr.expr_a)), sb_to_string(sb2));
    }
}

/**
 * Emit one heap-allocation `new` expression.
 *
 * @param self Backend state to inspect.
 * @param expr_id New-expression id.
 * @return Lowered pointer expression.
 */
func be_emit_new_expr(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    with (let new_ty = be_expr_type(self, expr_id) => type_free_opt(new_ty)) {
        if (new_ty == null || ord((new_ty as Type*).kind) != ord(TY_POINTER)) {
            return be_ice_string("[ICE-1200] missing inferred pointer type for new expression");
        }

        let base_ty = ((new_ty as Type*).inner as Type*);
        let c_base = cem_emit_type(base_ty);
        let c_ptr_ty = cem_emit_pointer_type(base_ty);
        let tmp = cem_fresh_tmp(self.emitter, "new");
        cem_emit_alloc_obj(self.emitter, c_ptr_ty, c_base, tmp);

        let arg_count = 0;
        if (expr.ids != null) {
            arg_count = vec_size(expr.ids as VectorBase*);
        }

        if (arg_count == 0 && ord(base_ty.kind) != ord(TY_ENUM)) {
            cem_emit_zero_init(self.emitter, tmp, c_base);
            return tmp;
        }

        if (ord(base_ty.kind) == ord(TY_STRUCT)) {
            let info = sig_lookup_struct_info(self.result.signatures as SignatureTables*, base_ty.module_name, base_ty.name);
            if (info == null) {
                return be_ice_string(concat4_s("[ICE-1210] missing StructInfo for ", base_ty.module_name, ".", base_ty.name));
            }
            with (let field_inits = vs_create(8) => vs_free(field_inits)) {
                for (let i = 0; i < arg_count; i = i + 1) {
                    let field = ptr_vec_get((info as StructInfo*).fields, i) as StructFieldInfo*;
                    vs_push(field_inits, field.name);
                    vs_push(field_inits,
                        be_emit_owned_expr_with_expected_type(self, id_vec_get(expr.ids as VectorBase*, i), field.field_type));
                }
                cem_emit_struct_init_from_fields(self.emitter, tmp, base_ty, field_inits);
                return tmp;
            }
        }

        if (ord(base_ty.kind) == ord(TY_ENUM)) {
            let variant_name = "";
            if (expr.type_ref != null) {
                variant_name = (expr.type_ref as TypeRef*).name;
            }
            let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, base_ty.module_name, base_ty.name);
            if (enum_info == null) {
                return be_ice_string("[ICE-1220] new enum allocation missing variant symbol");
            }
            let variant_decl = be_find_variant_decl(self, base_ty.module_name, base_ty.name, variant_name);
            let variant_info = cem_find_enum_variant_info(enum_info as EnumInfo*, variant_name);
            if (variant_decl == null || variant_info == null) {
                return be_ice_string("[ICE-1220] new enum allocation missing variant symbol");
            }
            with (let payload_inits = vs_create(8) => vs_free(payload_inits)) {
                for (let i = 0; i < arg_count; i = i + 1) {
                    let field_decl = ptr_vec_get((variant_decl as EnumVariant*).fields, i) as FieldDecl*;
                    let field_ty = ptr_vec_get((variant_info as EnumVariantInfo*).field_types, i) as Type*;
                    vs_push(payload_inits, field_decl.name);
                    vs_push(payload_inits,
                        be_emit_owned_expr_with_expected_type(self, id_vec_get(expr.ids as VectorBase*, i), field_ty));
                }
                cem_emit_enum_variant_init(self.emitter, tmp, base_ty, variant_name, payload_inits);
                return tmp;
            }
        }

        if (arg_count == 1) {
            cem_emit_pointer_assignment(self.emitter, tmp, be_emit_expr(self, id_vec_get(expr.ids as VectorBase*, 0)));
            return tmp;
        }

        return be_ice_string(concat3_s("[ICE-1231] unsupported new expression for type '", type_format(base_ty), "'"));
    }
}

/**
 * Emit one expression.
 *
 * @param self Backend state to inspect.
 * @param expr_id Expression id to lower.
 * @return Lowered expression string.
 */
func be_emit_expr(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    match (expr.kind) {
        EX_INT => { return cem_emit_int_literal(expr.int_value); }
        EX_BYTE => { return cem_emit_byte_literal(expr.int_value as byte); }
        EX_STRING => { return cem_emit_string_literal(expr.text_value); }
        EX_BOOL => { return cem_emit_bool_literal(expr.bool_value); }
        EX_NULL => {
            with (let expected_ty = be_expr_type(self, expr_id) => type_free_opt(expected_ty)) {
                if (expected_ty == null) {
                    return be_ice_string("[ICE-1091] missing expected type for null literal");
                }
                return cem_emit_null_literal(expected_ty as Type*, false);
            }
        }
        EX_VAR_REF => {
            let res = analysis_get_var_ref_resolution(self.result, self.current_module as string, expr_id);
            if (res != null && (res as int) == ord(VAR_RES_LOCAL)) {
                return cem_emit_var_ref(cem_mangle_identifier(expr.text_value));
            }

            let sym = be_lookup_symbol(self, expr.text_value, expr.module_path, expr.name_qualifier);
            if (sym == null) {
                return be_ice_string(concat4_s("[ICE-1103] unresolved variable reference after type checking: ",
                    self.current_module as string, "::", expr.text_value));
            }

            if (ord((sym as Symbol*).kind) == ord(SYM_FUNC)) {
                let decl = (sym as Symbol*).decl_ptr as FuncDecl*;
                if (decl.is_extern) {
                    return cem_emit_var_ref((sym as Symbol*).name);
                }
                return cem_emit_var_ref(cem_mangle_function_name((sym as Symbol*).module_name, (sym as Symbol*).name));
            }

            if (ord((sym as Symbol*).kind) == ord(SYM_LET)) {
                return cem_emit_var_ref(cem_mangle_let_name((sym as Symbol*).module_name, (sym as Symbol*).name));
            }

            if (ord((sym as Symbol*).kind) == ord(SYM_ENUM_VARIANT)) {
                with (let expr_ty = be_expr_type(self, expr_id) => type_free_opt(expr_ty),
                      let payload = vs_create(0) => vs_free(payload)) {
                    if (expr_ty == null) {
                        return be_ice_string("[ICE-1104] missing enum type for bare variant constructor");
                    }
                    return cem_emit_variant_constructor_for_type(expr_ty as Type*, (sym as Symbol*).name, payload);
                }
            }

            return be_ice_string("[ICE-1102] unsupported module-level variable reference");
        }
        EX_UNARY => {
            return cem_emit_unary_op(expr.text_value, be_emit_expr(self, expr.expr_a));
        }
        EX_BINARY => { return be_emit_binary_op(self, expr_id); }
        EX_CALL => { return be_emit_call(self, expr_id); }
        EX_INDEX => {
            return cem_emit_index_lvalue(be_emit_expr(self, expr.expr_a), be_emit_expr(self, expr.expr_b));
        }
        EX_FIELD => {
            with (let obj_ty = be_expr_type(self, expr.expr_a) => type_free_opt(obj_ty)) {
                let is_pointer = obj_ty != null && ord((obj_ty as Type*).kind) == ord(TY_POINTER);
                return cem_emit_field_access(be_emit_expr(self, expr.expr_a), expr.text_value, is_pointer);
            }
        }
        EX_PAREN => { return cem_emit_paren_expr(be_emit_expr(self, expr.expr_a)); }
        EX_CAST => {
            with (let src_ty = be_expr_type(self, expr.expr_a) => type_free_opt(src_ty),
                  let dst_ty = be_resolve_type_ref(self, expr.type_ref as TypeRef*) => type_free_opt(dst_ty)) {
                if (dst_ty == null) {
                    return be_ice_string("[ICE-1110] failed to resolve cast target type");
                }
                let c_inner = be_emit_expr(self, expr.expr_a);
                let c_dst = cem_emit_type(dst_ty as Type*);

                if (src_ty != null &&
                    be_is_int_assignable(src_ty as Type*) &&
                    be_is_int_assignable(dst_ty as Type*) &&
                    be_int_type_size(src_ty as Type*) > be_int_type_size(dst_ty as Type*)) {
                    return cem_emit_checked_narrow_cast(c_dst, c_inner);
                }

                if (ord((dst_ty as Type*).kind) == ord(TY_NULLABLE)) {
                    if (src_ty != null && type_equals((dst_ty as Type*).inner as Type*, src_ty as Type*)) {
                        if (cem_is_niche_nullable(dst_ty as Type*)) {
                            return cem_emit_cast(c_dst, c_inner);
                        }
                        return cem_emit_some_value_for_nullable(dst_ty as Type*, c_inner);
                    }
                }

                if (src_ty != null && ord((src_ty as Type*).kind) == ord(TY_NULLABLE) &&
                    type_equals(((src_ty as Type*).inner as Type*), dst_ty as Type*)) {
                    if (cem_is_niche_nullable(src_ty as Type*)) {
                        return cem_emit_unwrap_ptr(c_dst, c_inner, type_format(src_ty as Type*));
                    }
                    let tmp = cem_fresh_tmp(self.emitter, "unwrap");
                    cem_emit_temp_decl(self.emitter, cem_emit_type(src_ty as Type*), tmp, c_inner);
                    return cem_emit_unwrap_opt(cem_emit_type(src_ty as Type*), tmp, type_format(src_ty as Type*));
                }

                return cem_emit_cast(c_dst, c_inner);
            }
        }
        EX_TYPE => {
            return be_ice_string("[ICE-9149] bare type expression cannot be emitted directly");
        }
        EX_NEW => {
            return be_emit_new_expr(self, expr_id);
        }
        EX_TRY => {
            with (let src_ty = be_expr_type(self, expr.expr_a) => type_free_opt(src_ty)) {
                if (src_ty == null || ord((src_ty as Type*).kind) != ord(TY_NULLABLE)) {
                    return be_ice_string("[ICE-1130] TryExpr operand is not nullable");
                }
                if (self.current_func_result == null || ord((self.current_func_result as Type*).kind) != ord(TY_NULLABLE)) {
                    return be_ice_string("[ICE-1131] TryExpr used in non-nullable function");
                }

                let tmp = cem_fresh_tmp(self.emitter, "try");
                cem_emit_temp_decl(self.emitter, cem_emit_type(src_ty as Type*), tmp, be_emit_expr(self, expr.expr_a));
                let ret_none = cem_emit_null_literal(self.current_func_result as Type*, false);

                if (cem_is_niche_nullable(src_ty as Type*)) {
                    if (be_scope_chain_has_cleanup(self)) {
                        cem_emit_if_header(self.emitter, cem_emit_pointer_null_check(tmp, "=="));
                        cem_emit_block_start(self.emitter);
                        be_emit_cleanup_for_return(self, null);
                        cem_emit_return_stmt(self.emitter, ret_none);
                        cem_emit_block_end(self.emitter);
                    } else {
                        cem_emit_try_check_niche(self.emitter, tmp, ret_none);
                    }
                    return tmp;
                }

                if (be_scope_chain_has_cleanup(self)) {
                    cem_emit_if_header(self.emitter, cem_emit_null_check_eq(tmp));
                    cem_emit_block_start(self.emitter);
                    be_emit_cleanup_for_return(self, null);
                    cem_emit_return_stmt(self.emitter, ret_none);
                    cem_emit_block_end(self.emitter);
                } else {
                    cem_emit_try_check_value(self.emitter, tmp, ret_none);
                }
                return cem_emit_try_extract_value(tmp);
            }
        }
    }
}

/**
 * Emit cleanup for one by-value expression.
 *
 * @param self Backend state to update.
 * @param c_expr Lowered value expression.
 * @param ty Type of the value.
 */
func be_emit_value_cleanup(self: Backend*, c_expr: string, ty: Type*) {
    cem_emit_value_cleanup(self.emitter, c_expr, ty);
}

/**
 * Emit cleanup for a pointer-to-struct expression.
 *
 * @param self Backend state to update.
 * @param c_ptr_expr Lowered pointer expression.
 * @param struct_type Struct type to clean.
 */
func be_emit_struct_cleanup(self: Backend*, c_ptr_expr: string, struct_type: Type*) {
    cem_emit_struct_cleanup(self.emitter, c_ptr_expr, struct_type);
}

/**
 * Emit cleanup for a pointer-to-enum expression.
 *
 * @param self Backend state to update.
 * @param c_ptr_expr Lowered pointer expression.
 * @param enum_type Enum type to clean.
 */
func be_emit_enum_cleanup(self: Backend*, c_ptr_expr: string, enum_type: Type*) {
    cem_emit_enum_cleanup(self.emitter, c_ptr_expr, enum_type);
}

/**
 * Emit cleanup for owned values declared in one scope.
 *
 * @param self Backend state to update.
 * @param scope Scope to clean.
 */
func be_emit_cleanup_at_scope_exit(self: Backend*, scope: ScopeContext*) {
    for (let i = vec_size(scope.owned_vars) - 1; i >= 0; i = i - 1) {
        let item = ptr_vec_get(scope.owned_vars, i) as ScopeVar*;
        if (analysis_has_arc_data(self.result, item.var_type)) {
            be_emit_value_cleanup(self, item.name, item.var_type);
        }
    }
}

/**
 * Emit `with` cleanup recorded on one scope.
 *
 * @param self Backend state to update.
 * @param scope Scope carrying `with` cleanup state.
 */
func be_emit_with_cleanup_from_scope(self: Backend*, scope: ScopeContext*) {
    if (scope.with_cleanup_block < 0 && !sc_has_inline_cleanup(scope)) {
        return;
    }

    let old = scope.with_cleanup_in_progress;
    scope.with_cleanup_in_progress = true;
    cem_emit_block_start(self.emitter);
    let cleanup_scope = be_push_scope(self);

    if (scope.with_cleanup_block >= 0) {
        be_emit_block_sequence(self, scope.with_cleanup_block);
    } else {
        let items = scope.with_cleanup_inline as VectorBase*;
        for (let i = vec_size(items) - 1; i >= 0; i = i - 1) {
            be_emit_stmt(self, id_vec_get(items, i));
        }
    }

    if (!self.next_stmt_unreachable) {
        be_emit_cleanup_at_scope_exit(self, cleanup_scope);
    }
    be_pop_scope(self);
    cem_emit_block_end(self.emitter);
    scope.with_cleanup_in_progress = old;
}

/**
 * Emit cleanup required before returning from the current function.
 *
 * @param self Backend state to update.
 * @param returned_var Optional owned local to keep alive across cleanup.
 */
func be_emit_cleanup_for_return(self: Backend*, returned_var: string?) {
    let scope = self.current_scope;
    while (scope != null) {
        let cur = scope as ScopeContext*;
        if (((cur.with_cleanup_block >= 0) || sc_has_inline_cleanup(cur)) && !cur.with_cleanup_in_progress) {
            be_emit_with_cleanup_from_scope(self, cur);
        }
        for (let i = vec_size(cur.owned_vars) - 1; i >= 0; i = i - 1) {
            let item = ptr_vec_get(cur.owned_vars, i) as ScopeVar*;
            if (returned_var != null && eq_s(item.name, returned_var as string)) {
                continue;
            }
            if (analysis_has_arc_data(self.result, item.var_type)) {
                be_emit_value_cleanup(self, item.name, item.var_type);
            }
        }
        scope = cur.parent;
    }
}

/**
 * Emit cleanup required before breaking or continuing out of the innermost loop.
 *
 * @param self Backend state to update.
 * @param is_break `true` for break, `false` for continue.
 */
func be_emit_cleanup_for_loop_exit(self: Backend*, is_break: bool) {
    if (self.current_loop_cleanup_scopes == null) {
        be_ice("[ICE-1020] break/continue outside of loop");
    }

    let frame = self.current_loop_cleanup_scopes as LoopCleanupScopes*;
    let target_scope_id = frame.continue_scope_id;
    if (is_break) {
        target_scope_id = frame.break_scope_id;
    }

    let scope = self.current_scope;
    while (scope != null) {
        let cur = scope as ScopeContext*;
        if (((cur.with_cleanup_block >= 0) || sc_has_inline_cleanup(cur)) && !cur.with_cleanup_in_progress) {
            be_emit_with_cleanup_from_scope(self, cur);
        }
        for (let i = vec_size(cur.owned_vars) - 1; i >= 0; i = i - 1) {
            let item = ptr_vec_get(cur.owned_vars, i) as ScopeVar*;
            if (analysis_has_arc_data(self.result, item.var_type)) {
                be_emit_value_cleanup(self, item.name, item.var_type);
            }
        }
        if (cur.scope_id == target_scope_id) {
            break;
        }
        scope = cur.parent;
    }
}

/**
 * Emit one match-pattern payload binding set.
 *
 * @param self Backend state to update.
 * @param pattern_id Pattern id to inspect.
 * @param enum_type Scrutinee enum type.
 * @param arm_scope Arm scope receiving borrowed bindings.
 */
func be_emit_pattern_bindings(self: Backend*, pattern_id: PatternId, enum_type: Type*, arm_scope: ScopeContext*) {
    let pattern = pattern_arena_get(be_current_unit(self).parse_result.pattern_arena, pattern_id);
    if (ord(pattern.kind) != ord(PT_VARIANT)) {
        return;
    }

    let variant_decl = be_find_variant_decl(self, enum_type.module_name, enum_type.name, pattern.name);
    let enum_info = sig_lookup_enum_info(self.result.signatures as SignatureTables*, enum_type.module_name, enum_type.name);
    if (variant_decl == null || enum_info == null) {
        return;
    }

    let variant_info = cem_find_enum_variant_info(enum_info as EnumInfo*, pattern.name);
    if (variant_info == null || pattern.vars == null) {
        return;
    }

    for (let i = 0; i < vs_size(pattern.vars as VectorString*); i = i + 1) {
        let field_decl = ptr_vec_get((variant_decl as EnumVariant*).fields, i) as FieldDecl*;
        let field_ty = ptr_vec_get((variant_info as EnumVariantInfo*).field_types, i) as Type*;
        let c_name = cem_mangle_identifier(vs_get(pattern.vars as VectorString*, i));
        cem_emit_let_decl(self.emitter, cem_emit_type(field_ty), c_name,
            cem_emit_pattern_binding_init("_scrutinee", pattern.name, field_decl.name));
        sc_add_declared(arm_scope, c_name, field_ty);
    }
}

/**
 * Emit one `case` literal.
 *
 * @param self Backend state to inspect.
 * @param expr_id Literal expression id.
 * @return Lowered constant expression.
 */
func be_emit_case_literal(self: Backend*, expr_id: ExprId) -> string {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);
    match (expr.kind) {
        EX_INT => { return cem_emit_int_literal(expr.int_value); }
        EX_BYTE => { return cem_emit_byte_literal(expr.int_value as byte); }
        EX_BOOL => { return cem_emit_bool_literal(expr.bool_value); }
        EX_STRING => { return cem_emit_string_literal(expr.text_value); }
        _ => {
            return be_ice_string("[ICE-1194] unsupported case literal type");
        }
    }
}

/**
 * Emit a `drop` statement.
 *
 * @param self Backend state to update.
 * @param stmt Parsed drop statement.
 */
func be_emit_drop_stmt(self: Backend*, stmt: StmtNode*) {
    let c_name = cem_mangle_identifier(stmt.name);
    let var_type = be_lookup_local_var_type(self, stmt.name);
    if (var_type == null) {
        let sym = be_lookup_symbol(self, stmt.name, null, null);
        if (sym == null) {
            be_ice(concat3_s("[ICE-1060] undefined variable in drop: ", stmt.name, ""));
        }
        var_type = (sym as Symbol*).resolved_type;
    }
    if (var_type == null) {
        be_ice("[ICE-1060] drop requires resolved variable type");
    }

    let inner_type = var_type as Type*;
    if (ord((var_type as Type*).kind) == ord(TY_NULLABLE)) {
        inner_type = ((var_type as Type*).inner as Type*);
    }
    if (ord(inner_type.kind) != ord(TY_POINTER)) {
        be_ice(concat3_s("[ICE-1061] drop requires pointer type, got '", type_format(var_type as Type*), "'"));
    }

    let pointee = inner_type.inner as Type*;
    if (ord(pointee.kind) == ord(TY_STRUCT)) {
        be_emit_struct_cleanup(self, c_name, pointee);
    } else if (ord(pointee.kind) == ord(TY_ENUM)) {
        be_emit_enum_cleanup(self, c_name, pointee);
    } else if (analysis_is_arc_type(pointee)) {
        cem_emit_if_header(self.emitter, cem_emit_pointer_null_check(c_name, "!="));
        cem_emit_block_start(self.emitter);
        cem_emit_string_release(self.emitter, concat3_s("*", c_name, ""));
        cem_emit_block_end(self.emitter);
    }

    cem_emit_drop_call(self.emitter, c_name);
    cem_emit_null_assignment(self.emitter, c_name);
    self.next_stmt_unreachable = false;
}

/**
 * Emit a `match` statement.
 *
 * @param self Backend state to update.
 * @param stmt Parsed match statement.
 */
func be_emit_match_stmt(self: Backend*, stmt: StmtNode*) {
    with (let scrutinee_ty = be_expr_type(self, stmt.expr_a) => type_free_opt(scrutinee_ty)) {
        if (scrutinee_ty == null) {
            be_ice("[ICE-1190] missing inferred type for match scrutinee");
        }

        cem_emit_block_start(self.emitter);
        let outer_scope = be_push_scope(self);
        cem_emit_match_scrutinee_decl(self.emitter, cem_emit_type(scrutinee_ty as Type*), be_emit_expr(self, stmt.expr_a));
        if (!be_is_place_expr(self, stmt.expr_a) && analysis_has_arc_data(self.result, scrutinee_ty as Type*)) {
            sc_add_owned(outer_scope, "_scrutinee", scrutinee_ty as Type*);
        }

        cem_emit_match_switch_start(self.emitter, "_scrutinee");
        let arms = stmt.match_arms as VectorBase*;
        let unreachable_arms = 0;
        for (let i = 0; i < vec_size(arms); i = i + 1) {
            let arm = ptr_vec_get(arms, i) as MatchArm*;
            let pattern = pattern_arena_get(be_current_unit(self).parse_result.pattern_arena, arm.pattern);
            if (ord(pattern.kind) == ord(PT_WILDCARD)) {
                cem_emit_default_label(self.emitter);
            } else if (ord(pattern.kind) == ord(PT_VARIANT) && ord((scrutinee_ty as Type*).kind) == ord(TY_ENUM)) {
                cem_emit_case_label(self.emitter, cem_emit_enum_tag(scrutinee_ty as Type*, pattern.name));
            } else {
                be_ice("[ICE-1192] unsupported match pattern");
            }

            cem_emit_block_start(self.emitter);
            let arm_scope = be_push_scope(self);
            self.next_stmt_unreachable = false;
            if (ord(pattern.kind) == ord(PT_VARIANT) && ord((scrutinee_ty as Type*).kind) == ord(TY_ENUM)) {
                be_emit_pattern_bindings(self, arm.pattern, scrutinee_ty as Type*, arm_scope);
            }
            be_emit_block_sequence(self, arm.body);
            if (!self.next_stmt_unreachable) {
                be_emit_cleanup_at_scope_exit(self, arm_scope);
                cem_emit_exit_switch(self.emitter);
            } else {
                unreachable_arms = unreachable_arms + 1;
            }
            be_pop_scope(self);
            cem_emit_block_end(self.emitter);
        }
        cem_emit_switch_end(self.emitter);
        self.next_stmt_unreachable = unreachable_arms == vec_size(arms);
        if (!self.next_stmt_unreachable) {
            be_emit_cleanup_at_scope_exit(self, outer_scope);
        } else {
            cem_emit_unreachable_marker(self.emitter, "'match'");
        }
        be_pop_scope(self);
        cem_emit_block_end(self.emitter);
    }
}

/**
 * Emit a `case` statement.
 *
 * @param self Backend state to update.
 * @param stmt Parsed case statement.
 */
func be_emit_case_stmt(self: Backend*, stmt: StmtNode*) {
    with (let scrutinee_ty = be_expr_type(self, stmt.expr_a) => type_free_opt(scrutinee_ty)) {
        if (scrutinee_ty == null) {
            be_ice("[ICE-1193] missing inferred type for case scrutinee");
        }

        cem_emit_block_start(self.emitter);
        let outer_scope = be_push_scope(self);
        cem_emit_match_scrutinee_decl(self.emitter, cem_emit_type(scrutinee_ty as Type*), be_emit_expr(self, stmt.expr_a));
        if (!be_is_place_expr(self, stmt.expr_a) && analysis_has_arc_data(self.result, scrutinee_ty as Type*)) {
            sc_add_owned(outer_scope, "_scrutinee", scrutinee_ty as Type*);
        }

        let arms = stmt.case_arms as VectorBase*;
        let total_arms = vec_size(arms);
        if (stmt.case_else != null) {
            total_arms = total_arms + 1;
        }
        let unreachable_arms = 0;

        if (type_is_builtin(scrutinee_ty as Type*, "string")) {
            for (let i = 0; i < vec_size(arms); i = i + 1) {
                let arm = ptr_vec_get(arms, i) as CaseArm*;
                let cond = cem_emit_string_equals_call("_scrutinee", be_emit_case_literal(self, arm.literal));
                if (i == 0) {
                    cem_emit_if_header(self.emitter, cond);
                } else {
                    cem_emit_else(self.emitter);
                    cem_emit_if_header(self.emitter, cond);
                }
                cem_emit_block_start(self.emitter);
                let arm_scope = be_push_scope(self);
                self.next_stmt_unreachable = false;
                be_emit_stmt(self, arm.body);
                if (!self.next_stmt_unreachable) {
                    be_emit_cleanup_at_scope_exit(self, arm_scope);
                } else {
                    unreachable_arms = unreachable_arms + 1;
                }
                be_pop_scope(self);
                cem_emit_block_end(self.emitter);
            }
            if (stmt.case_else != null) {
                cem_emit_else(self.emitter);
                cem_emit_block_start(self.emitter);
                let else_scope = be_push_scope(self);
                self.next_stmt_unreachable = false;
                be_emit_stmt(self, (stmt.case_else as CaseElse*).body);
                if (!self.next_stmt_unreachable) {
                    be_emit_cleanup_at_scope_exit(self, else_scope);
                } else {
                    unreachable_arms = unreachable_arms + 1;
                }
                be_pop_scope(self);
                cem_emit_block_end(self.emitter);
            }
        } else {
            cem_emit_switch_start(self.emitter, "_scrutinee");
            for (let i = 0; i < vec_size(arms); i = i + 1) {
                let arm = ptr_vec_get(arms, i) as CaseArm*;
                cem_emit_case_label(self.emitter, be_emit_case_literal(self, arm.literal));
                cem_emit_block_start(self.emitter);
                let arm_scope = be_push_scope(self);
                self.next_stmt_unreachable = false;
                be_emit_stmt(self, arm.body);
                if (!self.next_stmt_unreachable) {
                    be_emit_cleanup_at_scope_exit(self, arm_scope);
                    cem_emit_exit_switch(self.emitter);
                } else {
                    unreachable_arms = unreachable_arms + 1;
                }
                be_pop_scope(self);
                cem_emit_block_end(self.emitter);
            }
            if (stmt.case_else != null) {
                cem_emit_default_label(self.emitter);
                cem_emit_block_start(self.emitter);
                let else_scope2 = be_push_scope(self);
                self.next_stmt_unreachable = false;
                be_emit_stmt(self, (stmt.case_else as CaseElse*).body);
                if (!self.next_stmt_unreachable) {
                    be_emit_cleanup_at_scope_exit(self, else_scope2);
                    cem_emit_exit_switch(self.emitter);
                } else {
                    unreachable_arms = unreachable_arms + 1;
                }
                be_pop_scope(self);
                cem_emit_block_end(self.emitter);
            }
            cem_emit_switch_end(self.emitter);
        }

        self.next_stmt_unreachable = stmt.case_else != null && unreachable_arms == total_arms;
        if (!self.next_stmt_unreachable) {
            be_emit_cleanup_at_scope_exit(self, outer_scope);
        } else {
            cem_emit_unreachable_marker(self.emitter, "'case'");
        }
        be_pop_scope(self);
        cem_emit_block_end(self.emitter);
    }
}

/**
 * Emit a `with` statement.
 *
 * @param self Backend state to update.
 * @param stmt Parsed with statement.
 */
func be_emit_with_stmt(self: Backend*, stmt: StmtNode*) {
    cem_emit_block_start(self.emitter);
    let with_scope = be_push_scope(self);
    if (stmt.stmt_b >= 0) {
        with_scope.with_cleanup_block = stmt.stmt_b;
    }

    let items = stmt.with_items as VectorBase*;
    if (stmt.stmt_b >= 0) {
        with (let predecl_types = spm_create() => be_type_ptr_map_temp_free(predecl_types)) {
            for (let i = 0; i < vec_size(items); i = i + 1) {
                let item = ptr_vec_get(items, i) as WithItem*;
                let init_stmt = stmt_arena_get(be_current_stmt_arena(self), item.init);
                if (ord(init_stmt.kind) == ord(ST_LET)) {
                    let predecl_ty = be_emit_with_cleanup_header_let_predecl(self, init_stmt);
                    if (predecl_ty != null) {
                        spm_put(predecl_types, int_to_string(i), predecl_ty as void*);
                    }
                }
            }

            for (let item_i = 0; item_i < vec_size(items); item_i = item_i + 1) {
                let item = ptr_vec_get(items, item_i) as WithItem*;
                let init_stmt = stmt_arena_get(be_current_stmt_arena(self), item.init);
                let predecl_ty = spm_get(predecl_types, int_to_string(item_i));
                if (predecl_ty != null && ord(init_stmt.kind) == ord(ST_LET)) {
                    be_emit_with_cleanup_header_let_assign(self, init_stmt, predecl_ty as Type*);
                } else {
                    be_emit_stmt(self, item.init);
                }
            }
        }
    } else {
        for (let i = 0; i < vec_size(items); i = i + 1) {
            let item = ptr_vec_get(items, i) as WithItem*;
            be_emit_stmt(self, item.init);
            if (item.has_cleanup && item.cleanup_stmt >= 0) {
                sc_push_inline_cleanup(with_scope, item.cleanup_stmt);
            }
        }
    }

    cem_emit_block_start(self.emitter);
    let body_scope = be_push_scope(self);
    be_emit_block_sequence(self, stmt.stmt_a);
    let body_unreachable = self.next_stmt_unreachable;
    if (!body_unreachable) {
        be_emit_cleanup_at_scope_exit(self, body_scope);
    }
    be_pop_scope(self);
    cem_emit_block_end(self.emitter);

    if (!body_unreachable) {
        be_emit_with_cleanup_from_scope(self, with_scope);
        be_emit_cleanup_at_scope_exit(self, with_scope);
    }
    self.next_stmt_unreachable = body_unreachable;
    be_pop_scope(self);
    cem_emit_block_end(self.emitter);
}

/**
 * Emit one block body sequence without outer braces.
 *
 * @param self Backend state to update.
 * @param block_id Block statement id.
 */
func be_emit_block_sequence(self: Backend*, block_id: StmtId) {
    self.next_stmt_unreachable = false;
    let block = stmt_arena_get(be_current_stmt_arena(self), block_id);
    if (ord(block.kind) != ord(ST_BLOCK) || block.ids == null) {
        return;
    }

    let ids = block.ids as VectorBase*;
    for (let i = 0; i < vec_size(ids); i = i + 1) {
        if (self.next_stmt_unreachable) {
            cem_emit_unreachable_comment(self.emitter);
            self.next_stmt_unreachable = false;
        }
        be_emit_stmt(self, id_vec_get(ids, i));
    }
}

/**
 * Emit one lexical block statement.
 *
 * @param self Backend state to update.
 * @param stmt_id Block statement id.
 */
func be_emit_block_stmt(self: Backend*, stmt_id: StmtId) {
    cem_emit_block_start(self.emitter);
    let block_scope = be_push_scope(self);
    be_emit_block_sequence(self, stmt_id);
    if (!self.next_stmt_unreachable) {
        be_emit_cleanup_at_scope_exit(self, block_scope);
    }
    be_pop_scope(self);
    cem_emit_block_end(self.emitter);
}

/**
 * Emit control flow for one statement condition with short-circuit semantics.
 *
 * ARC temps produced while lowering condition leaves stay inside the emitted
 * condition block instead of being hoisted into an enclosing control-flow
 * header.
 *
 * @param self Backend state to update.
 * @param expr_id Condition expression to lower.
 * @param true_label Jump target when the condition is true.
 * @param false_label Jump target when the condition is false.
 */
func be_emit_condition_branch(self: Backend*, expr_id: ExprId, true_label: string, false_label: string) {
    let expr = expr_arena_get(be_current_expr_arena(self), expr_id);

    if (ord(expr.kind) == ord(EX_PAREN)) {
        be_emit_condition_branch(self, expr.expr_a, true_label, false_label);
        return;
    }

    if (ord(expr.kind) == ord(EX_BINARY) && eq_s(expr.text_value, "&&")) {
        let rhs_label = be_fresh_label(self, "cond_rhs");
        be_emit_condition_branch(self, expr.expr_a, rhs_label, false_label);
        cem_emit_label(self.emitter, rhs_label);
        be_emit_condition_branch(self, expr.expr_b, true_label, false_label);
        return;
    }

    if (ord(expr.kind) == ord(EX_BINARY) && eq_s(expr.text_value, "||")) {
        let rhs_label2 = be_fresh_label(self, "cond_rhs");
        be_emit_condition_branch(self, expr.expr_a, true_label, rhs_label2);
        cem_emit_label(self.emitter, rhs_label2);
        be_emit_condition_branch(self, expr.expr_b, true_label, false_label);
        return;
    }

    cem_emit_block_start(self.emitter);
    let leaf_scope = be_push_scope(self);
    let c_cond = be_emit_expr(self, expr_id);
    cem_emit_if_header(self.emitter, c_cond);
    cem_emit_block_start(self.emitter);
    be_emit_cleanup_at_scope_exit(self, leaf_scope);
    cem_emit_goto(self.emitter, true_label);
    cem_emit_block_end(self.emitter);
    be_emit_cleanup_at_scope_exit(self, leaf_scope);
    be_pop_scope(self);
    cem_emit_block_end(self.emitter);
    cem_emit_goto(self.emitter, false_label);
}

/**
 * Evaluate one statement condition into a stable boolean temp.
 *
 * The returned temp is safe to reference from an `if`/`while` header because
 * condition ARC temps are scoped to the emitted condition block and cleaned
 * before control continues.
 *
 * @param self Backend state to update.
 * @param expr_id Condition expression to lower.
 * @return Name of the generated boolean temp.
 */
func be_emit_condition_value(self: Backend*, expr_id: ExprId) -> string {
    let cond_tmp = cem_fresh_tmp(self.emitter, "cond");
    with (let bool_ty = type_builtin_bool() => type_free(bool_ty)) {
        cem_emit_temp_decl(self.emitter, cem_emit_type(bool_ty), cond_tmp, cem_emit_bool_literal(false));
    }

    let true_label = be_fresh_label(self, "cond_true");
    let false_label = be_fresh_label(self, "cond_false");
    let end_label = be_fresh_label(self, "cond_end");

    cem_emit_block_start(self.emitter);
    be_emit_condition_branch(self, expr_id, true_label, false_label);
    cem_emit_label(self.emitter, true_label);
    cem_emit_assignment(self.emitter, cond_tmp, cem_emit_bool_literal(true));
    cem_emit_goto(self.emitter, end_label);
    cem_emit_label(self.emitter, false_label);
    cem_emit_label(self.emitter, end_label);
    cem_emit_block_end(self.emitter);
    return cond_tmp;
}

/**
 * Emit one `if` branch and report whether it ends unreachable.
 *
 * @param self Backend state to update.
 * @param stmt_id Statement id for the branch.
 * @return `true` when control cannot fall through the branch.
 */
func be_emit_if_branch(self: Backend*, stmt_id: StmtId) -> bool {
    let branch = stmt_arena_get(be_current_stmt_arena(self), stmt_id);
    self.next_stmt_unreachable = false;
    if (ord(branch.kind) == ord(ST_BLOCK)) {
        be_emit_block_stmt(self, stmt_id);
    } else {
        cem_emit_block_start(self.emitter);
        let branch_scope = be_push_scope(self);
        be_emit_stmt(self, stmt_id);
        if (!self.next_stmt_unreachable) {
            be_emit_cleanup_at_scope_exit(self, branch_scope);
        }
        be_pop_scope(self);
        cem_emit_block_end(self.emitter);
    }
    return self.next_stmt_unreachable;
}

/**
 * Emit one statement.
 *
 * @param self Backend state to update.
 * @param stmt_id Statement id to lower.
 */
func be_emit_stmt(self: Backend*, stmt_id: StmtId) {
    if (stmt_id < 0) {
        return;
    }

    let stmt = stmt_arena_get(be_current_stmt_arena(self), stmt_id);
    be_emit_line_directive(self, stmt.span);

    match (stmt.kind) {
        ST_BLOCK => {
            be_emit_block_stmt(self, stmt_id);
        }
        ST_LET => {
            let var_ty: Type*? = null;
            if (stmt.type_ref != null) {
                var_ty = be_resolve_type_ref(self, stmt.type_ref as TypeRef*);
            }
            if (var_ty == null) {
                var_ty = be_expr_type(self, stmt.expr_a);
            }
            if (var_ty == null) {
                be_ice(concat3_s("[ICE-1170] missing inferred type for let initializer '", stmt.name, "'"));
            }
            let c_name = cem_mangle_identifier(stmt.name);
            let c_type = cem_emit_type(var_ty as Type*);
            let c_init = be_emit_owned_expr_with_expected_type(self, stmt.expr_a, var_ty as Type*);
            cem_emit_let_decl(self.emitter, c_type, c_name, c_init);
            if (self.current_scope != null) {
                if (analysis_has_arc_data(self.result, var_ty as Type*)) {
                    sc_add_owned(self.current_scope as ScopeContext*, c_name, var_ty as Type*);
                } else {
                    sc_add_declared(self.current_scope as ScopeContext*, c_name, var_ty as Type*);
                }
            }
            self.next_stmt_unreachable = false;
            type_free(var_ty as Type*);
        }
        ST_ASSIGN => {
            with (let dst_ty = be_expr_type(self, stmt.expr_a) => type_free_opt(dst_ty)) {
                if (dst_ty == null) {
                    be_ice("[ICE-1240] missing inferred type for assignment");
                }
                let c_target = be_emit_lvalue(self, stmt.expr_a);
                let c_value = be_emit_owned_expr_with_expected_type(self, stmt.expr_b, dst_ty as Type*);
                if (analysis_has_arc_data(self.result, dst_ty as Type*)) {
                    let temp = cem_fresh_tmp(self.emitter, "tmp");
                    cem_emit_temp_decl(self.emitter, cem_emit_type(dst_ty as Type*), temp, c_value);
                    be_emit_value_cleanup(self, c_target, dst_ty as Type*);
                    cem_emit_assignment(self.emitter, c_target, temp);
                } else {
                    cem_emit_assignment(self.emitter, c_target, c_value);
                }
                self.next_stmt_unreachable = false;
            }
        }
        ST_EXPR => {
            if (ord(expr_arena_get(be_current_expr_arena(self), stmt.expr_a).kind) == ord(EX_NULL)) {
                cem_emit_comment(self.emitter, "null literal");
                self.next_stmt_unreachable = false;
                return;
            }
            let c_expr = be_emit_expr(self, stmt.expr_a);
            with (let expr_ty = be_expr_type(self, stmt.expr_a) => type_free_opt(expr_ty)) {
                if (expr_ty != null && be_should_materialize_arc_temp(self, stmt.expr_a, expr_ty as Type*)) {
                    be_materialize_arc_temp(self, c_expr, expr_ty as Type*);
                } else if (expr_ty != null &&
                           ord(expr_arena_get(be_current_expr_arena(self), stmt.expr_a).kind) == ord(EX_TRY) &&
                           !analysis_has_arc_data(self.result, expr_ty as Type*)) {
                    cem_emit_expr_stmt(self.emitter, cem_emit_discard_expr(c_expr));
                } else {
                    cem_emit_expr_stmt(self.emitter, c_expr);
                }
            }
            self.next_stmt_unreachable = false;
        }
        ST_IF => {
            let c_cond = be_emit_condition_value(self, stmt.expr_a);
            cem_emit_if_header(self.emitter, c_cond);
            let then_unreachable = be_emit_if_branch(self, stmt.stmt_a);

            if (stmt.stmt_b >= 0) {
                cem_emit_else(self.emitter);
                let else_unreachable = be_emit_if_branch(self, stmt.stmt_b);
                self.next_stmt_unreachable = then_unreachable && else_unreachable;
            } else {
                self.next_stmt_unreachable = false;
            }
        }
        ST_WHILE => {
            let break_label = be_fresh_label(self, "lbrk");
            let continue_label = be_fresh_label(self, "lcont");
            be_push_loop_labels(self, break_label, continue_label);
            cem_emit_while_header(self.emitter, cem_emit_bool_literal(true));
            cem_emit_block_start(self.emitter);
            let c_cond = be_emit_condition_value(self, stmt.expr_a);
            cem_emit_if_header(self.emitter, cem_emit_negated_condition(c_cond));
            cem_emit_block_start(self.emitter);
            cem_emit_goto(self.emitter, break_label);
            cem_emit_block_end(self.emitter);
            let loop_scope = be_push_scope(self);
            be_push_loop_cleanup_scopes(self, loop_scope, loop_scope);
            be_emit_block_sequence(self, stmt.stmt_a);
            if (!self.next_stmt_unreachable) {
                be_emit_cleanup_at_scope_exit(self, loop_scope);
            }
            cem_emit_label(self.emitter, continue_label);
            be_pop_loop_cleanup_scopes(self);
            be_pop_scope(self);
            cem_emit_block_end(self.emitter);
            cem_emit_label(self.emitter, break_label);
            be_pop_loop_labels(self);
            self.next_stmt_unreachable = false;
        }
        ST_FOR => {
            let break_label2 = be_fresh_label(self, "lbrk");
            let continue_label2 = be_fresh_label(self, "lcont");
            be_push_loop_labels(self, break_label2, continue_label2);
            let outer_scope = be_push_scope(self);
            cem_emit_for_loop_start(self.emitter);
            if (stmt.stmt_a >= 0) {
                be_emit_stmt(self, stmt.stmt_a);
            }

            cem_emit_while_header(self.emitter, cem_emit_bool_literal(true));
            cem_emit_block_start(self.emitter);
            if (stmt.expr_a >= 0) {
                let c_cond2 = be_emit_condition_value(self, stmt.expr_a);
                cem_emit_if_header(self.emitter, cem_emit_negated_condition(c_cond2));
                cem_emit_block_start(self.emitter);
                cem_emit_goto(self.emitter, break_label2);
                cem_emit_block_end(self.emitter);
            }
            cem_emit_block_start(self.emitter);
            let loop_scope2 = be_push_scope(self);
            be_push_loop_cleanup_scopes(self, loop_scope2, outer_scope);
            be_emit_block_sequence(self, stmt.stmt_c);
            let body_falls_through = !self.next_stmt_unreachable;
            if (body_falls_through) {
                be_emit_cleanup_at_scope_exit(self, loop_scope2);
            }
            be_pop_loop_cleanup_scopes(self);
            be_pop_scope(self);
            cem_emit_block_end(self.emitter);
            self.next_stmt_unreachable = false;
            cem_emit_label(self.emitter, continue_label2);
            if (stmt.stmt_b >= 0) {
                be_emit_stmt(self, stmt.stmt_b);
            }
            cem_emit_block_end(self.emitter);
            be_emit_cleanup_at_scope_exit(self, outer_scope);
            be_pop_scope(self);
            cem_emit_for_loop_end(self.emitter);
            cem_emit_label(self.emitter, break_label2);
            be_pop_loop_labels(self);
            self.next_stmt_unreachable = false;
        }
        ST_RETURN => {
            if (stmt.expr_a >= 0) {
                if (self.current_func_result == null) {
                    be_ice("[ICE-1293] backend missing current function result type");
                }
                let returned_var = be_lookup_owned_local_name(self, stmt.expr_a);
                let c_value = "";
                if (returned_var != null) {
                    c_value = be_emit_expr_with_expected_type(self, stmt.expr_a, self.current_func_result as Type*);
                } else {
                    c_value = be_emit_owned_expr_with_expected_type(self, stmt.expr_a, self.current_func_result as Type*);
                }
                if (be_scope_chain_has_cleanup(self)) {
                    let ret_tmp = cem_fresh_tmp(self.emitter, "ret");
                    cem_emit_temp_decl(self.emitter, cem_emit_type(self.current_func_result as Type*), ret_tmp, c_value);
                    be_emit_cleanup_for_return(self, returned_var);
                    cem_emit_return_stmt(self.emitter, ret_tmp);
                } else {
                    cem_emit_return_stmt(self.emitter, c_value);
                }
            } else {
                if (be_scope_chain_has_cleanup(self)) {
                    be_emit_cleanup_for_return(self, null);
                }
                cem_emit_return_void_stmt(self.emitter);
            }
            self.next_stmt_unreachable = true;
        }
        ST_DROP => {
            be_emit_drop_stmt(self, stmt);
        }
        ST_MATCH => {
            be_emit_match_stmt(self, stmt);
        }
        ST_CASE => {
            be_emit_case_stmt(self, stmt);
        }
        ST_BREAK => {
            if (self.current_loop_labels == null) {
                be_ice("[ICE-1020] break/continue outside of loop");
            }
            be_emit_cleanup_for_loop_exit(self, true);
            cem_emit_goto(self.emitter, (self.current_loop_labels as LoopLabels*).break_label);
            self.next_stmt_unreachable = true;
        }
        ST_CONTINUE => {
            if (self.current_loop_labels == null) {
                be_ice("[ICE-1020] break/continue outside of loop");
            }
            be_emit_cleanup_for_loop_exit(self, false);
            cem_emit_goto(self.emitter, (self.current_loop_labels as LoopLabels*).continue_label);
            self.next_stmt_unreachable = true;
        }
        ST_WITH => {
            be_emit_with_stmt(self, stmt);
        }
    }
}

/**
 * Emit all non-extern function definitions.
 *
 * @param self Backend state to update.
 */
func be_emit_function_definitions(self: Backend*) {
    if (self.result.signatures == null) {
        return;
    }

    cem_emit_section_comment(self.emitter, "Function definitions");
    for (let i = 0; i < driver_unit_count(self.result.driver_state); i = i + 1) {
        let unit = driver_unit_get(self.result.driver_state, i);
        if (unit.parse_result.root_module == null) {
            continue;
        }

        let root = unit.parse_result.root_module as Module*;
        self.current_module = root.name;
        self.current_unit = unit;
        self.current_env = be_find_env(self, root.name);
        cem_emit_module_separator(self.emitter, root.name);

        for (let j = 0; j < vec_size(root.decls); j = j + 1) {
            let top = ptr_vec_get(root.decls, j) as TopLevelDecl*;
            if (ord(top.kind) != ord(TD_FUNC)) {
                continue;
            }
            let decl = top.data as FuncDecl*;
            if (decl.is_extern) {
                continue;
            }

            let func_type = sig_lookup_func_type(self.result.signatures as SignatureTables*, root.name, decl.name);
            if (func_type == null) {
                be_ice(concat4_s("[ICE-1150] missing FuncType for ", root.name, ".", decl.name));
            }

            be_emit_line_directive(self, decl.span);
            cem_emit_function_definition_header(self.emitter, root.name, decl, func_type as Type*);
            self.current_func_result = (func_type as Type*).result as Type*;
            let func_scope = be_push_scope(self);
            for (let p = 0; p < vec_size(decl.params); p = p + 1) {
                let param_decl = ptr_vec_get(decl.params, p) as Param*;
                let param_ty = ptr_vec_get((func_type as Type*).params as VectorBase*, p) as Type*;
                sc_add_declared(func_scope, cem_mangle_identifier(param_decl.name), param_ty);
            }
            be_emit_block_sequence(self, decl.body);
            if (!self.next_stmt_unreachable) {
                be_emit_cleanup_at_scope_exit(self, func_scope);
            }
            be_pop_scope(self);
            self.current_func_result = null;
            cem_emit_function_definition_footer(self.emitter);
        }
    }
}

/**
 * Emit the C `main()` wrapper when the entry module defines `main`.
 *
 * @param self Backend state to update.
 */
func be_emit_main_wrapper_if_needed(self: Backend*) {
    if (is_empty_s(self.result.driver_state.entry_module) || self.result.signatures == null) {
        return;
    }

    let func_type = sig_lookup_func_type(self.result.signatures as SignatureTables*, self.result.driver_state.entry_module,
        "main");
    if (func_type == null) {
        return;
    }
    cem_emit_main_wrapper(self.emitter, self.result.driver_state.entry_module, func_type as Type*);
}

/**
 * Generate complete C source from a typed analysis result.
 *
 * @param result Typed analysis result to lower.
 * @param opts Codegen options to honor.
 * @param cfg Logging configuration to use.
 * @return Complete generated C translation unit.
 */
func backend_generate(result: AnalysisResult*, opts: CodegenOptions*, cfg: LogConfig*) -> string {
    if (analysis_has_errors(result)) {
        be_ice("[ICE-9303] backend_generate requires analysis without errors");
    }

    with (let self = be_create(result, opts, cfg) => be_free(self)) {
        log_stage(cfg, "Generating C code", "");
        log_debug(cfg, "Preparing optional wrapper types");
        cem_prepare_optional_wrappers(self.emitter);
        log_debug(cfg, "Emitting header and forward declarations");
        cem_emit_header(self.emitter, opts);
        cem_emit_forward_decls(self.emitter);
        cem_emit_section_comment(self.emitter, "Optional wrapper types (builtins / early)");
        cem_emit_optional_wrappers(self.emitter, true);
        be_emit_type_definitions(self);
        cem_emit_section_comment(self.emitter, "Optional wrapper types (late)");
        cem_emit_optional_wrappers(self.emitter, false);
        be_emit_let_declarations(self);
        be_emit_function_declarations(self);
        be_emit_function_definitions(self);
        be_emit_main_wrapper_if_needed(self);
        return cem_get_output(self.emitter);
    }
}
