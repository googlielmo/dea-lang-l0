module source_paths;

import sys.rt;

import std.fs;
import std.path;
import std.string;
import std.system;
import std.text;
import std.vector;
import util.diag;

import util.strings;

/**
 * Represents the SourceSearchPaths structure.
 */
struct SourceSearchPaths {
    system_roots: VectorString*;
    project_roots: VectorString*;
}

/**
 * Create an empty source search-path collection.
 *
 * @return New search-path set with separate system and project root vectors.
 */
func sp_create() -> SourceSearchPaths* {
    return new SourceSearchPaths(vs_create(2), vs_create(2));
}

/**
 * Free a source search-path collection.
 *
 * @param self Search paths to free.
 */
func sp_free(self: SourceSearchPaths*) {
    vs_free(self.system_roots);
    vs_free(self.project_roots);
    drop self;
}

/**
 * Append a system root directory.
 *
 * @param self Search paths to update.
 * @param root Root directory to search before project roots.
 */
func sp_add_system_root(self: SourceSearchPaths*, root: string) {
    vs_push(self.system_roots, root);
}

/**
 * Append a project root directory.
 *
 * @param self Search paths to update.
 * @param root Project root directory to search.
 */
func sp_add_project_root(self: SourceSearchPaths*, root: string) {
    vs_push(self.project_roots, root);
}

/**
 * Return the number of configured system roots.
 *
 * @param self Search paths to inspect.
 * @return Number of system root directories.
 */
func sp_system_root_count(self: SourceSearchPaths*) -> int {
    return vs_size(self.system_roots);
}

/**
 * Return the number of configured project roots.
 *
 * @param self Search paths to inspect.
 * @return Number of project root directories.
 */
func sp_project_root_count(self: SourceSearchPaths*) -> int {
    return vs_size(self.project_roots);
}

/**
 * Return a system root by index.
 *
 * @param self Search paths to inspect.
 * @param index Zero-based system-root index.
 * @return System root at `index`.
 */
func sp_system_root_get(self: SourceSearchPaths*, index: int) -> string {
    return vs_get(self.system_roots, index);
}

/**
 * Return a project root by index.
 *
 * @param self Search paths to inspect.
 * @param index Zero-based project-root index.
 * @return Project root at `index`.
 */
func sp_project_root_get(self: SourceSearchPaths*, index: int) -> string {
    return vs_get(self.project_roots, index);
}

/**
 * Format one root list using the Stage 1 verbose display contract.
 *
 * @param roots Root vector to format.
 * @return Comma-joined quoted roots, or `<none>` when empty.
 */
func sp_format_root_list(roots: VectorString*) -> string {
    if (vs_size(roots) == 0) {
        return "<none>";
    }

    with (let sb = sb_create() => sb_free(sb)) {
        for (let i = 0; i < vs_size(roots); i = i + 1) {
            if (i > 0) {
                sb_append(sb, ",");
            }
            sb_append(sb, "'");
            sb_append(sb, vs_get(roots, i));
            sb_append(sb, "'");
        }
        return sb_to_string(sb);
    }
}

/**
 * Convert a dotted module name to its relative `.l0` path.
 *
 * @param module_name Dotted module name such as `foo.bar`.
 * @return Relative source path such as `foo/bar.l0`.
 */
func sp_module_relpath(module_name: string) -> string {
    with (let cb = cb_create() => cb_free(cb)) {
        for (let i = 0; i < len_s(module_name); i = i + 1) {
            let c = char_at_s(module_name, i);
            if (c == '.') {
                cb_append(cb, '/');
            } else {
                cb_append(cb, c);
            }
        }
        cb_append_s(cb, ".l0");
        return cb_to_string(cb);
    }
}

/**
 * Resolve a module name against configured search roots.
 *
 * @param self Search paths to inspect.
 * @param module_name Dotted module name to resolve.
 * @return First matching source path, or `null` if the module is not found.
 */
func sp_resolve(self: SourceSearchPaths*, module_name: string) -> string? {
    let rel = sp_module_relpath(module_name);

    for (let i = 0; i < vs_size(self.system_roots); i = i + 1) {
        let candidate = join(vs_get(self.system_roots, i), rel);
        if (exists(candidate)) {
            return candidate;
        }
    }

    for (let project_i = 0; project_i < vs_size(self.project_roots); project_i = project_i + 1) {
        let candidate = join(vs_get(self.project_roots, project_i), rel);
        if (exists(candidate)) {
            return candidate;
        }
    }

    return null;
}

/**
 * Check whether a module-name component is a valid identifier.
 *
 * @param component Module-name component to validate.
 * @return `true` if the component matches identifier rules.
 */
func sp_is_valid_ident_component(component: string) -> bool {
    let n = len_s(component);
    if (n == 0) {
        return false;
    }

    let first = char_at_s(component, 0);
    if (!(is_alpha(first) || first == '_')) {
        return false;
    }

    for (let i = 1; i < n; i = i + 1) {
        let c = char_at_s(component, i);
        if (!(is_alnum(c) || c == '_')) {
            return false;
        }
    }

    return true;
}

/**
 * Check whether a dotted module name is valid.
 *
 * @param module_name Module name to validate.
 * @return `true` if every component is a valid identifier.
 */
func sp_is_valid_module_name(module_name: string) -> bool {
    if (is_empty_s(module_name)) {
        return false;
    }

    with (let parts = us_split_char(module_name, '.', true) => vs_free(parts)) {
        for (let i = 0; i < vs_size(parts); i = i + 1) {
            if (!sp_is_valid_ident_component(vs_get(parts, i))) {
                return false;
            }
        }
    }

    return true;
}

/**
 * Ensure a default project root exists.
 *
 * @param project_roots Project-root vector to update.
 */
func sp_apply_default_project_roots(project_roots: VectorString*) {
    if (vs_size(project_roots) == 0) {
        vs_push(project_roots, ".");
    }
}

/**
 * Append system roots from a split environment-style path string.
 *
 * @param sys_roots System-root vector to update.
 * @param env_value Colon- or semicolon-separated root list.
 */
func sp_append_env_sys_roots(sys_roots: VectorString*, env_value: string) {
    with (let roots = us_split_chars2_non_empty(env_value, ':', ';') => vs_free(roots)) {
        for (let i = 0; i < vs_size(roots); i = i + 1) {
            vs_push(sys_roots, vs_get(roots, i));
        }
    }
}

/**
 * Populate default system roots from effective environment values when needed.
 *
 * @param sys_roots System-root vector to update.
 * @param l0_system Effective `L0_SYSTEM` value, if any.
 * @param l0_home Effective `L0_HOME` value, if any.
 */
func sp_apply_default_sys_roots_env(sys_roots: VectorString*, l0_system: string?, l0_home: string?) {
    if (vs_size(sys_roots) > 0) {
        return;
    }

    if (l0_system != null && !is_empty_s(l0_system as string)) {
        sp_append_env_sys_roots(sys_roots, l0_system as string);
        return;
    }

    if (l0_home != null && !is_empty_s(l0_home as string)) {
        vs_push(sys_roots, join(l0_home as string, "shared/l0/stdlib"));
    }
}

/**
 * Populate default system roots from `L0_SYSTEM` when needed.
 *
 * @param sys_roots System-root vector to update.
 */
func sp_apply_default_sys_roots(sys_roots: VectorString*) {
    sp_apply_default_sys_roots_env(sys_roots, env_get("L0_SYSTEM"), env_get("L0_HOME"));
}

/**
 * Build a search-path collection from explicit root vectors.
 *
 * @param project_roots Project roots to copy.
 * @param sys_roots System roots to copy.
 * @return New search-path collection containing both root sets.
 */
func sp_build_from_roots(project_roots: VectorString*, sys_roots: VectorString*) -> SourceSearchPaths* {
    let sp = sp_create();

    for (let i = 0; i < vs_size(sys_roots); i = i + 1) {
        sp_add_system_root(sp, vs_get(sys_roots, i));
    }

    for (let project_i = 0; project_i < vs_size(project_roots); project_i = project_i + 1) {
        sp_add_project_root(sp, vs_get(project_roots, project_i));
    }

    return sp;
}

/**
 * Normalize a CLI entry target to a module name.
 *
 * @param target CLI target, either a module name or a path-like input.
 * @param project_roots Project-root vector to extend when `target` includes a parent path.
 * @param diags Diagnostic collector for validation errors.
 * @return Normalized module name, or `null` if validation fails.
 */
func sp_normalize_entry_target(target: string, project_roots: VectorString*, diags: DiagCollector*) -> string? {
    if (has_extension(target, ".l0") || is_absolute(target) || has_parent(target)) {
        let module_name = "";
        if (has_extension(target, ".l0")) {
            module_name = stem(target);
        } else {
            module_name = basename(target);
        }

        let parent_dir = parent(target);
        if (parent_dir != ".") {
            vs_push(project_roots, parent_dir);
        }

        if (!sp_is_valid_module_name(module_name)) {
            diag_error(
                diags,
                "l0c",
                "L0C-0011",
                concat3_s("invalid entry module name '", module_name, "': module components must be valid identifiers"),
                "",
                0,
                0,
                0,
                0
            );
            return null;
        }
        return module_name;
    }

    if (!sp_is_valid_module_name(target)) {
        diag_error(
            diags,
            "l0c",
            "L0C-0011",
            concat3_s("invalid entry module name '", target, "': module components must be valid identifiers"),
            "",
            0,
            0,
            0,
            0
        );
        return null;
    }

    return target;
}
