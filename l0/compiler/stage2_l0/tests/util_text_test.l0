    let l3 = to_lower_s("already lower");
    printl_ss("  to_lower_s('already lower'):", l3);

    let l4 = to_lower_s("123ABC");
    printl_ss("  to_lower_s('123ABC'):", l4);

    let l5 = to_lower_s("");
    printl_ss("  to_lower_s(''):", l5);
    printl_si("    (length):", len_s(l5));

    assert(l1 == "hello", "Expected to_lower_s('HELLO') to be 'hello'");
    assert(l2 == "hello world", "Expected to_lower_s('Hello World') to be 'hello world'");
    assert(l3 == "already lower", "Expected to_lower_s('already lower') to be 'already lower'");
    assert(l4 == "123abc", "Expected to_lower_s('123ABC') to be '123abc'");
    assert(l5 == "", "Expected to_lower_s('') to be ''");

    printl_s("to_lower_s tests passed!\n");
}

/**
 * Tests test_is_digit_base.
 */
func test_is_digit_base() {
    printl_s("=== Test is_digit_base ===");

    assert(is_digit_base('0', 2), "Expected is_digit_base('0', 2) to be true");
    assert(is_digit_base('1', 2), "Expected is_digit_base('1', 2) to be true");
    assert(!is_digit_base('2', 2), "Expected is_digit_base('2', 2) to be false");

    assert(is_digit_base('9', 10), "Expected is_digit_base('9', 10) to be true");
    assert(!is_digit_base('a', 10), "Expected is_digit_base('a', 10) to be false");

    assert(is_digit_base('a', 16), "Expected is_digit_base('a', 16) to be true");
    assert(is_digit_base('F', 16), "Expected is_digit_base('F', 16) to be true");
    assert(!is_digit_base('g', 16), "Expected is_digit_base('g', 16) to be false");
    assert(!is_digit_base('-', 16), "Expected is_digit_base('-', 16) to be false");

    printl_s("is_digit_base tests passed!\n");
}

/**
 * Tests test_to_digit_base.
 */
func test_to_digit_base() -> Unit? {
    printl_s("=== Test to_digit_base ===");

    let d1 = to_digit_base('1', 2)?;
    let d2 = to_digit_base('7', 8)?;
    let d3 = to_digit_base('9', 10)?;
    let d4 = to_digit_base('a', 16)?;
    let d5 = to_digit_base('F', 16)?;

    assert(d1 == 1, "Expected to_digit_base('1', 2) to be 1");
    assert(d2 == 7, "Expected to_digit_base('7', 8) to be 7");
    assert(d3 == 9, "Expected to_digit_base('9', 10) to be 9");
    assert(d4 == 10, "Expected to_digit_base('a', 16) to be 10");
    assert(d5 == 15, "Expected to_digit_base('F', 16) to be 15");

    assert(to_digit_base('2', 2) == null, "Expected to_digit_base('2', 2) to be null");
    assert(to_digit_base('8', 8) == null, "Expected to_digit_base('8', 8) to be null");
    assert(to_digit_base('g', 16) == null, "Expected to_digit_base('g', 16) to be null");
    assert(to_digit_base('-', 16) == null, "Expected to_digit_base('-', 16) to be null");

    printl_s("to_digit_base tests passed!\n");
    return std.unit::present();
}

/**
 * Tests test_string_to_int_base_valid.
 */
func test_string_to_int_base_valid() -> Unit? {
    printl_s("=== Test string_to_int_base (valid) ===");

    let v1 = string_to_int_base("101101", 2)?;
    let v2 = string_to_int_base("-101101", 2)?;
    let v3 = string_to_int_base("777", 8)?;
    let v4 = string_to_int_base("00000123", 10)?;
    let v5 = string_to_int_base("-00000123", 10)?;
    let v6 = string_to_int_base("7fffffff", 16)?;
    let v7 = string_to_int_base("-80000000", 16)?;
    let v8 = string_to_int_base("A", 16)?;
    let v9 = string_to_int_base("0000", 2)?;
    let v10 = string_to_int_base("-0000", 16)?;

    assert(v1 == 45, "Expected string_to_int_base('101101', 2) to be 45");
    assert(v2 == -45, "Expected string_to_int_base('-101101', 2) to be -45");
    assert(v3 == 511, "Expected string_to_int_base('777', 8) to be 511");
    assert(v4 == 123, "Expected string_to_int_base('00000123', 10) to be 123");
    assert(v5 == -123, "Expected string_to_int_base('-00000123', 10) to be -123");
    assert(v6 == 2147483647, "Expected string_to_int_base('7fffffff', 16) to be 2147483647");
    assert(v7 == -2147483648, "Expected string_to_int_base('-80000000', 16) to be -2147483648");
    assert(v8 == 10, "Expected string_to_int_base('A', 16) to be 10");
    assert(v9 == 0, "Expected string_to_int_base('0000', 2) to be 0");
    assert(v10 == 0, "Expected string_to_int_base('-0000', 16) to be 0");

    printl_s("string_to_int_base valid tests passed!\n");
    return std.unit::present();
}

/**
 * Tests test_string_to_int_base_invalid.
 */
func test_string_to_int_base_invalid() {
    printl_s("=== Test string_to_int_base (invalid) ===");

    assert(string_to_int_base("", 10) == null, "Expected string_to_int_base('', 10) to be null");
    assert(string_to_int_base("-", 10) == null, "Expected string_to_int_base('-', 10) to be null");
    assert(string_to_int_base("+1", 10) == null, "Expected string_to_int_base('+1', 10) to be null");
    assert(string_to_int_base("2", 2) == null, "Expected string_to_int_base('2', 2) to be null");
    assert(string_to_int_base("08", 8) == null, "Expected string_to_int_base('08', 8) to be null");
    assert(string_to_int_base("1g", 16) == null, "Expected string_to_int_base('1g', 16) to be null");
    assert(string_to_int_base("0x10", 16) == null, "Expected string_to_int_base('0x10', 16) to be null");
    assert(string_to_int_base("--1", 10) == null, "Expected string_to_int_base('--1', 10) to be null");
    assert(string_to_int_base(" 1", 10) == null, "Expected string_to_int_base(' 1', 10) to be null");
    assert(string_to_int_base("1 ", 10) == null, "Expected string_to_int_base('1 ', 10) to be null");

    printl_s("string_to_int_base invalid tests passed!\n");
}

/**
 * Tests test_string_to_int_base_limits.
 */
func test_string_to_int_base_limits() -> Unit? {
    printl_s("=== Test string_to_int_base (limits) ===");

    let dec_max = string_to_int_base("2147483647", 10)?;
    let dec_min = string_to_int_base("-2147483648", 10)?;
    let bin_max = string_to_int_base("1111111111111111111111111111111", 2)?;
    let bin_min = string_to_int_base("-10000000000000000000000000000000", 2)?;

    assert(dec_max == 2147483647, "Expected decimal INT_MAX parse");
    assert(dec_min == -2147483648, "Expected decimal INT_MIN parse");
    assert(bin_max == 2147483647, "Expected binary INT_MAX parse");
    assert(bin_min == -2147483648, "Expected binary INT_MIN parse");

    assert(string_to_int_base("2147483648", 10) == null, "Expected decimal overflow to return null");
    assert(string_to_int_base("-2147483649", 10) == null, "Expected decimal underflow to return null");
    assert(string_to_int_base("80000000", 16) == null, "Expected hex overflow to return null");
    assert(string_to_int_base("-80000001", 16) == null, "Expected hex underflow to return null");
    assert(string_to_int_base("10000000000000000000000000000000", 2) == null, "Expected binary overflow to return null");
    assert(string_to_int_base("-10000000000000000000000000000001", 2) == null, "Expected binary underflow to return null");

    printl_s("string_to_int_base limits tests passed!\n");
    return std.unit::present();
}

/**
 * Tests test_bool_string_conversions.
 */
func test_bool_string_conversions() -> Unit? {
    printl_s("=== Test bool string conversions ===");

    let s_true = bool_to_string(true);
    let s_false = bool_to_string(false);
    assert(s_true == "true", "Expected bool_to_string(true) to be 'true'");
    assert(s_false == "false", "Expected bool_to_string(false) to be 'false'");

    let b_true = string_to_bool("true")?;
    let b_false = string_to_bool("false")?;
    assert(b_true, "Expected string_to_bool('true') to be true");
    assert(!b_false, "Expected string_to_bool('false') to be false");

    assert(string_to_bool("True") == null, "Expected string_to_bool('True') to be null");
    assert(string_to_bool("FALSE") == null, "Expected string_to_bool('FALSE') to be null");
    assert(string_to_bool("") == null, "Expected string_to_bool('') to be null");
    assert(string_to_bool("0") == null, "Expected string_to_bool('0') to be null");
    assert(string_to_bool("yes") == null, "Expected string_to_bool('yes') to be null");

    printl_s("bool string conversion tests passed!\n");
    return std.unit::present();
}

/**
 * Tests test_byte_string_conversions.
 */
func test_byte_string_conversions() -> Unit? {
    printl_s("=== Test byte string conversions ===");

    let b0 = 0 as byte;
    let b255 = 255 as byte;
    let s0 = byte_to_string(b0);
    let s255 = byte_to_string(b255);
    let shex = byte_to_string_base(b255, 16);
    let sbin = byte_to_string_base(b255, 2);

    assert(s0 == "0", "Expected byte_to_string(0) to be '0'");
    assert(s255 == "255", "Expected byte_to_string(255) to be '255'");
    assert(shex == "ff", "Expected byte_to_string_base(255, 16) to be 'ff'");
    assert(sbin == "11111111", "Expected byte_to_string_base(255, 2) to be '11111111'");

    let p0 = string_to_byte("0")?;
    let p255 = string_to_byte("255")?;
    let phex = string_to_byte_base("ff", 16)?;
    let pbin = string_to_byte_base("11111111", 2)?;

    assert((p0 as int) == 0, "Expected string_to_byte('0') to be 0");
    assert((p255 as int) == 255, "Expected string_to_byte('255') to be 255");
    assert((phex as int) == 255, "Expected string_to_byte_base('ff', 16) to be 255");
    assert((pbin as int) == 255, "Expected string_to_byte_base('11111111', 2) to be 255");

    assert(string_to_byte("256") == null, "Expected string_to_byte('256') to be null");
    assert(string_to_byte("-1") == null, "Expected string_to_byte('-1') to be null");
    assert(string_to_byte_base("1ff", 16) == null, "Expected string_to_byte_base('1ff', 16) to be null");
    assert(string_to_byte_base("gg", 16) == null, "Expected string_to_byte_base('gg', 16) to be null");
    assert(string_to_byte("") == null, "Expected string_to_byte('') to be null");

    printl_s("byte string conversion tests passed!\n");
    return std.unit::present();
}

/**
 * Tests test_string_to_int.
 */
func test_string_to_int() -> Unit? {
    printl_s("=== Test string_to_int ===");

    let s1 = "12345";
    let v1 = string_to_int(s1)?;
    printl_si(concat3_s("  string_to_int('", s1, "'):"), v1);

    let s2 = "-6789";
    let v2 = string_to_int(s2)?;
    printl_si(concat3_s("  string_to_int('", s2, "'):"), v2);

    let s3 = "0";
    let v3 = string_to_int(s3)?;
    printl_si(concat3_s("  string_to_int('", s3, "'):"), v3);

    // INT_MIN
    let s4 = "-2147483648"; // INT_MIN
    let v4 = string_to_int(s4)?;
    printl_si(concat3_s("  string_to_int('", s4, "'):"), v4);

    // INT_MAX
    let s7 = "2147483647"; // INT_MAX
    let v7 = string_to_int(s7)?;
    printl_si(concat3_s("  string_to_int('", s7, "'):"), v7);

    // check underflow
    let s6 = "-2147483649"; // INT_MIN - 1
    let v6 = string_to_int(s6);
    if (v6 == null) {
        printl_s(concat3_s("  string_to_int('", s6, "'): null (underflow) OK"));
    }

    // check overflow
    let s5 = "2147483648"; // INT_MAX + 1
    let v5 = string_to_int(s5);
    if (v5 == null) {
        printl_s(concat3_s("  string_to_int('", s5, "'): null (overflow) OK"));
    }

    let s8 = "9999999999"; // definitely overflow
    let v8 = string_to_int(s8);
    if (v8 == null) {
        printl_s(concat3_s("  string_to_int('", s8, "'): null (overflow) OK"));
    }

    let s9 = "-9999999999"; // definitely underflow
    let v9 = string_to_int(s9);
    if (v9 == null) {
        printl_s(concat3_s("  string_to_int('", s9, "'): null (underflow) OK"));
    }

    assert(v1 == 12345, "Expected string_to_int('12345') to be 12345");
    assert(v2 == -6789, "Expected string_to_int('-6789') to be -6789");
    assert(v3 == 0, "Expected string_to_int('0') to be 0");
    assert(v4 == -2147483648, "Expected string_to_int('-2147483648') to be -2147483648");
    assert(v7 == 2147483647, "Expected string_to_int('2147483647') to be 2147483647");
    assert(v6 == null, "Expected string_to_int('-2147483649') to be null (underflow)");
    assert(v5 == null, "Expected string_to_int('2147483648') to be null (overflow)");
    assert(v8 == null, "Expected string_to_int('9999999999') to be null (overflow)");
    assert(v9 == null, "Expected string_to_int('-9999999999') to be null (underflow)");

    printl_s("string_to_int tests passed!\n");

    return std.unit::present();
}

/**
 * Tests test_int_to_string.
 */
func test_int_to_string() {
    printl_s("=== Test int_to_string ===");

    let i1 = 12345;
    let s1 = int_to_string(i1);
    print_si("  int_to_string(", i1);
    printl_ss("):", int_to_string(i1));

    let i2 = -6789;
    let s2 = int_to_string(i2);
    print_si("  int_to_string(", i2);
    printl_ss("):", int_to_string(i2));

    let i3 = 0;
    let s3 = int_to_string(i3);
    print_si("  int_to_string(", i3);
    printl_ss("):", int_to_string(i3));

    let i4 = -2147483648; // INT_MIN
    let s4 = int_to_string(i4);
    print_si("  int_to_string(", i4);
    printl_ss("):", int_to_string(i4));

    let i5 = 2147483647; // INT_MAX
    let s5 = int_to_string(i5);
    print_si("  int_to_string(", i5);
    printl_ss("):", int_to_string(i5));

    assert(s1 == "12345", "Expected int_to_string(12345) to be '12345'");
    assert(s2 == "-6789", "Expected int_to_string(-6789) to be '-6789'");
    assert(s3 == "0", "Expected int_to_string(0) to be '0'");
    assert(s4 == "-2147483648", "Expected int_to_string(-2147483648) to be '-2147483648'");
    assert(s5 == "2147483647", "Expected int_to_string(2147483647) to be '2147483647'");

    printl_s("int_to_string tests passed!\n");
}

// test int_to_hex_string
/**
 * Tests test_int_to_hex_string.
 */
func test_int_to_hex_string() {
    printl_s("=== Test int_to_hex_string ===");

    let i1 = 255;
    let s1 = int_to_hex_string(i1);
    print_si("  int_to_hex_string(", i1);
    printl_ss("):", s1);

    let i2 = 4095;
    let s2 = int_to_hex_string(i2);
    print_si("  int_to_hex_string(", i2);
    printl_ss("):", s2);

    let i3 = 0;
    let s3 = int_to_hex_string(i3);
    print_si("  int_to_hex_string(", i3);
    printl_ss("):", s3);

    let i4 = 305419896; // 0x12345678
    let s4 = int_to_hex_string(i4);
    print_si("  int_to_hex_string(", i4);
    printl_ss("):", s4);

    let i5 = -1; // negative number
    let s5 = int_to_hex_string(i5);
    print_si("  int_to_hex_string(", i5);
    printl_ss("):", s5);

    let i6 = -2147483648; // INT_MIN
    let s6 = int_to_hex_string(i6);
    print_si("  int_to_hex_string(", i6);
    printl_ss("):", s6);

    assert(s1 == "ff", "Expected int_to_hex_string(255) to be 'ff'");
    assert(s2 == "fff", "Expected int_to_hex_string(4095) to be 'fff'");
    assert(s3 == "0", "Expected int_to_hex_string(0) to be '0'");
    assert(s4 == "12345678", "Expected int_to_hex_string(305419896) to be '12345678'");
    assert(s5 == "-1", "Expected int_to_hex_string(-1) to be '-1'");
    assert(s6 == "-80000000", "Expected int_to_hex_string(-2147483648) to be '-80000000'");

    printl_s("int_to_hex_string tests passed!\n");
}

/**
 * Tests test_int_to_bin_string.
 */
func test_int_to_bin_string() {
    printl_s("=== Test int_to_bin_string ===");

    let i1 = 5;
    let s1 = int_to_bin_string(i1);
    print_si("  int_to_bin_string(", i1);
    printl_ss("):", s1);

    let i2 = 10;
    let s2 = int_to_bin_string(i2);
    print_si("  int_to_bin_string(", i2);
    printl_ss("):", s2);

    let i3 = 0;
    let s3 = int_to_bin_string(i3);
    print_si("  int_to_bin_string(", i3);
    printl_ss("):", s3);

    let i4 = -1; // negative number
    let s4 = int_to_bin_string(i4);
    print_si("  int_to_bin_string(", i4);
    printl_ss("):", s4);

    let i5 = -2147483648; // INT_MIN
    let s5 = int_to_bin_string(i5);
    print_si("  int_to_bin_string(", i5);
    printl_ss("):", s5);

    assert(s1 == "101", "Expected int_to_bin_string(5) to be '101'");
    assert(s2 == "1010", "Expected int_to_bin_string(10) to be '1010'");
    assert(s3 == "0", "Expected int_to_bin_string(0) to be '0'");
    assert(s4 == "-1", "Expected int_to_bin_string(-1) to be '-1'");
    assert(s5 == "-10000000000000000000000000000000", "Expected int_to_bin_string(-2147483648) to be '-10000000000000000000000000000000'");

    printl_s("int_to_bin_string tests passed!\n");
}

/**
 * Main entry point for the module.
 */
func main() -> int {
    printl_s("==========================================");
    printl_s("      String Utilities Test Suite");
    printl_s("==========================================\n");

    // Character classification
    test_is_space();
    test_is_digit();
    test_is_alpha();
    test_is_alnum();

    // Character manipulation
    test_to_digit();
    test_to_upper();
    test_to_lower();

    // StringBuffer
    test_string_buffer();
    test_string_buffer_empty();

    // CharBuffer
    test_char_buffer();
    test_char_buffer_clear();

    // String utilities
    test_concat3_s();
    test_repeat_s();
    test_trim_s();
    test_is_empty_s();
    test_split_s();
    test_find_last_s();
    test_lines_s();
    test_join_s();
    test_replace_s();
    test_to_upper_s();
    test_to_lower_s();

    // String <-> int conversions
    test_is_digit_base();
    test_to_digit_base();
    test_string_to_int_base_valid();
    test_string_to_int_base_invalid();
    test_string_to_int_base_limits();
    test_bool_string_conversions();
    test_byte_string_conversions();
    test_string_to_int();
    test_int_to_string();
    test_int_to_bin_string();
    test_int_to_hex_string();

    printl_s("==========================================");
    printl_s("  All String Utility tests passed!");
    printl_s("==========================================");

    return 0;
}
