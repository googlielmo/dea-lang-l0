module string_equality_main;

import std.string;

func main() -> int {
    let lit = "dea";
    let same_lit = "dea";
    let different_lit = "dea!";
    let empty = "";
    let built_a = concat_s("de", "a");
    let built_b = concat_s("de", "a");
    let built_diff = concat_s("de", "a!");
    if (lit == same_lit && lit != different_lit &&
        empty == "" && empty != "x" &&
        built_a == built_b && built_a != built_diff &&
        built_a == lit && lit == built_b) {
        return 23;
    }
    return 0;
}
