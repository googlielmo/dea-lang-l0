module typing_field_diag_err;

struct Point { x: int; y: int; }

extern func maybe_point() -> Point?;

/**
 * Triggers nullable-struct field access.
 */
func err_nullable_struct_field() {
    let p: Point? = maybe_point();
    let x = p.x; // TYP-0220
}

/**
 * Triggers an unknown struct-field access.
 */
func err_missing_struct_field() {
    let p = Point(1, 2);
    let z = p.z; // TYP-0221
}

/**
 * Triggers field access on a non-struct type.
 */
func err_non_struct_field() {
    let value: int = 1;
    let field = value.missing; // TYP-0222
}
