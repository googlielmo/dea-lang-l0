module typing_loop_cond_err;

/**
 * Triggers loop-condition diagnostic codes.
 */
func err_loop_conditions() -> int {
    while (1) { // TYP-0080
    }
    for (let i: int = 0; i; i = i + 1) { // TYP-0090
    }
    return 0;
}
