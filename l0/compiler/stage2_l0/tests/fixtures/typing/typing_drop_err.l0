module typing_drop_err;

struct Box {
    value: int;
}

/**
 * Triggers an unknown-variable drop error.
 */
func err_drop_unknown() {
    drop missing; // TYP-0060
}

/**
 * Triggers a non-pointer drop error.
 */
func err_drop_non_pointer() {
    let value: int = 1;
    drop value; // TYP-0061
}

/**
 * Valid drop for a pointer local.
 */
func ok_drop_pointer() {
    let p: Box* = new Box(1);
    drop p;
}
