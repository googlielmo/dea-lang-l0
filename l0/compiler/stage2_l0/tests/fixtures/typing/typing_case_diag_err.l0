module typing_case_diag_err;

struct Point {
    x: int;
}

/**
 * Triggers TYP-0106 for an invalid scrutinee type.
 */
func err_case_bad_scrutinee(p: Point) -> int {
    case (p) {
        else { return 0; }
    }
}

/**
 * Triggers TYP-0107 for an arm literal type mismatch.
 */
func err_case_literal_type_mismatch(x: int) -> int {
    case (x) {
        "hello" => { return 1; }
        else { return 0; }
    }
}

/**
 * Triggers TYP-0108 for a duplicate literal.
 */
func err_case_duplicate_literal(x: int) -> int {
    case (x) {
        1 => { return 1; }
        1 => { return 2; }
        else { return 0; }
    }
}
