module typing_let_diag_err;

func noop() -> void {
    return;
}

/**
 * Triggers Stage 1 `let` declaration diagnostics.
 */
func err_let_diag() -> int {
    let a: void = noop(); // TYP-0050
    let b = null; // TYP-0052
    let c = noop(); // TYP-0053
    let d: int = 1;
    let d: int = 2; // TYP-0020
    return 0;
}
