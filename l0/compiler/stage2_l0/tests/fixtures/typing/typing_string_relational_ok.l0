module typing_string_relational_ok;

func literal_and_empty_checks() -> bool {
    let empty = "";
    return "dea" < "dea!" && "dea" <= "dea" && "dea!" > "dea" && "dea!" >= "dea" && empty < "x";
}

func branch_and_loop(seed: string) -> int {
    let count = 0;
    while (seed <= "go" && count < 2) {
        count = count + 1;
    }
    if (seed >= "go" && seed > "fn" && count == 2) {
        return count;
    }
    return 0;
}

func compare_aliases(seed: string) -> bool {
    let alias = seed;
    return alias <= seed && alias >= seed && alias < "stop";
}

func main() -> int {
    if (literal_and_empty_checks() && compare_aliases("go") && branch_and_loop("go") == 2) {
        return 1;
    }
    return 0;
}
