module typing_loop_control_err;

/**
 * Triggers a `break`-outside-loop error.
 */
func err_break_outside_loop() -> int {
    break; // TYP-0110
    return 0;
}

/**
 * Triggers a `continue`-outside-loop error.
 */
func err_continue_outside_loop() -> int {
    continue; // TYP-0120
    return 0;
}
