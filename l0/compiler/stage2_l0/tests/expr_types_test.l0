/**
 * Tests assignment-vs-cast nullability behavior.
 */
func test_typing_nullable_assignment() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "typing_nullable_assignment", cfg);
        assert(analysis_has_errors(result), "expected typing errors for typing_nullable_assignment");
        assert(count_diag_code(result, "TYP-0310") == 1, "expected nullable-to-non-nullable initializer mismatch");
        assert(!has_diag_code(result, "TYP-0315"), "did not expect secondary return type mismatch on nullable assignment");
        analysis_result_free(result);
    }
    sp_free(sp);
}

/**
 * Tests function-call mismatch diagnostics.
 */
func test_typing_call_err() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "typing_call_err", cfg);
        assert(analysis_has_errors(result), "expected typing errors for typing_call_err");
        assert(count_diag_code(result, "TYP-0183") == 2, "expected both arity mismatches to report TYP-0183");
        assert(count_diag_code(result, "TYP-0312") == 1, "expected one argument type mismatch to report TYP-0312");
        assert(!has_diag_code(result, "TYP-0320"), "did not expect legacy Stage 2 arity mismatch code");
        assert(!has_diag_code(result, "TYP-0321"), "did not expect legacy Stage 2 argument mismatch code");
        assert(!has_diag_code(result, "TYP-0315"), "did not expect secondary return type mismatch on call errors");
        analysis_result_free(result);
    }
    sp_free(sp);
}

