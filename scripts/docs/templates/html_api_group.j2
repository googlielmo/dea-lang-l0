<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ title }} API | Dea/L0 API</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,400i,600,600i%7CSource+Code+Pro:400,400i,600" />
  <link rel="stylesheet" href="{{ root_prefix }}/m-dark+documentation.compiled.css" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#385170" />
  <style>
    .m-doc-browse-list { list-style: none; margin: 0; padding: 0; }
    .m-doc-browse-entry {
      margin: 0;
      padding: 0;
      margin-bottom: 0.58rem;
    }
    .m-doc-browse-entry-grid {
      display: grid;
      grid-template-columns: 1fr;
      border: 1px solid rgba(130, 163, 198, 0.16);
      border-radius: 0.18rem;
      overflow: hidden;
    }
    .m-doc-browse-entry-main,
    .m-doc-browse-entry-ref {
      padding: 0.5rem 0.78rem;
    }
    .m-doc-browse-entry-main-link {
      display: inline-block;
      font-weight: 600;
      font-size: 1rem;
      line-height: 1.4;
      overflow-wrap: anywhere;
    }
    .m-doc-browse-entry-source {
      margin-top: 0.16rem;
      font-size: 0.88rem;
      overflow-wrap: anywhere;
    }
    .m-doc-browse-entry-ref {
      border-top: 1px solid rgba(130, 163, 198, 0.16);
    }
    .m-doc-browse-entry-ref-links {
      line-height: 1.4;
      overflow-wrap: anywhere;
      margin-top: 0;
    }
    .m-doc-browse-entry-ref-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .m-doc-browse-entry-ref-item {
      margin: 0 0 0.16rem;
      line-height: 1.35;
    }
    .m-doc-browse-entry-ref-item:last-child {
      margin-bottom: 0;
    }
    .m-doc-browse-entry-ref-kind {
      margin-left: 0.2rem;
    }
    @media screen and (min-width: 62rem) {
      .m-doc-browse-entry-grid {
        grid-template-columns: 1fr 1fr;
      }
      .m-doc-browse-entry-ref {
        border-top: 0;
        border-left: 1px solid rgba(130, 163, 198, 0.16);
      }
      .m-doc-browse-entry-grid-single {
        grid-template-columns: 1fr;
      }
      .m-doc-browse-entry-grid-single .m-doc-browse-entry-ref {
        border-left: 0;
      }
    }
  </style>
</head>
<body>
<header><nav id="navigation">
  <div class="m-container">
    <div class="m-row">
      <a href="{{ root_prefix }}/index.html" id="m-navbar-brand" class="m-col-t-8 m-col-m-none m-left-m">Dea/L0 API</a>
      <div class="m-col-t-4 m-hide-m m-text-right m-nopadr">
        <a href="#search" class="m-doc-search-icon" title="Search" onclick="return showSearch()"><svg style="height: 0.9rem;" viewBox="0 0 16 16">
          <path id="m-doc-search-icon-path" d="m6 0c-3.31 0-6 2.69-6 6 0 3.31 2.69 6 6 6 1.49 0 2.85-0.541 3.89-1.44-0.0164 0.338 0.147 0.759 0.5 1.15l3.22 3.79c0.552 0.614 1.45 0.665 2 0.115 0.55-0.55 0.499-1.45-0.115-2l-3.79-3.22c-0.392-0.353-0.812-0.515-1.15-0.5 0.895-1.05 1.44-2.41 1.44-3.89 0-3.31-2.69-6-6-6zm0 1.56a4.44 4.44 0 0 1 4.44 4.44 4.44 4.44 0 0 1-4.44 4.44 4.44 4.44 0 0 1-4.44-4.44 4.44 4.44 0 0 1 4.44-4.44z"/>
        </svg></a>
      </div>
      <div id="m-navbar-collapse" class="m-col-t-12 m-show-m m-col-m-none m-right-m">
        <div class="m-row">
          <ol class="m-col-t-6 m-col-m-none">
            <li><a href="{{ root_prefix }}/index.html">Home</a></li>
            <li><a href="{{ root_prefix }}/stage1.html">Stage 1</a></li>
            <li><a href="{{ root_prefix }}/stage2.html">Stage 2</a></li>
            <li><a href="{{ root_prefix }}/shared.html">Shared</a></li>
          </ol>
          <ol class="m-col-t-6 m-col-m-none" start="5">
            <li><a href="https://github.com/googlielmo/dea-lang-l0">GitHub</a></li>
            <li class="m-show-m"><a href="#search" class="m-doc-search-icon" title="Search" onclick="return showSearch()"><svg style="height: 0.9rem;" viewBox="0 0 16 16">
              <use href="#m-doc-search-icon-path" />
            </svg></a></li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</nav></header>
<main><article>
  <div class="m-container m-container-inflatable">
    <div class="m-row">
      <div class="m-col-l-10 m-push-l-1">
        <h1>{{ title }}</h1>
        <p>Generated API index for the {{ title }} source set. Each entry links to a source overview and available type reference pages.</p>
        <ul class="m-doc-browse-list">
{% for entry in entries %}
          <li class="m-doc-browse-entry">
            <div class="m-doc-browse-entry-grid{% if not entry.reference_links %} m-doc-browse-entry-grid-single{% endif %}">
              <div class="m-doc-browse-entry-main">
                <a class="m-doc-browse-entry-main-link" href="{{ entry.url }}">{{ entry.title }}</a>
{% if entry.source_path and entry.source_path != entry.title %}
                <div class="m-doc m-doc-browse-entry-source">{{ entry.source_path }}</div>
{% endif %}
              </div>
{% if entry.reference_links %}
              <div class="m-doc-browse-entry-ref">
                <div class="m-doc m-doc-browse-entry-ref-links">
                  <ul class="m-doc-browse-entry-ref-list">
{% for link in entry.reference_links %}
                    <li class="m-doc-browse-entry-ref-item"><a href="{{ link.url }}">{{ link.label }}</a><span class="m-doc m-doc-browse-entry-ref-kind">{{ link.kind }}</span></li>
{% endfor %}
                  </ul>
                </div>
              </div>
{% endif %}
            </div>
          </li>
{% endfor %}
        </ul>
      </div>
    </div>
  </div>
</article></main>
<div class="m-doc-search" id="search">
  <a href="#!" onclick="return hideSearch()"></a>
  <div class="m-container">
    <div class="m-row">
      <div class="m-col-m-8 m-push-m-2">
        <div class="m-doc-search-header m-text m-small">
          <div><span class="m-label m-default">Tab</span> / <span class="m-label m-default">T</span> to search, <span class="m-label m-default">Esc</span> to close</div>
          <div id="search-symbolcount">&hellip;</div>
        </div>
        <div class="m-doc-search-content">
          <form>
            <input type="search" name="q" id="search-input" placeholder="Loading &hellip;" disabled="disabled" autofocus="autofocus" autocomplete="off" spellcheck="false" />
          </form>
          <noscript class="m-text m-danger m-text-center">Unlike everything else in the docs, the search functionality <em>requires</em> JavaScript.</noscript>
          <div id="search-help" class="m-text m-dim m-text-center">
            <p class="m-noindent">Search for symbols, directories, files, pages or
            modules. You can omit any prefix from the symbol or file path; adding a
            <code>:</code> or <code>/</code> suffix lists all members of given symbol or
            directory.</p>
            <p class="m-noindent">Use <span class="m-label m-dim">&darr;</span>
            / <span class="m-label m-dim">&uarr;</span> to navigate through the list,
            <span class="m-label m-dim">Enter</span> to go.
            <span class="m-label m-dim">Tab</span> autocompletes common prefix, you can
            copy a link to the result using <span class="m-label m-dim">⌘</span>
            <span class="m-label m-dim">L</span> while <span class="m-label m-dim">⌘</span>
            <span class="m-label m-dim">M</span> produces a Markdown link.</p>
          </div>
          <div id="search-notfound" class="m-text m-warning m-text-center">Sorry, nothing was found.</div>
          <ul id="search-results"></ul>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="{{ root_prefix }}/search-v2.js"></script>
<script src="{{ root_prefix }}/searchdata-v2.js" async="async"></script>
</body>
</html>
