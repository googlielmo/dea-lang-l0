PROJECT_NAME           = "Dea/L0 API"
PROJECT_NUMBER         = "{{ project_number }}"
OUTPUT_DIRECTORY       = "{{ output_directory }}"
INPUT                  = \
    "{{ mainpage }}" \
    "{{ stage1_dir }}" \
    "{{ stage2_src_dir }}" \
    "{{ stage2_cli_file }}" \
    "{{ shared_stdlib_dir }}" \
    "{{ shared_runtime_dir }}"
RECURSIVE              = YES
FILE_PATTERNS          = *.py *.l0 *.h *.md
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = "{{ strip_from_path }}"
STRIP_FROM_INC_PATH    = "{{ strip_from_path }}"
EXCLUDE_PATTERNS       = */__pycache__/* */.pytest_cache/* */test_* */tests/* */fixtures/*
EXTENSION_MAPPING      = l0=C
OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_LOGFILE           = "{{ warn_logfile }}"
QUIET                  = YES
GENERATE_HTML          = NO
GENERATE_XML           = {{ generate_xml }}
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO
GENERATE_LATEX         = {{ generate_latex }}
LATEX_OUTPUT           = latex
PDF_HYPERLINKS         = YES
USE_PDFLATEX           = YES
COMPACT_LATEX          = NO
CREATE_SUBDIRS         = NO
USE_MDFILE_AS_MAINPAGE = "{{ mainpage }}"
