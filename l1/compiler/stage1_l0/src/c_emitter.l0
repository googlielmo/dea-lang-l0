 * @param c_init Lowered initializer.
 */
func cem_emit_let_decl(self: CEmitter*, c_type: string, c_var_name: string, c_init: string) {
    ccb_emit(self.out, concat4_s(c_type, " ", c_var_name, concat3_s(" = ", c_init, ";")));
}

/**
 * Emit an assignment statement.
 *
 * @param self Emitter to update.
 * @param c_target Lowered lvalue.
 * @param c_value Lowered rvalue.
