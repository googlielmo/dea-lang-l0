module lexer_test;

import std.io;
import std.string;
import std.assert;

import lexer;
import tokens;
import util.diag;

/**
 * Lexes source and asserts that the first token is one integer literal.
 *
 * @param source Source text to lex.
 * @param expected_text Expected literal spelling preserved in the token.
 * @param expected_value Expected parsed integer value.
 */
func expect_single_int(source: string, expected_text: string, expected_value: int) {
    let ls = ls_create(source, "<test>");
    let toks = tokenize(ls);
    assert(toks != null, "Expected lexing to succeed");
    assert(!ls_has_errors(ls), "Expected no lexer diagnostics");

    let tv = toks as TokenVector;
    assert(tv_len(tv) == 2, "Expected one token plus EOF");

    let tok = tv_get(tv, 0);
    match (tok.token_type) {
        TT_INT(text, value) => {
            assert(eq_s(text, expected_text), "Unexpected integer literal text");
            assert(value == expected_value, "Unexpected integer literal value");
        }
        _ => {
            printl_ss("actual token:", token_to_string(tok));
            assert(false, "Expected integer literal token");
        }
    }

    tv_free(tv);
    ls_free(ls);
}

/**
 * Lexes source and asserts that the first token is one bigint literal.
 *
 * @param source Source text to lex.
 * @param expected_text Expected literal spelling preserved in the token.
 * @param expected_base Expected numeric base.
 */
func expect_single_bigint(source: string, expected_text: string, expected_base: int) {
    let ls = ls_create(source, "<test>");
    let toks = tokenize(ls);
    assert(toks != null, "Expected lexing to succeed");
    assert(!ls_has_errors(ls), "Expected no lexer diagnostics");

    let tv = toks as TokenVector;
    assert(tv_len(tv) == 2, "Expected one token plus EOF");

    let tok = tv_get(tv, 0);
    match (tok.token_type) {
        TT_BIGINT(text, base) => {
            assert(eq_s(text, expected_text), "Unexpected bigint literal text");
            assert(base == expected_base, "Unexpected bigint base");
        }
        _ => {
            printl_ss("actual token:", token_to_string(tok));
            assert(false, "Expected bigint literal token");
        }
    }

    tv_free(tv);
    ls_free(ls);
}

/**
 * Lexes source and asserts that the first token is one real literal.
 *
 * @param source Source text to lex.
 * @param expected_sig Expected significand spelling preserved in the token.
 * @param expected_exp_text Expected exponent text without the marker and including any explicit sign.
 * @param expected_is_float Whether the token should report the float suffix.
 */
func expect_single_real(source: string, expected_sig: string, expected_exp_text: string, expected_is_float: bool) {
    let ls = ls_create(source, "<test>");
    let toks = tokenize(ls);
    assert(toks != null, "Expected lexing to succeed");
    assert(!ls_has_errors(ls), "Expected no lexer diagnostics");

    let tv = toks as TokenVector;
    assert(tv_len(tv) == 2, "Expected one token plus EOF");

    let tok = tv_get(tv, 0);
    match (tok.token_type) {
        TT_REALNUM(sig, exp_text, is_float) => {
            assert(eq_s(sig, expected_sig), "Unexpected real literal significand");
            assert(eq_s(exp_text, expected_exp_text), "Unexpected real literal exponent text");
            assert(is_float == expected_is_float, "Unexpected real literal float suffix flag");
        }
        _ => {
            printl_ss("actual token:", token_to_string(tok));
            assert(false, "Expected real literal token");
        }
    }

    tv_free(tv);
    ls_free(ls);
}

/**
 * Lexes source and asserts the first diagnostic code.
 *
 * @param source Source text to lex.
 * @param expected Expected first diagnostic code.
 */
func expect_lex_error(source: string, expected: string) {
    let ls = ls_create(source, "<test>");
    let toks = tokenize(ls);
    assert(toks == null, "Expected lexing to fail");
    assert(ls_has_errors(ls), "Expected lexer diagnostics");
    assert(diag_count(ls.diags) > 0, "Expected at least one diagnostic");

    let diag = diag_get(ls.diags, 0);
    if (!eq_s(diag.code, expected)) {
        printl_ss("actual error code:", diag.code);
        printl_ss("actual error message:", diag.message);
        assert(false, "Unexpected lexer diagnostic code");
    }

    ls_free(ls);
}

/**
 * Lexes source and asserts the first two tokens by rendered spelling.
 *
 * @param source Source text to lex.
 * @param expected_first Expected rendering for token 0.
 * @param expected_second Expected rendering for token 1.
 */
func expect_two_tokens(source: string, expected_first: string, expected_second: string) {
    let ls = ls_create(source, "<test>");
    let toks = tokenize(ls);
    assert(toks != null, "Expected lexing to succeed");
    assert(!ls_has_errors(ls), "Expected no lexer diagnostics");

    let tv = toks as TokenVector;
    assert(tv_len(tv) == 3, "Expected two tokens plus EOF");

    let tok0 = tv_get(tv, 0);
    let tok1 = tv_get(tv, 1);
    let actual0 = token_to_string(tok0);
    let actual1 = token_to_string(tok1);
    if (!eq_s(actual0, expected_first)) {
        printl_ss("actual token 0:", actual0);
        assert(false, "Unexpected first token");
    }
    if (!eq_s(actual1, expected_second)) {
        printl_ss("actual token 1:", actual1);
        assert(false, "Unexpected second token");
    }

    tv_free(tv);
    ls_free(ls);
}

/**
 * Tests accepted prefixed integer literals.
 */
func test_prefixed_int_literals_ok() {
    expect_single_int("0x2a", "0x2a", 42);
    expect_single_int("0b101010", "0b101010", 42);
    expect_single_int("0o52", "0o52", 42);
    expect_single_int("-0x2a", "-0x2a", -42);
    expect_single_int("-0b101010", "-0b101010", -42);
    expect_single_int("-0o52", "-0o52", -42);
}

/**
 * Tests malformed prefixed integer literals.
 */
func test_prefixed_int_literals_err() {
    expect_lex_error("0x", "LEX-0062");
    expect_lex_error("0b", "LEX-0063");
    expect_lex_error("0o", "LEX-0064");
    expect_lex_error("0xg", "LEX-0062");
    expect_lex_error("0b2", "LEX-0063");
    expect_lex_error("0o8", "LEX-0064");
    expect_lex_error("0X2A", "LEX-0061");
    expect_lex_error("0B101010", "LEX-0061");
    expect_lex_error("0O52", "LEX-0061");
    expect_lex_error("0x1g", "LEX-0061");
    expect_lex_error("0b12", "LEX-0061");
    expect_lex_error("0o78", "LEX-0061");
    expect_lex_error("0xff_name", "LEX-0061");
}

/**
 * Tests that signed 32-bit integer boundaries parse in every supported base.
 */
func test_int_literal_limits_all_bases() {
    expect_single_int("2147483647", "2147483647", 2147483647);
    expect_single_int("-2147483648", "-2147483648", -2147483648);
    expect_single_int("0x7fffffff", "0x7fffffff", 2147483647);
    expect_single_int("-0x80000000", "-0x80000000", -2147483648);
    expect_single_int("0b1111111111111111111111111111111",
        "0b1111111111111111111111111111111", 2147483647);
    expect_single_int("-0b10000000000000000000000000000000",
        "-0b10000000000000000000000000000000", -2147483648);
    expect_single_int("0o17777777777", "0o17777777777", 2147483647);
    expect_single_int("-0o20000000000", "-0o20000000000", -2147483648);
}

/**
 * Tests that integer literals exceeding 32-bit signed range produce bigint tokens.
 */
func test_prefixed_int_literals_overflow() {
    expect_single_bigint("2147483648", "2147483648", 10);
    expect_single_bigint("-2147483649", "-2147483649", 10);
    expect_single_bigint("0x80000000", "80000000", 16);
    expect_single_bigint("-0x80000001", "-80000001", 16);
    expect_single_bigint("0b10000000000000000000000000000000",
        "10000000000000000000000000000000", 2);
    expect_single_bigint("-0b10000000000000000000000000000001",
        "-10000000000000000000000000000001", 2);
    expect_single_bigint("0o20000000000", "20000000000", 8);
    expect_single_bigint("-0o20000000001", "-20000000001", 8);
}

/**
 * Tests accepted real literals.
 */
func test_real_literals_ok() {
    expect_single_real("1.0", "1.0", "", false);
    expect_single_real("0.0", "0.0", "", false);
    expect_single_real("123.456", "123.456", "", false);
    expect_single_real("1.0f", "1.0", "", true);
    expect_single_real("1.0F", "1.0", "", true);
    expect_single_real("-1.0", "-1.0", "", false);
    expect_single_real("-1.0f", "-1.0", "", true);

    expect_single_real("1e3", "1", "3", false);
    expect_single_real("1E3", "1", "3", false);
    expect_single_real("1e+3", "1", "+3", false);
    expect_single_real("1e-3", "1", "-3", false);
    expect_single_real("1e3f", "1", "3", true);
    expect_single_real("1E-3F", "1", "-3", true);
    expect_single_real("-1e3", "-1", "3", false);
    expect_single_real("-1e-3f", "-1", "-3", true);
}

/**
 * Tests malformed real literals.
 */
func test_real_literals_err() {
    expect_lex_error("1e", "LEX-0065");
    expect_lex_error("1e+", "LEX-0065");
    expect_lex_error("1e-", "LEX-0065");
    expect_lex_error("1.0e", "LEX-0065");
    expect_lex_error("1.0e+", "LEX-0065");

    expect_lex_error("1.0x", "LEX-0066");
    expect_lex_error("1e3x", "LEX-0066");
    expect_lex_error("1.0ff", "LEX-0066");
    expect_lex_error("1e3foo", "LEX-0066");

    expect_lex_error("1.0d", "LEX-0067");
    expect_lex_error("1.0D", "LEX-0067");
    expect_lex_error("1e3d", "LEX-0067");

    expect_lex_error("123f", "LEX-0068");
    expect_lex_error("123F", "LEX-0068");
    expect_lex_error("-123f", "LEX-0068");
}

/**
 * Tests boundary forms that are not currently recognized as real literals.
 */
func test_real_literal_boundaries() {
    expect_two_tokens("1.", "int(1)", ".");
    expect_two_tokens(".5", ".", "int(5)");
}

/**
 * Tests implemented and still-reserved integer builtin names.
 */
func test_small_integer_builtin_words() {
    expect_two_tokens("tiny short", "ident(tiny)", "ident(short)");
    expect_two_tokens("ushort long", "ident(ushort)", "ident(long)");
    expect_two_tokens("uint ulong", "ident(uint)", "ident(ulong)");
}

/**
 * Main entry point for the module.
 */
func main() {
    test_prefixed_int_literals_ok();
    test_prefixed_int_literals_err();
    test_int_literal_limits_all_bases();
    test_prefixed_int_literals_overflow();
    test_real_literals_ok();
    test_real_literals_err();
    test_real_literal_boundaries();
    test_small_integer_builtin_words();
    printl_s("lexer_test: all tests passed");
}
