module typing_bitwise_err;

func err_bool_and() {
    let x = true & false; // TYP-0170
}

func err_float_or() {
    let x = 1.0 | 2.0; // TYP-0170
}

func err_shift_bool() {
    let x = 1 << true; // TYP-0170
}

func err_unary_bool() {
    let x = ~false; // TYP-0170
}
