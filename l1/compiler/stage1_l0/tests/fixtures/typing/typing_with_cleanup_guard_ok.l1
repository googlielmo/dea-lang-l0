module typing_with_cleanup_guard_ok;

func ok() -> int? {
    return 1 as int?;
}

func fail() -> int? {
    return null;
}

/**
 * Keeps cleanup references on the safe subset only.
 */
func ok_cleanup_guard_subset() -> int? {
    with (let q: int? = ok()?,
          let p: int = fail()?) {
    } cleanup {
        if (q != null) {
            q as int;
        }
    }
    return 0 as int?;
}
