module typing_string_equality_ok;

func literal_and_empty_checks() -> bool {
    let empty = "";
    return "dea" == "dea" && "dea" != "l1" && empty == "" && empty != "x";
}

func branch_and_loop(seed: string) -> int {
    let count = 0;
    while (seed == "go" && count != 2) {
        count = count + 1;
    }
    if (seed == "go" && count == 2 && seed != "stop") {
        return count;
    }
    return 0;
}

func compare_aliases(seed: string) -> bool {
    let alias = seed;
    return alias == seed && alias != "other";
}

func main() -> int {
    if (literal_and_empty_checks() && compare_aliases("go") && branch_and_loop("go") == 2) {
        return 1;
    }
    return 0;
}
