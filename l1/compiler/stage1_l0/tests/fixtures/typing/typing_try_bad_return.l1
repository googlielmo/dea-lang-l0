module typing_try_bad_return;

/**
 * Triggers `TYP-0251` for postfix try in a non-nullable function.
 *
 * @param value Nullable input value.
 * @return Never produced successfully.
 */
func bad_return(value: int?) -> int {
    return value?;
}
