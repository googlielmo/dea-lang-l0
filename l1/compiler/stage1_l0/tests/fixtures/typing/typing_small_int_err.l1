module typing_small_int_err;

struct Packet {
    a: tiny;
}

func take_tiny(x: tiny) -> int {
    return x;
}

func return_nonliteral_narrow(x: int) -> tiny {
    return x; // TYP-0315
}

func assign_nonliteral_narrow(x: int) {
    let t: tiny = 0;
    t = x; // TYP-0311
}

func call_nonliteral_narrow(x: int) -> int {
    return take_tiny(x); // TYP-0312
}

func struct_nonliteral_narrow(x: int) -> Packet {
    return Packet(x); // TYP-0313
}
