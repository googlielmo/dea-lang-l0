module real_transcendental_main;

import std.real;

func main() -> int {
    if (std.real::exp_f(0.0f) != 1.0f) { return 1; }
    if (std.real::log_d(1.0) != 0.0) { return 2; }
    if (std.real::pow_f(2.0f, 3.0f) != 8.0f) { return 3; }

    let s = std.real::sin_d(0.0);
    if (s != 0.0) { return 4; }
    let c = std.real::cos_f(0.0f);
    if (c != 1.0f) { return 5; }

    return 0;
}
