/**
 * Tests function pointer type syntax in annotations and aliases.
 */
func test_function_pointer_type_syntax_ok() {
    let src = "module main; type Callback = func(int, bool) -> int; type MaybeCallback = (func() -> void)?; func main(cb: func(int) -> int) -> int { let chosen: (func(int) -> int)? = cb; return cb(1); }";
    let result = parse_module_source(src, "<test>");
    if (parse_has_errors(result)) {
        let diag = parse_diag_get(result, 0);
        printl_ss("unexpected parse error code:", diag.code);
        printl_ss("unexpected parse error message:", diag.message);
        assert(false, "Expected function pointer type syntax to parse");
    }

    let root = result.root_module as Module*;
    let callback_top = ptr_vec_get(root.decls, 0) as TopLevelDecl*;
    let callback = callback_top.data as TypeAliasDecl*;
    assert(callback.target.func_params != null, "expected function type params");
    assert(vec_size(callback.target.func_params as VectorBase*) == 2, "expected two callback parameters");
    assert(callback.target.func_result != null, "expected callback result");

    let maybe_top = ptr_vec_get(root.decls, 1) as TopLevelDecl*;
    let maybe = maybe_top.data as TypeAliasDecl*;
    assert(maybe.target.is_nullable, "expected nullable function pointer alias");
    assert(maybe.target.func_params != null, "expected nullable function pointer params");
    assert(vec_size(maybe.target.func_params as VectorBase*) == 0, "expected zero-arg function type");

    parse_result_free(result);
}

/**
 * Tests test_top_level_multi_error_collection.
 */
func test_top_level_multi_error_collection() {
    let src = "module main; struct Broken { x: 123; } type T = int func good() -> int { return 0; }";
    expect_min_error_count(src, 2);
}

/**
 * Main entry point for the module.
 */
func main() {
    test_valid_module();
    test_module_decl_error();
    test_reserved_variable_name_error();
    test_top_level_const_ok();
    test_top_level_const_missing_type_err();
    test_top_level_const_missing_initializer_err();
    test_local_const_rejected_err();
    test_bitwise_unary_precedence_shape();
    test_with_mixed_forms_error();
    test_case_empty_error();
    test_expr_precedence_postfix_and_qualified_type_ok();
    test_prefixed_int_literals_ok();
    test_prefixed_int_literals_err();
    test_postfix_chain_ok();
    test_type_expr_call_arg_ok();
    test_small_integer_type_positions_ok();
    test_large_integer_type_positions_ok();
    test_bigint_literal_expr_shape();
    test_float_type_positions_ok();
    test_real_literals_in_exprs_ok();
    test_bitwise_binary_ops_ok();
    test_bitwise_precedence_shape();
    test_qualified_expr_module_path_ok();
    test_qualified_type_name_ok();
    test_top_level_let_bitwise_ok();
    test_type_alias_missing_semi_error();
    test_struct_field_error();
    test_enum_variant_field_error();
    test_new_expr_bitwise_arg_ok();
    test_function_pointer_type_syntax_ok();
    test_top_level_multi_error_collection();
    printl_s("parser_test: all tests passed");
}
