/**
 * Tests that out-of-int literals parse as `EX_BIGINT` with preserved text and base.
 */
func test_bigint_literal_expr_shape() {
    let src = "module main; func main() -> long { let x: long = 2147483648; return 0x80000000; }";
    let result = parse_module_source(src, "<test>");
    assert(!parse_has_errors(result), "Expected parse to succeed");
    assert(result.root_module != null, "Expected parsed module");

    let root = result.root_module as Module*;
    assert(vec_size(root.decls) == 1, "Expected one declaration");
    let top = ptr_vec_get(root.decls, 0) as TopLevelDecl*;
    assert(ord(top.kind) == ord(TD_FUNC), "Expected function declaration");

    let func_decl = top.data as FuncDecl*;
    let body = stmt_arena_get(result.stmt_arena, func_decl.body);
    assert(body.ids != null, "Expected function body block statements");
    let stmts = body.ids as VectorBase*;
    assert(vec_size(stmts) == 2, "Expected let plus return statements");

    let let_stmt = stmt_arena_get(result.stmt_arena, id_vec_get(stmts, 0));
    let let_expr = expr_arena_get(result.expr_arena, let_stmt.expr_a);
    assert(ord(let_expr.kind) == ord(EX_BIGINT), "Expected bigint let initializer");
    assert(let_expr.text_value == "2147483648", "Unexpected decimal bigint payload");
    assert(let_expr.base_value == 10, "Unexpected decimal bigint base");

    let return_stmt = stmt_arena_get(result.stmt_arena, id_vec_get(stmts, 1));
    let return_expr = expr_arena_get(result.expr_arena, return_stmt.expr_a);
    assert(ord(return_expr.kind) == ord(EX_BIGINT), "Expected bigint return expression");
    assert(return_expr.text_value == "80000000", "Unexpected hexadecimal bigint payload");
    assert(return_expr.base_value == 16, "Unexpected hexadecimal bigint base");

    parse_result_free(result);
}

/**
 * Tests floating literals in ordinary expressions.
 */
func test_real_literals_in_exprs_ok() {
    let src = "module main; func main() -> double { let x: float = 1.0f; let y: double = 1e3; return -x + y / 2.0; }";
    expect_ok(src);
}

/**
 * Tests bitwise operators in ordinary expressions.
 */
func test_bitwise_binary_ops_ok() {
    let src = "module main; func main() -> int { let x: int = (1 & 3) | (2 ^ 4); return x + (~1); }";
    expect_ok(src);
}

/**
 * Tests bitwise precedence across binary layers.
 */
func test_bitwise_precedence_shape() {
    let src = "module main; func main() -> int { return 1 | 2 ^ 3 & 4 == 5 < 6 << 1 + 2 * 3; }";
    let result = parse_module_source(src, "<test>");
    assert(!parse_has_errors(result), "Expected parse to succeed");
    assert(result.root_module != null, "Expected parsed module");

    let root = result.root_module as Module*;
    assert(vec_size(root.decls) == 1, "Expected one declaration");
    let top = ptr_vec_get(root.decls, 0) as TopLevelDecl*;
    assert(ord(top.kind) == ord(TD_FUNC), "Expected function declaration");

    let func_decl = top.data as FuncDecl*;
    let body = stmt_arena_get(result.stmt_arena, func_decl.body);
    assert(body.ids != null, "Expected function body statements");
    let stmts = body.ids as VectorBase*;
    assert(vec_size(stmts) == 1, "Expected one return statement");

    let return_stmt = stmt_arena_get(result.stmt_arena, id_vec_get(stmts, 0));
    let root_expr = expr_arena_get(result.expr_arena, return_stmt.expr_a);
    assert(ord(root_expr.kind) == ord(EX_BINARY), "Expected binary root expression");
    assert(root_expr.text_value == "|", "Expected '|' at the root");

    let xor_expr = expr_arena_get(result.expr_arena, root_expr.expr_b);
    assert(ord(xor_expr.kind) == ord(EX_BINARY), "Expected '^' expression");
    assert(xor_expr.text_value == "^", "Expected '^' below '|'");

    let and_expr = expr_arena_get(result.expr_arena, xor_expr.expr_b);
    assert(ord(and_expr.kind) == ord(EX_BINARY), "Expected '&' expression");
    assert(and_expr.text_value == "&", "Expected '&' below '^'");

    let eq_expr = expr_arena_get(result.expr_arena, and_expr.expr_b);
    assert(ord(eq_expr.kind) == ord(EX_BINARY), "Expected equality expression");
    assert(eq_expr.text_value == "==", "Expected '==' below '&'");

    let rel_expr = expr_arena_get(result.expr_arena, eq_expr.expr_b);
    assert(ord(rel_expr.kind) == ord(EX_BINARY), "Expected relational expression");
    assert(rel_expr.text_value == "<", "Expected '<' below '=='");

    let shift_expr = expr_arena_get(result.expr_arena, rel_expr.expr_b);
    assert(ord(shift_expr.kind) == ord(EX_BINARY), "Expected shift expression");
    assert(shift_expr.text_value == "<<", "Expected '<<' below '<'");

    let add_expr = expr_arena_get(result.expr_arena, shift_expr.expr_b);
    assert(ord(add_expr.kind) == ord(EX_BINARY), "Expected additive expression");
    assert(add_expr.text_value == "+", "Expected '+' below '<<'");

    let mul_expr = expr_arena_get(result.expr_arena, add_expr.expr_b);
    assert(ord(mul_expr.kind) == ord(EX_BINARY), "Expected multiplicative expression");
    assert(mul_expr.text_value == "*", "Expected '*' below '+'");

    parse_result_free(result);
}

