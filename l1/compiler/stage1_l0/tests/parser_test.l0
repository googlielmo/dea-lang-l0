module parser_test;

import std.io;
import std.string;
import std.assert;
import std.vector;

import ast;
import parser;
import std.text;

/**
 * Parses source and asserts that the first diagnostic matches `expected`.
 *
 * @param source The module source to parse.
 * @param expected The expected diagnostic code.
 */
func expect_error_code(source: string, expected: string) {
    let result = parse_module_source(source, "<test>");
    if (!parse_has_errors(result)) {
        assert(false, concat3_s("Expected parse error ", expected, " but parse succeeded"));
    }
    if (parse_diag_count(result) < 1) {
        assert(false, "Expected at least one diagnostic");
    }

    let diag = parse_diag_get(result, 0);
    if (!eq_s(diag.code, expected)) {
        printl_ss("actual error code:", diag.code);
        assert(false, concat_s("Expected parse error code ", expected));
    }

    parse_result_free(result);
}

/**
 * Parses source and asserts that it succeeds without diagnostics.
 *
 * @param source The module source to parse.
 */
func expect_ok(source: string) {
    let result = parse_module_source(source, "<test>");
    if (parse_has_errors(result)) {
        if (parse_diag_count(result) > 0) {
            let diag = parse_diag_get(result, 0);
            printl_ss("unexpected parse error code:", diag.code);
            printl_ss("unexpected parse error message:", diag.message);
        }
        assert(false, "Expected parse to succeed");
    }
    assert(result.root_module != null, "Expected module for successful parse");

    parse_result_free(result);
}

/**
 * Parses source and asserts that at least `expected_min` diagnostics are reported.
 *
 * @param source The module source to parse.
 * @param expected_min The minimum number of diagnostics expected.
 */
func expect_min_error_count(source: string, expected_min: int) {
    let result = parse_module_source(source, "<test>");
    if (!parse_has_errors(result)) {
        assert(false, "Expected parse errors");
    }
    let count = parse_diag_count(result);
    if (count < expected_min) {
        printl_si("actual error count:", count);
        assert(false, "Expected more parse diagnostics");
    }
    parse_result_free(result);
}

/**
 * Tests test_valid_module.
 */
func test_valid_module() {
    let src = "module main; import std.io; func add(a: int, b: int) -> int { return 0; }";
    expect_ok(src);
}

/**
 * Tests test_module_decl_error.
 */
func test_module_decl_error() {
    expect_error_code("module ;", "PAR-0311");
}

/**
 * Tests test_reserved_variable_name_error.
 */
func test_reserved_variable_name_error() {
    let future_src = "module main; func main() -> int { let __dea__future__keyword__: int = 0; return __dea__future__keyword__; }";
    expect_error_code(future_src, "PAR-0010");

    let src = "module main; func main() -> int { let uint: int = 0; return uint; }";
    expect_error_code(src, "PAR-0011");
}

/**
 * Tests test_reserved_operator_error.
 */
func test_reserved_operator_error() {
    let src = "module main; func main() -> int { let x: int = ~1; return x; }";
    expect_error_code(src, "PAR-0226");
}

/**
 * Tests test_with_mixed_forms_error.
 */
func test_with_mixed_forms_error() {
    let src = "module main; func main() -> int { with (let x: int = 1 => drop x, let y: int = 2) { return 0; } }";
    expect_error_code(src, "PAR-0503");
}

/**
 * Tests test_case_empty_error.
 */
func test_case_empty_error() {
    let src = "module main; func main() -> int { case (1) { } return 0; }";
    expect_error_code(src, "PAR-0240");
}

/**
 * Tests test_expr_precedence_postfix_and_qualified_type_ok.
 */
func test_expr_precedence_postfix_and_qualified_type_ok() {
    let src = "module main; extern func sink(x: int) -> int; func helper(v: int*) -> int { return v[0]; } func main() -> int { let p: int* = new int(1); let n: int = sink((1 + 2 * 3) as int); let x: int = helper(p); let y: int = new color::Color::Red*(p).field?; return n + x + y; }";
    expect_ok(src);
}

/**
 * Tests prefixed integer literals in expressions.
 */
func test_prefixed_int_literals_ok() {
    let src = "module main; func main() -> int { let x: int = 0x2a + 0b10 + 0o4; let y: int = -0x2a; return x + y; }";
    expect_ok(src);
}

/**
 * Tests malformed prefixed integer literals surfacing lexer diagnostics through parsing.
 */
func test_prefixed_int_literals_err() {
    expect_error_code("module main; func main() -> int { return 0x; }", "LEX-0062");
    expect_error_code("module main; func main() -> int { return 0b12; }", "LEX-0061");
    expect_error_code("module main; func main() -> int { return 0o8; }", "LEX-0064");
}

/**
 * Tests test_postfix_chain_ok.
 */
func test_postfix_chain_ok() {
    let src = "module main; func main() -> int { let v: int = a.b(1, 2)[0]?; return v; }";
    expect_ok(src);
}

/**
 * Tests test_type_expr_call_arg_ok.
 */
func test_type_expr_call_arg_ok() {
    let src = "module main; extern func sizeof(x: int) -> int; func main() -> int { return sizeof(int*); }";
    expect_ok(src);
}

/**
 * Tests small integer builtin names in type positions.
 */
func test_small_integer_type_positions_ok() {
    let src = "module main; extern func sizeof(x: int) -> int; struct S { a: tiny; b: short?; c: ushort*; } func f(a: tiny, b: short?, c: ushort*) -> short { let x: tiny* = new tiny(1); let y: ushort? = null; return sizeof(short) as short; }";
    expect_ok(src);
}

/**
 * Tests large integer builtin names in type positions.
 */
func test_large_integer_type_positions_ok() {
    let src = "module main; extern func sizeof(x: int) -> int; struct S { a: uint; b: long?; c: ulong*; } func f(a: uint, b: long?, c: ulong*) -> long { let x: uint* = new uint(1); let y: ulong? = null; return sizeof(long) as long; }";
    expect_ok(src);
}

/**
 * Tests floating builtin names in type positions.
 */
func test_float_type_positions_ok() {
    let src = "module main; extern func sizeof(x: int) -> int; struct S { a: float; b: double?; c: float*; } func f(a: float, b: double?, c: float*) -> double { let x: float* = new float(1); let y: double? = null; return sizeof(double) as double; }";
    expect_ok(src);
}

/**
 * Tests that out-of-int literals parse as `EX_BIGINT` with preserved text and base.
 */
func test_bigint_literal_expr_shape() {
    let src = "module main; func main() -> long { let x: long = 2147483648; return 0x80000000; }";
    let result = parse_module_source(src, "<test>");
    assert(!parse_has_errors(result), "Expected parse to succeed");
    assert(result.root_module != null, "Expected parsed module");

    let root = result.root_module as Module*;
    assert(vec_size(root.decls) == 1, "Expected one declaration");
    let top = ptr_vec_get(root.decls, 0) as TopLevelDecl*;
    assert(ord(top.kind) == ord(TD_FUNC), "Expected function declaration");

    let func_decl = top.data as FuncDecl*;
    let body = stmt_arena_get(result.stmt_arena, func_decl.body);
    assert(body.ids != null, "Expected function body block statements");
    let stmts = body.ids as VectorBase*;
    assert(vec_size(stmts) == 2, "Expected let plus return statements");

    let let_stmt = stmt_arena_get(result.stmt_arena, id_vec_get(stmts, 0));
    let let_expr = expr_arena_get(result.expr_arena, let_stmt.expr_a);
    assert(ord(let_expr.kind) == ord(EX_BIGINT), "Expected bigint let initializer");
    assert(eq_s(let_expr.text_value, "2147483648"), "Unexpected decimal bigint payload");
    assert(let_expr.base_value == 10, "Unexpected decimal bigint base");

    let return_stmt = stmt_arena_get(result.stmt_arena, id_vec_get(stmts, 1));
    let return_expr = expr_arena_get(result.expr_arena, return_stmt.expr_a);
    assert(ord(return_expr.kind) == ord(EX_BIGINT), "Expected bigint return expression");
    assert(eq_s(return_expr.text_value, "80000000"), "Unexpected hexadecimal bigint payload");
    assert(return_expr.base_value == 16, "Unexpected hexadecimal bigint base");

    parse_result_free(result);
}

/**
 * Tests floating literals in ordinary expressions.
 */
func test_real_literals_in_exprs_ok() {
    let src = "module main; func main() -> double { let x: float = 1.0f; let y: double = 1e3; return -x + y / 2.0; }";
    expect_ok(src);
}

/**
 * Tests test_reserved_binary_and_error.
 */
func test_reserved_binary_and_error() {
    let src = "module main; func main() -> int { let x: int = 1 & 2; return x; }";
    expect_error_code(src, "PAR-0226");
}

/**
 * Tests test_reserved_binary_shift_error.
 */
func test_reserved_binary_shift_error() {
    let src = "module main; func main() -> int { let x: int = 1 << 2; return x; }";
    expect_error_code(src, "PAR-0226");
}

/**
 * Tests test_qualified_expr_module_path_ok.
 */
func test_qualified_expr_module_path_ok() {
    let src = "module main; func main() -> int { let x = parser.decl::impl_parse_module_tokens; return 0; }";
    expect_ok(src);
}

/**
 * Tests test_qualified_type_name_ok.
 */
func test_qualified_type_name_ok() {
    let src = "module main; func f(x: color::Color::Red*) -> color::Color::Red? { return null; }";
    expect_ok(src);
}

/**
 * Tests test_top_level_let_expr_error.
 */
func test_top_level_let_expr_error() {
    let src = "module main; let x: int = ~1;";
    expect_error_code(src, "PAR-0226");
}

/**
 * Tests test_type_alias_missing_semi_error.
 */
func test_type_alias_missing_semi_error() {
    let src = "module main; type Foo = int func main() -> int { return 0; }";
    expect_error_code(src, "PAR-0073");
}

/**
 * Tests test_struct_field_error.
 */
func test_struct_field_error() {
    let src = "module main; struct Foo { x: 123; }";
    expect_error_code(src, "PAR-0400");
}

/**
 * Tests test_enum_variant_field_error.
 */
func test_enum_variant_field_error() {
    let src = "module main; enum Foo { Bar(x: 123); }";
    expect_error_code(src, "PAR-0400");
}

/**
 * Tests test_new_expr_bad_arg_error.
 */
func test_new_expr_bad_arg_error() {
    let src = "module main; func main() -> int { let x: Foo* = new Foo(~1); return 0; }";
    expect_error_code(src, "PAR-0226");
}

/**
 * Tests test_top_level_multi_error_collection.
 */
func test_top_level_multi_error_collection() {
    let src = "module main; struct Broken { x: 123; } type T = int func good() -> int { return 0; }";
    expect_min_error_count(src, 2);
}

/**
 * Main entry point for the module.
 */
func main() {
    test_valid_module();
    test_module_decl_error();
    test_reserved_variable_name_error();
    test_reserved_operator_error();
    test_with_mixed_forms_error();
    test_case_empty_error();
    test_expr_precedence_postfix_and_qualified_type_ok();
    test_prefixed_int_literals_ok();
    test_prefixed_int_literals_err();
    test_postfix_chain_ok();
    test_type_expr_call_arg_ok();
    test_small_integer_type_positions_ok();
    test_large_integer_type_positions_ok();
    test_bigint_literal_expr_shape();
    test_float_type_positions_ok();
    test_real_literals_in_exprs_ok();
    test_reserved_binary_and_error();
    test_reserved_binary_shift_error();
    test_qualified_expr_module_path_ok();
    test_qualified_type_name_ok();
    test_top_level_let_expr_error();
    test_type_alias_missing_semi_error();
    test_struct_field_error();
    test_enum_variant_field_error();
    test_new_expr_bad_arg_error();
    test_top_level_multi_error_collection();
    printl_s("parser_test: all tests passed");
}
