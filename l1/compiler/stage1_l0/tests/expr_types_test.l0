        assert(count_diag_code(result, "TYP-0183") == 2, "expected both arity mismatches to report TYP-0183");
        assert(count_diag_code(result, "TYP-0312") == 1, "expected one argument type mismatch to report TYP-0312");
        assert(!has_diag_code(result, "TYP-0320"), "did not expect legacy function-call arity code");
        assert(!has_diag_code(result, "TYP-0321"), "did not expect legacy function-call argument type code");
        assert(!has_diag_code(result, "TYP-0315"), "did not expect secondary return type mismatch on call errors");
        analysis_result_free(result);
    }
    sp_free(sp);
}

