/**
 * Tests cleanup-block header-failure guard diagnostics.
 */
func test_typing_with_cleanup_guard() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let err_result = analysis_analyze_entry(sp, "typing_with_cleanup_guard_err", cfg);
        assert(analysis_has_errors(err_result), "expected typing errors for typing_with_cleanup_guard_err");
        assert(count_diag_code(err_result, "TYP-0156") == 2, "expected guarded cleanup diagnostics for both header vars");
        analysis_result_free(err_result);

        let ok_result = analysis_analyze_entry(sp, "typing_with_cleanup_guard_ok", cfg);
        assert(!analysis_has_errors(ok_result), "expected no typing errors for typing_with_cleanup_guard_ok");
        assert(!has_diag_code(ok_result, "TYP-0156"), "did not expect guarded cleanup diagnostics for nullable subset");
        analysis_result_free(ok_result);
    }
    sp_free(sp);
}

