/**
 * Create an empty driver state for isolated semantic helper tests.
 *
 * @return New empty driver state.
 */
func bt_empty_driver_state() -> DriverState* {
    return new DriverState("", ptr_vec_create(0), vs_create(0), diag_create(), vs_create(0), vs_create(0));
}

/**
 * Create an empty analysis result for isolated helper tests.
 *
 * @return New empty analysis result.
 */
func bt_empty_analysis_result() -> AnalysisResult* {
    return new AnalysisResult(bt_empty_driver_state(), diag_create(), null, null, null, spm_create(), sim_create(), spm_create());
}

/**
 * Parse and add one source module to a driver state.
 *
 * @param state Driver state to update.
 * @param source Module source text.
 * @param filename Source filename for diagnostics.
 */
func bt_push_source_unit(state: DriverState*, source: string, filename: string) {
    let pr = parse_module_source(source, filename);
    if (pr.root_module == null) {
        ptr_vec_push(state.units, new DriverUnit("", filename, pr) as void*);
        return;
    }

    let mod = pr.root_module as Module*;
    vs_push(state.source_names, filename);
    vs_push(state.source_texts, source);
    ptr_vec_push(state.units, new DriverUnit(mod.name, filename, pr) as void*);
}

/**
 * Build a full semantic analysis result from in-memory module sources.
 *
 * @param entry_module Entry-module name.
 * @param filenames Source filenames aligned with `sources`.
 * @param sources Module source texts aligned with `filenames`.
 * @return Fully analyzed result.
 */
func bt_analyze_sources(entry_module: string, filenames: VectorString*, sources: VectorString*) -> AnalysisResult* {
    let state = new DriverState(entry_module, ptr_vec_create(vs_size(sources)), vs_create(vs_size(sources)), diag_create(),
        vs_create(vs_size(sources)), vs_create(vs_size(sources)));

    for (let i = 0; i < vs_size(sources); i = i + 1) {
        bt_push_source_unit(state, vs_get(sources, i), vs_get(filenames, i));
    }

    let result = new AnalysisResult(state, diag_create(), null, null, null, spm_create(), sim_create(), spm_create());
    result.names = nr_resolve(state, result.diags);
    result.signatures = sig_resolve(state, result.names as NameResolution*, result.diags);
    result.locals_result = locals_resolve(state, result.diags);
    expr_types_check(result);
    return result;
}

/**
 * Join newline-terminated source lines into one module source string.
 *
 * @param lines Source lines in order.
 * @return Combined source text with trailing newlines.
 */
func bt_source(lines: VectorString*) -> string {
    with (let sb = sb_create() => sb_free(sb)) {
        for (let i = 0; i < vs_size(lines); i = i + 1) {
            sb_append(sb, vs_get(lines, i));
            sb_append(sb, "\n");
        }
        return sb_to_string(sb);
    }
}

/**
 * Tests test_codegen_options_defaults.
 */
func test_codegen_options_defaults() {
    let opts = cg_options_create();
    assert(opts.emit_line_directives, "line directives should default to enabled");
    assert(!opts.trace_arc, "trace_arc should default to false");
    assert(!opts.trace_memory, "trace_memory should default to false");
    cg_options_free(opts);
}

/**
 * Tests test_scope_context_tracks_declared_and_owned_variables.
 */
func test_scope_context_tracks_declared_and_owned_variables() {
    let scope = sc_create(null);
    let ty = type_builtin_int();
    sc_add_declared(scope, "plain", ty);
    sc_add_owned(scope, "owned", ty);

    assert(sc_lookup_declared_type(scope, "plain") != null, "declared variable should be found");
    assert(sc_lookup_declared_type(scope, "owned") != null, "owned variable should be found");
    assert(vec_size(scope.owned_vars) == 1, "expected one owned variable");

    sc_remove_owned(scope, "owned");
    assert(vec_size(scope.owned_vars) == 0, "owned variable should be removed");

    type_free(ty);
    sc_free(scope);
}

/**
 * Tests test_scope_context_inline_cleanup_tracking.
 */
func test_scope_context_inline_cleanup_tracking() {
    let scope = sc_create(null);
    assert(!sc_has_inline_cleanup(scope), "inline cleanup should start empty");
    sc_push_inline_cleanup(scope, 3);
    sc_push_inline_cleanup(scope, 9);
    assert(sc_has_inline_cleanup(scope), "inline cleanup should be present");
    assert(vec_size(scope.with_cleanup_inline as VectorBase*) == 2, "expected two cleanup items");
    sc_free(scope);
}

/**
 * Tests test_backend_scope_helpers_manage_cleanup_state.
 */
func test_backend_scope_helpers_manage_cleanup_state() {
    with (let result = bt_empty_analysis_result() => analysis_result_free(result),
          let opts = cg_options_create() => cg_options_free(opts),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let self = be_create(result, opts, cfg) => be_free(self)) {
        let borrowed_ty = type_builtin_int();
        let owned_ty = type_builtin_string();
        let temp_ty = type_builtin_string();
        let root = be_push_scope(self);
        sc_add_declared(root, "borrowed", borrowed_ty);
        sc_add_owned(root, "owned_name", owned_ty);

        assert(be_lookup_local_var_type(self, "borrowed") != null, "declared local lookup should succeed");
        assert(be_scope_chain_has_cleanup(self), "owned ARC local should trigger cleanup detection");

        let temp = be_materialize_arc_temp(self, "((dea_string)DEA_STRING_CONST(\"x\", 1))", temp_ty);
        assert(eq_s(temp, "dea_arc_1"), "ARC temp naming mismatch");
        assert(vec_size(root.owned_vars) == 2, "materialized ARC temp should become owned");

        let child = be_push_scope(self);
        sc_push_inline_cleanup(child, 7);
        assert(be_scope_chain_has_cleanup(self), "inline cleanup in child scope should be visible");
        be_pop_scope(self);
        be_pop_scope(self);
        type_free(borrowed_ty);
        type_free(owned_ty);
        type_free(temp_ty);
    }
}

/**
 * Tests test_analysis_expr_lookup_helpers.
 */
func test_analysis_expr_lookup_helpers() {
    let result = bt_empty_analysis_result();
    let expr_key = analysis_expr_key("demo.main", 7);
    assert(eq_s(expr_key, "demo.main::7"), "expression key mismatch");

    spm_put(result.expr_types, analysis_expr_key("demo.main", 7), type_builtin_bool() as void*);
    spm_put(result.intrinsic_targets, analysis_expr_key("demo.main", 8), type_builtin_int() as void*);
    sim_put(result.var_ref_resolution, analysis_expr_key("demo.main", 9), ord(VAR_RES_LOCAL));

    let expr_ty = analysis_get_expr_type(result, "demo.main", 7);
    let intrinsic_ty = analysis_get_intrinsic_target(result, "demo.main", 8);
    let var_res = analysis_get_var_ref_resolution(result, "demo.main", 9);

    assert(expr_ty != null, "expression type lookup should succeed");
    assert(type_is_builtin(expr_ty as Type*, "bool"), "expression type should be bool");
    assert(intrinsic_ty != null, "intrinsic target lookup should succeed");
    assert(type_is_builtin(intrinsic_ty as Type*, "int"), "intrinsic target should be int");
    assert(var_res != null && (var_res as int) == ord(VAR_RES_LOCAL), "var-ref resolution mismatch");

    type_free(expr_ty as Type*);
    type_free(intrinsic_ty as Type*);
    analysis_result_free(result);
}

/**
 * Tests test_analysis_has_arc_data_for_struct_and_nullable_pointer.
 */
func test_analysis_has_arc_data_for_struct_and_nullable_pointer() {
    let result = bt_empty_analysis_result();

    let struct_fields = ptr_vec_create(1);
    ptr_vec_push(struct_fields, new StructFieldInfo("name", type_builtin_string()) as void*);
    let struct_info = new StructInfo(
        "demo.main::Thing",
        "demo.main",
        "Thing",
        "",
        span_here(1, 1),
        type_new_struct("demo.main", "Thing"),
        struct_fields
    );

    result.signatures = new SignatureTables(spm_create(), spm_create(), spm_create(), spm_create());
    spm_put((result.signatures as SignatureTables*).struct_infos, "demo.main::Thing", struct_info as void*);

    let query_struct = type_new_struct("demo.main", "Thing");
    let query_nullable_ptr = type_new_nullable(type_new_pointer(type_builtin_int()));

    assert(analysis_has_arc_data(result, query_struct), "struct with string field should have ARC data");
    assert(!analysis_has_arc_data(result, query_nullable_ptr), "nullable pointer should use niche encoding without ARC");

    type_free(query_struct);
    type_free(query_nullable_ptr);
    analysis_result_free(result);
}

/**
 * Tests test_backend_generate_types_and_top_level_lets.
 */
func test_backend_generate_types_and_top_level_lets() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(12) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "struct Point {");
        vs_push(lines, "    x: int;");
        vs_push(lines, "    y: int;");
        vs_push(lines, "}");
        vs_push(lines, "enum MaybePoint {");
        vs_push(lines, "    None;");
        vs_push(lines, "    Some(value: Point);");
        vs_push(lines, "}");
        vs_push(lines, "let origin = Point(0, 0);");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let p = origin;");
        vs_push(lines, "    return p.x;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for type-order fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "/* Type definitions (dependency-ordered) */"),
            "type-definition section comment missing");
        assert(contains_s(generated,
            "struct dea_demo_main_Point {\n    dea_int x;\n    dea_int y;\n};\n#endif\n\n#ifndef DEA_DEFINED_dea_demo_main_MaybePoint"),
            "struct should be emitted before dependent enum");
        assert(contains_s(generated, "static struct dea_demo_main_Point dea_demo_main_origin = { .x = 0, .y = 0 };"),
            "top-level struct constructor let mismatch");
        assert(contains_s(generated, "return (p).x;"), "field access lowering mismatch");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_basic_control_flow.
 */
func test_backend_generate_basic_control_flow() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(16) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "func add(a: int, b: int) -> int {");
        vs_push(lines, "    return a + b;");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let sum = 0;");
        vs_push(lines, "    for (let i = 0; i < 3; i = i + 1) {");
        vs_push(lines, "        if (i < 2) {");
        vs_push(lines, "            sum = sum + add(i, 1);");
        vs_push(lines, "        }");
        vs_push(lines, "    }");
        vs_push(lines, "    while (sum > 0) {");
        vs_push(lines, "        return sum;");
        vs_push(lines, "    }");
        vs_push(lines, "    return 0;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for control-flow fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "dea_int dea_demo_main_add(dea_int a, dea_int b);"),
            "function declaration mismatch");
        assert(contains_s(generated, "return (_rt_iadd(a, b));"), "checked integer add lowering mismatch");
        assert(contains_s(generated, "// for loop"), "for-loop wrapper comment mismatch");
        assert(contains_s(generated, "dea_int i = 0;\n        while (1)"),
            "for-loop lowering mismatch");
        assert(contains_s(generated, "if ((i < 2))"), "if lowering mismatch");
        assert(contains_s(generated, "sum = (_rt_iadd(sum, dea_demo_main_add(i, 1)));"),
            "assignment and call lowering mismatch");
        assert(contains_s(generated, "while (1)"), "while lowering mismatch");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_loop_exit_case_lowering.
 */
func test_backend_generate_loop_exit_case_lowering() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(16) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    for (let i = 0; i < 3; i = i + 1) {");
        vs_push(lines, "        case (i) {");
        vs_push(lines, "            0 => {");
        vs_push(lines, "                continue;");
        vs_push(lines, "            }");
        vs_push(lines, "            else {");
        vs_push(lines, "                break;");
        vs_push(lines, "            }");
        vs_push(lines, "        }");
        vs_push(lines, "    }");
        vs_push(lines, "    return 0;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for case/loop fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "switch (_scrutinee) {"), "case lowering should use switch for ints");
        assert(contains_s(generated, "goto __lcont_"), "continue should lower to loop label goto");
        assert(contains_s(generated, "goto __lbrk_"), "break should lower to loop label goto");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_match_and_with_cleanup_block.
 */
func test_backend_generate_match_and_with_cleanup_block() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(24) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "enum MaybeInt {");
        vs_push(lines, "    None;");
        vs_push(lines, "    Some(value: int);");
        vs_push(lines, "}");
        vs_push(lines, "func make() -> MaybeInt {");
        vs_push(lines, "    return Some(7);");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let total = 0;");
        vs_push(lines, "    with (let x = 1) {");
        vs_push(lines, "        total = x;");
        vs_push(lines, "    } cleanup {");
        vs_push(lines, "        total = x;");
        vs_push(lines, "    }");
        vs_push(lines, "    match (make()) {");
        vs_push(lines, "        Some(v) => {");
        vs_push(lines, "            return v;");
        vs_push(lines, "        }");
        vs_push(lines, "        None => {");
        vs_push(lines, "            return total;");
        vs_push(lines, "        }");
        vs_push(lines, "    }");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for match/with fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "struct dea_demo_main_MaybeInt _scrutinee = dea_demo_main_make();"),
            "match scrutinee temp mismatch");
        assert(contains_s(generated, "switch ((_scrutinee).tag) {"), "match lowering should switch on enum tag");
        assert(contains_s(generated, "dea_int v = (_scrutinee).data.Some.value;"), "pattern binding mismatch");
        assert(contains_s(generated, "total = x;\n        }\n        {\n            total = x;"),
            "with cleanup block should run after body in header scope");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_with_cleanup_block_header_try_predeclares_nullable_lets.
 */
func test_backend_generate_with_cleanup_block_header_try_predeclares_nullable_lets() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(20) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "enum Expr {");
        vs_push(lines, "    Num(value: int);");
        vs_push(lines, "}");
        vs_push(lines, "func parse(c: int) -> Expr*? {");
        vs_push(lines, "    return null;");
        vs_push(lines, "}");
        vs_push(lines, "func free_expr(e: Expr*?) {");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> Expr*? {");
        vs_push(lines, "    let result: Expr*? = null;");
        vs_push(lines, "    with (let left: Expr*? = parse(0)?,");
        vs_push(lines, "          let right: Expr*? = parse(1)?) {");
        vs_push(lines, "        return result;");
        vs_push(lines, "    } cleanup {");
        vs_push(lines, "        if (result == null) { free_expr(left); free_expr(right); }");
        vs_push(lines, "    }");
        vs_push(lines, "    return result;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for with-header try fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "struct dea_demo_main_Expr* left = NULL;"),
            "nullable cleanup-block header let should be predeclared to null");
        assert(contains_s(generated, "struct dea_demo_main_Expr* right = NULL;"),
            "second nullable cleanup-block header let should be predeclared to null");
        assert(contains_s(generated, "left = dea_try_"), "predeclared left should be assigned after the try succeeds");
        assert(contains_s(generated, "right = dea_try_"), "predeclared right should be assigned after the try succeeds");
        assert(!contains_s(generated, "struct dea_demo_main_Expr* left = dea_try_"),
            "left should not be redeclared after predeclaration");
        assert(!contains_s(generated, "struct dea_demo_main_Expr* right = dea_try_"),
            "right should not be redeclared after predeclaration");
        assert(contains_s(generated, "dea_demo_main_free_expr(left);"),
            "cleanup block should still reference the predeclared left variable");
        assert(contains_s(generated, "dea_demo_main_free_expr(right);"),
            "cleanup block should still reference the predeclared right variable");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_drop_statement.
 */
func test_backend_generate_drop_statement() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(8) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "extern func alloc() -> int*;");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let p = alloc();");
        vs_push(lines, "    drop p;");
        vs_push(lines, "    return 0;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for drop fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "_rt_drop((void*)p);"), "drop call mismatch");
        assert(contains_s(generated, "p = NULL;"), "drop should null the pointer after release");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_new_and_try_lowering.
 */
func test_backend_generate_new_and_try_lowering() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(24) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "struct Box {");
        vs_push(lines, "    value: int;");
        vs_push(lines, "}");
        vs_push(lines, "enum Result {");
        vs_push(lines, "    Ok(value: int);");
        vs_push(lines, "}");
        vs_push(lines, "func maybe(flag: bool) -> int? {");
        vs_push(lines, "    if (flag) { return 7; }");
        vs_push(lines, "    return null;");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> int? {");
        vs_push(lines, "    let z = new Box();");
        vs_push(lines, "    let p = new Box(7);");
        vs_push(lines, "    let r = new Ok(9);");
        vs_push(lines, "    let x = maybe(true)?;");
        vs_push(lines, "    drop z;");
        vs_push(lines, "    drop p;");
        vs_push(lines, "    drop r;");
        vs_push(lines, "    return x;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for new/try fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "_rt_alloc_obj((dea_int)sizeof(struct dea_demo_main_Box));"),
            "new expression should allocate heap storage");
        assert(contains_s(generated, "(struct dea_demo_main_Box){ 0 }"),
            "zero-arg struct new should lower to zero initialization");
        assert(contains_s(generated, "*dea_new_"), "new expression should initialize the allocated object");
        assert(contains_s(generated, "dea_demo_main_Result_Ok"),
            "enum variant new should initialize the variant tag");
        assert(contains_s(generated, "dea_opt_int dea_try_"), "try expression should materialize a temp");
        assert(contains_s(generated, "if (!((dea_try_"), "try expression should check has_value");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_intrinsics_use_analyzed_target_types.
 */
func test_backend_generate_intrinsics_use_analyzed_target_types() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(16) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "enum Flag {");
        vs_push(lines, "    Off;");
        vs_push(lines, "    On;");
        vs_push(lines, "}");
        vs_push(lines, "struct Pair {");
        vs_push(lines, "    left: int;");
        vs_push(lines, "    right: int;");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let p = Pair(1, sizeof(Pair));");
        vs_push(lines, "    let f = On;");
        vs_push(lines, "    return p.right + ord(f);");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for sizeof/ord fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "((dea_int)sizeof(struct dea_demo_main_Pair))"),
            "sizeof should lower through the analyzed target type");
        assert(contains_s(generated, "((dea_int)((f).tag))"), "ord should lower to the enum tag");

        analysis_result_free(result);
    }
}

/**
 * Tests that user functions named like intrinsics are not lowered as `dea` intrinsics.
 */
func test_backend_generate_dea_intrinsics_respect_symbol_origin() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(24) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "enum Flag {");
        vs_push(lines, "    Off;");
        vs_push(lines, "    On;");
        vs_push(lines, "}");
        vs_push(lines, "func sizeof(x: int) -> int {");
        vs_push(lines, "    return x + 7;");
        vs_push(lines, "}");
        vs_push(lines, "func ord(x: int) -> int {");
        vs_push(lines, "    return x + 9;");
        vs_push(lines, "}");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let a = sizeof(4);");
        vs_push(lines, "    let b = ord(5);");
        vs_push(lines, "    let c = dea::sizeof(Flag);");
        vs_push(lines, "    let d = dea::ord(On);");
        vs_push(lines, "    return a + b + c + d;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for dea shadowing fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "dea_demo_main_sizeof(4)"),
            "local sizeof should lower as a normal function call");
        assert(contains_s(generated, "dea_demo_main_ord(5)"),
            "local ord should lower as a normal function call");
        assert(contains_s(generated, "((dea_int)sizeof(struct dea_demo_main_Flag))"),
            "dea::sizeof should lower through intrinsic emission");
        assert(contains_s(generated, "((dea_int)(((struct dea_demo_main_Flag){ .tag = dea_demo_main_Flag_On }).tag))"),
            "dea::ord should lower through intrinsic emission");

        analysis_result_free(result);
    }
}

/**
 * Tests test_backend_generate_string_copy_retains.
 */
func test_backend_generate_string_copy_retains() {
    with (let filenames = vs_create(1) => vs_free(filenames),
          let sources = vs_create(1) => vs_free(sources),
          let lines = vs_create(8) => vs_free(lines),
          let cfg = log_config_create(LL_ERROR, false) => drop cfg,
          let opts = cg_options_create() => cg_options_free(opts)) {
        opts.emit_line_directives = false;
        vs_push(filenames, "demo/main.l1");
        vs_push(lines, "module demo.main;");
        vs_push(lines, "func main() -> int {");
        vs_push(lines, "    let s = \"hi\";");
        vs_push(lines, "    let t = s;");
        vs_push(lines, "    return 0;");
        vs_push(lines, "}");
        vs_push(sources, bt_source(lines));

        let result = bt_analyze_sources("demo.main", filenames, sources);
        assert(!analysis_has_errors(result), "analysis should succeed for ARC copy fixture");

        let generated = backend_generate(result, opts, cfg);
        assert(contains_s(generated, "rt_string_retain(dea_copy_"), "copying an owned string should retain");
        assert(contains_s(generated, "rt_string_release(t);"), "owned local cleanup should release copied string");
        assert(contains_s(generated, "rt_string_release(s);"), "owned local cleanup should release original string");

        analysis_result_free(result);
    }
}

/**
 * Main entry point for the module.
 */
func main() {
    test_codegen_options_defaults();
    test_scope_context_tracks_declared_and_owned_variables();
    test_scope_context_inline_cleanup_tracking();
    test_backend_scope_helpers_manage_cleanup_state();
    test_analysis_expr_lookup_helpers();
    test_analysis_has_arc_data_for_struct_and_nullable_pointer();
    test_backend_generate_types_and_top_level_lets();
    test_backend_generate_basic_control_flow();
    test_backend_generate_loop_exit_case_lowering();
    test_backend_generate_match_and_with_cleanup_block();
    test_backend_generate_with_cleanup_block_header_try_predeclares_nullable_lets();
    test_backend_generate_drop_statement();
    test_backend_generate_new_and_try_lowering();
    test_backend_generate_intrinsics_use_analyzed_target_types();
    test_backend_generate_dea_intrinsics_respect_symbol_origin();
    test_backend_generate_string_copy_retains();
    printl_s("backend_test: all tests passed");
}
