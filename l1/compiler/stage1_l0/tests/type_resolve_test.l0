module type_resolve_test;

import std.io;
import std.string;
import std.assert;
import std.vector;
import std.hashset;

import analysis;
import sem_context;
import source_paths;
import ast;
import type_resolve;
import types;
import symbols;
import util.log;
import name_resolver;

/**
 * Returns the root directory for test fixtures.
 *
 * @return The semantics fixture directory used by these tests.
 */
func fixture_root() -> string {
    return "compiler/stage1_l0/tests/fixtures/semantics";
}

/**
 * Creates and configures source search paths for testing.
 *
 * @return Source search paths rooted at the semantics fixtures directory.
 */
func make_paths() -> SourceSearchPaths* {
    let sp = sp_create();
    sp_add_project_root(sp, fixture_root());
    return sp;
}

/**
 * Tests test_tr_symbol_lookup.
 */
func test_tr_symbol_lookup() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "ok_main", cfg);
        let nr = result.names as NameResolution*;
        let env = nr_env_find(nr, "ok_main") as ModuleEnv*;
        
        // Lookup local func
        let sym = tr_symbol_lookup(nr, env, "main", null, null);
        assert(sym != null, "main should be found");
        assert(ord((sym as Symbol*).kind) == ord(SYM_FUNC), "main should be a function");
        
        // Lookup imported func
        let sym2 = tr_symbol_lookup(nr, env, "make_point", null, null);
        assert(sym2 != null, "make_point should be found via import");
        assert((sym2 as Symbol*).module_name == "shared_types", "make_point should be in shared_types");

        with (let dea_path = vs_create(1) => vs_free(dea_path)) {
            vs_push(dea_path, "dea");
            let dea_sym = tr_symbol_lookup(nr, env, "sizeof", dea_path, null);
            assert(dea_sym != null, "dea::sizeof should be found");
            assert((dea_sym as Symbol*).module_name == "dea", "dea::sizeof should resolve from dea");
        }
        
        // Lookup qualified variant (Status::Active)
        let env_ok = nr_env_find(nr, "shared_types") as ModuleEnv*;
        with (let qual = vs_create(1) => vs_free(qual)) {
            vs_push(qual, "OptionInt");
            let sym3 = tr_symbol_lookup(nr, env_ok, "Some", null, qual);
            assert(sym3 != null, "OptionInt::Some should be found");
            assert(ord((sym3 as Symbol*).kind) == ord(SYM_ENUM_VARIANT), "Some should be a variant");
        }
        
        analysis_result_free(result);
    }
    sp_free(sp);
}

/**
 * Tests test_tr_resolve_type_ref.
 */
func test_tr_resolve_type_ref() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "ok_main", cfg);
        let nr = result.names as NameResolution*;
        let tables = result.signatures as SignatureTables*;
        let env = nr_env_find(nr, "ok_main") as ModuleEnv*;
        
        with (let seen = ss_create() => ss_free(seen)) {
            // builtin int
            let tref = new TypeRef("int", 0, false, null, null, null, null, Span(0,0,0,0));
            let ty = tr_resolve_type_ref(tables, nr, env, tref, result.diags, seen);
            assert(ty != null, "int should resolve");
            assert(type_is_builtin(ty as Type*, "int"), "should be int");
            type_free(ty as Type*);
            drop tref;

            let tref_tiny = new TypeRef("tiny", 0, false, null, null, null, null, Span(0,0,0,0));
            let ty_tiny = tr_resolve_type_ref(tables, nr, env, tref_tiny, result.diags, seen);
            assert(ty_tiny != null, "tiny should resolve");
            assert(type_is_builtin(ty_tiny as Type*, "tiny"), "should be tiny");
            type_free(ty_tiny as Type*);
            drop tref_tiny;

            let tref_short_opt = new TypeRef("short", 0, true, null, null, null, null, Span(0,0,0,0));
            let ty_short_opt = tr_resolve_type_ref(tables, nr, env, tref_short_opt, result.diags, seen);
            assert(ty_short_opt != null, "short? should resolve");
            assert(ord((ty_short_opt as Type*).kind) == ord(TY_NULLABLE), "should be nullable");
            assert(type_is_builtin((ty_short_opt as Type*).inner as Type*, "short"), "inner should be short");
            type_free(ty_short_opt as Type*);
            drop tref_short_opt;

            let tref_uint = new TypeRef("uint", 0, false, null, null, null, null, Span(0,0,0,0));
            let ty_uint = tr_resolve_type_ref(tables, nr, env, tref_uint, result.diags, seen);
            assert(ty_uint != null, "uint should resolve");
            assert(type_is_builtin(ty_uint as Type*, "uint"), "should be uint");
            type_free(ty_uint as Type*);
            drop tref_uint;

            let tref_long_opt = new TypeRef("long", 0, true, null, null, null, null, Span(0,0,0,0));
            let ty_long_opt = tr_resolve_type_ref(tables, nr, env, tref_long_opt, result.diags, seen);
            assert(ty_long_opt != null, "long? should resolve");
            assert(ord((ty_long_opt as Type*).kind) == ord(TY_NULLABLE), "should be nullable");
            assert(type_is_builtin((ty_long_opt as Type*).inner as Type*, "long"), "inner should be long");
            type_free(ty_long_opt as Type*);
            drop tref_long_opt;

            let tref_ushort_ptr = new TypeRef("ushort", 1, false, null, null, null, null, Span(0,0,0,0));
            let ty_ushort_ptr = tr_resolve_type_ref(tables, nr, env, tref_ushort_ptr, result.diags, seen);
            assert(ty_ushort_ptr != null, "ushort* should resolve");
            assert(ord((ty_ushort_ptr as Type*).kind) == ord(TY_POINTER), "should be pointer");
            assert(type_is_builtin((ty_ushort_ptr as Type*).inner as Type*, "ushort"), "inner should be ushort");
            type_free(ty_ushort_ptr as Type*);
            drop tref_ushort_ptr;

            let tref_ulong_ptr = new TypeRef("ulong", 1, false, null, null, null, null, Span(0,0,0,0));
            let ty_ulong_ptr = tr_resolve_type_ref(tables, nr, env, tref_ulong_ptr, result.diags, seen);
            assert(ty_ulong_ptr != null, "ulong* should resolve");
            assert(ord((ty_ulong_ptr as Type*).kind) == ord(TY_POINTER), "should be pointer");
            assert(type_is_builtin((ty_ulong_ptr as Type*).inner as Type*, "ulong"), "inner should be ulong");
            type_free(ty_ulong_ptr as Type*);
            drop tref_ulong_ptr;

            let tref_float = new TypeRef("float", 0, false, null, null, null, null, Span(0,0,0,0));
            let ty_float = tr_resolve_type_ref(tables, nr, env, tref_float, result.diags, seen);
            assert(ty_float != null, "float should resolve");
            assert(type_is_builtin(ty_float as Type*, "float"), "should be float");
            type_free(ty_float as Type*);
            drop tref_float;

            let tref_double_opt = new TypeRef("double", 0, true, null, null, null, null, Span(0,0,0,0));
            let ty_double_opt = tr_resolve_type_ref(tables, nr, env, tref_double_opt, result.diags, seen);
            assert(ty_double_opt != null, "double? should resolve");
            assert(ord((ty_double_opt as Type*).kind) == ord(TY_NULLABLE), "should be nullable");
            assert(type_is_builtin((ty_double_opt as Type*).inner as Type*, "double"), "inner should be double");
            type_free(ty_double_opt as Type*);
            drop tref_double_opt;
            
            // struct Point (from shared_types)
            let tref2 = new TypeRef("Point", 0, false, null, null, null, null, Span(0,0,0,0));
            let ty2 = tr_resolve_type_ref(tables, nr, env, tref2, result.diags, seen);
            assert(ty2 != null, "Point should resolve");
            assert(ord((ty2 as Type*).kind) == ord(TY_STRUCT), "should be struct");
            assert((ty2 as Type*).name == "Point", "name should be Point");
            type_free(ty2 as Type*);
            drop tref2;
            
            // pointer Point*
            let tref3 = new TypeRef("Point", 1, false, null, null, null, null, Span(0,0,0,0));
            let ty3 = tr_resolve_type_ref(tables, nr, env, tref3, result.diags, seen);
            assert(ty3 != null, "Point* should resolve");
            assert(ord((ty3 as Type*).kind) == ord(TY_POINTER), "should be pointer");
            type_free(ty3 as Type*);
            drop tref3;
        }
        
        analysis_result_free(result);
    }
    sp_free(sp);
}

/**
 * Tests module-qualified enum variant lookup when a local variant shadows imported names.
 */
func test_tr_module_qualified_variant_lookup_survives_shadow_warning() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "shadow_warn_main", cfg);
        let nr = result.names as NameResolution*;
        let env = nr_env_find(nr, "shadow_warn_main") as ModuleEnv*;

        assert(!analysis_has_errors(result), "expected shadow_warn_main analysis to succeed");
        assert(env != null, "shadow_warn_main env should be available");

        let local = tr_symbol_lookup(nr, env, "Red", null, null);
        assert(local != null, "local Red should resolve without qualification");
        assert((local as Symbol*).module_name == "shadow_warn_main", "unqualified Red should resolve locally");

        with (let module_path = vs_create(1) => vs_free(module_path)) {
            vs_push(module_path, "shadow_warn_uno");
            let qualified = tr_symbol_lookup(nr, env, "Red", module_path, null);
            assert(qualified != null, "shadow_warn_uno::Red should resolve");
            assert(ord((qualified as Symbol*).kind) == ord(SYM_ENUM_VARIANT), "qualified Red should be a variant");
            assert((qualified as Symbol*).module_name == "shadow_warn_uno",
                "qualified Red should resolve from shadow_warn_uno");
        }

        analysis_result_free(result);
    }
    sp_free(sp);
}

/**
 * Main entry point for the module.
 */
func main() {
    test_tr_symbol_lookup();
    test_tr_resolve_type_ref();
    test_tr_module_qualified_variant_lookup_survives_shadow_warning();
    printl_s("type_resolve_test: all tests passed");
}
