        "const_main scalar const lowering mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests non-constant top-level `let` execution and hidden init-function C emission in `--run --keep-c` mode.
 */
func test_run_nonconstant_top_level_let_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "toplet_init_main");

        let rc = run_with_argv(argv);
        assert(rc == 23, "--run --keep-c should compile and execute toplet_init_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "toplet_init_main kept C file should exist");
    assert(contains_s(c_text as string, "static dea_int dea_toplet_init_dep_BASE = 0;"),
        "toplet_init_main dep zero-init mismatch");
    assert(contains_s(c_text as string, "static dea_int dea_toplet_init_main_ANSWER = 0;"),
        "toplet_init_main main zero-init mismatch");
    assert(contains_s(c_text as string, "static void _dea_init_toplet_init_dep(void)"),
        "toplet_init_main dep init function missing");
    assert(contains_s(c_text as string, "dea_toplet_init_dep_BASE = dea_toplet_init_dep_seed();"),
        "toplet_init_main dep init assignment mismatch");
    assert(contains_s(c_text as string, "static void _dea_init_toplet_init_main(void)"),
        "toplet_init_main main init function missing");
    assert(contains_s(c_text as string, "dea_toplet_init_main_ANSWER = dea_toplet_init_main_bump(dea_toplet_init_dep_get_base());"),
        "toplet_init_main main init assignment mismatch");
    assert(contains_s(c_text as string,
        "static void _dea_init_modules(void)\n{\n    _dea_init_toplet_init_dep();\n    _dea_init_toplet_init_main();\n}\n"),
        "toplet_init_main global init order mismatch");
    assert(contains_s(c_text as string, "_rt_init_args(argc, argv);\n    _dea_init_modules();\n    return (int) dea_toplet_init_main_main();"),
        "toplet_init_main wrapper init call mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests float/double build-and-run execution with kept generated C.
 */
func test_run_float_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "float_main");

        let rc = run_with_argv(argv);
        assert(rc == 17, "--run --keep-c should compile and execute float_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "float_main kept C file should exist");
    assert(contains_s(c_text as string, "#include <float.h>"), "float_main float contract header missing");
    assert(contains_s(c_text as string, "#if FLT_RADIX != 2"), "float_main float radix guard missing");
    assert(contains_s(c_text as string, "__FAST_MATH__"), "float_main fast-math guard missing");
    assert(contains_s(c_text as string, "double dea_float_main_widen(float x)"), "float_main widen signature mismatch");
    assert(contains_s(c_text as string, "float seed = 1.0f;"), "float_main float literal lowering mismatch");
    assert(contains_s(c_text as string, "double total = ((dea_float_main_widen(seed) + 1.5) + 1.5);"),
        "float_main double arithmetic lowering mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests float/double subtraction, multiplication, division, and casts in `--run --keep-c` mode.
 */
func test_run_float_ops_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "float_ops_main");

        let rc = run_with_argv(argv);
        assert(rc == 21, "--run --keep-c should compile and execute float_ops_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "float_ops_main kept C file should exist");
    assert(contains_s(c_text as string, "float diff = (lhs - rhs);"), "float_ops_main subtraction lowering mismatch");
    assert(contains_s(c_text as string, "float prod = (rhs * 4.0f);"), "float_ops_main multiplication lowering mismatch");
    assert(contains_s(c_text as string, "double quot = (9.0 / 2.0);"), "float_ops_main division lowering mismatch");
    assert(contains_s(c_text as string, "float narrowed = ((float)(quot));"), "float_ops_main narrowing cast mismatch");
    assert(contains_s(c_text as string, "dea_int back_to_int = ((dea_int)(from_int));"),
        "float_ops_main double-to-int cast mismatch");
    assert(!contains_s(c_text as string, "_rt_isub("), "float_ops_main subtraction should not use checked integer subtraction");
    assert(!contains_s(c_text as string, "_rt_imul("), "float_ops_main multiplication should not use checked integer multiplication");
    assert(!contains_s(c_text as string, "_rt_idiv("), "float_ops_main division should not use checked integer division");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests floating zero-division lowering in kept generated C.
 */
func test_build_float_zero_division_keep_c() {
    let out_path = build_output_path();
    let c_path = build_c_output_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "--keep-c");
        vs_push(argv, "float_zero_div_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "default build mode should succeed for float_zero_div_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "float_zero_div_main kept C file should exist");
    assert(contains_s(c_text as string, "double dz = (1.0 / 0.0);"), "float_zero_div_main double zero-division mismatch");
    assert(contains_s(c_text as string, "float fz = (1.0f / 0.0f);"), "float_zero_div_main float zero-division mismatch");
    assert(!contains_s(c_text as string, "_rt_idiv("), "float_zero_div_main should not use checked integer division");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests that build mode rejects explicit C options that violate the floating-point contract.
 */
func test_build_float_rejects_invalid_math_mode_option() {
    let out_path = build_output_path();
    let c_path = build_c_output_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(14) => vs_free(argv)) {
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "--keep-c");
        vs_push(argv, "--c-options");
        vs_push(argv, "-fno-signed-zeros");
        vs_push(argv, "float_main");

        let rc = run_with_argv(argv);
        assert(rc == 1, "float_main should reject invalid signed-zero-breaking C options");
    }

    assert(!exists(out_path), "invalid FP mode should fail before producing an executable");
    assert(!exists(c_path), "invalid FP mode should fail before writing kept generated C");
}

/**
 * Tests test_merge_c_option_words_cli_last.
 */
func test_merge_c_option_words_cli_last() {
    with (let words = l0c_merge_c_option_words("-DENV_ONE   -DENV_TWO", "-DCLI_ONE -DCLI_TWO") => vs_free(words)) {
        assert(vs_size(words) == 4, "expected 4 merged C option words");
        assert(eq_s(vs_get(words, 0), "-DENV_ONE"), "env option #1 should come first");
        assert(eq_s(vs_get(words, 1), "-DENV_TWO"), "env option #2 should come before CLI options");
        assert(eq_s(vs_get(words, 2), "-DCLI_ONE"), "cli option #1 should come after env options");
        assert(eq_s(vs_get(words, 3), "-DCLI_TWO"), "cli option #2 should come last");
    }
}

/**
 * Tests test_merge_c_option_words_ignores_empty_inputs.
 */
func test_merge_c_option_words_ignores_empty_inputs() {
    with (let empty_words = l0c_merge_c_option_words("   \t  ", null) => vs_free(empty_words)) {
        assert(vs_size(empty_words) == 0, "blank env options should produce no words");
    }

    with (let cli_words = l0c_merge_c_option_words(null, "  -DCLI_ONLY\t") => vs_free(cli_words)) {
        assert(vs_size(cli_words) == 1, "single CLI option should be preserved");
        assert(eq_s(vs_get(cli_words, 0), "-DCLI_ONLY"), "CLI option text mismatch");
    }
}

