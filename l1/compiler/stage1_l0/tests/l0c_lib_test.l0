/**
 * Main entry point for the module.
 */
func main() {
    test_check_ok();
    test_check_cycle_fails();
    test_check_semantic_failure();
    test_tok_ok();
    test_gen_ok_stdout();
    test_gen_ok_output_file();
    test_gen_trace_defines();
    test_parse_error_exit_code();
    test_default_build_mode_succeeds();
    test_run_exit_code_passthrough();
    test_run_keep_c_output_file();
    test_run_cleanup_return_precedence();
    test_run_try_chain_short_circuits();
    test_run_shadowed_qualified_variant();
    test_run_bitwise_build_and_keep_c();
    test_run_string_equality_build_and_keep_c();
    test_run_string_relational_build_and_keep_c();
    test_run_const_build_and_keep_c();
    test_run_nonconstant_top_level_let_build_and_keep_c();
    test_run_float_build_and_keep_c();
    test_run_float_ops_build_and_keep_c();
    test_build_float_zero_division_keep_c();
    test_build_float_rejects_invalid_math_mode_option();
    test_merge_c_option_words_cli_last();
    test_merge_c_option_words_ignores_empty_inputs();
    test_type_ok();
    test_sym_ok();
    test_sym_all_modules_ok();
    test_run_real_classify();
    test_run_real_basic();
    test_run_real_round();
    test_run_real_decompose();
    test_run_real_transcendental();
    printl_s("l0c_lib_test: all tests passed");
}
