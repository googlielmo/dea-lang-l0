/**
 * Tests test_default_build_mode_succeeds.
 */
func test_default_build_mode_succeeds() {
    let out_path = build_output_path();
    let c_path = build_c_output_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "--keep-c");
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "default build mode should succeed for ok_main");
    }

    assert(exists(out_path), "built executable should exist");
    assert(exists(c_path), "kept generated C should exist for build");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

