/**
 * Returns the root directory for test fixtures.
 *
 * @return The driver fixture directory used by command-line tests.
 */
func fixture_root() -> string {
    return "compiler/stage1_l0/tests/fixtures/driver";
}

/**
 * Returns the semantics fixture directory used by command-line tests.
 *
 * @return The semantics fixture directory for semantic failure cases.
 */
func semantics_fixture_root() -> string {
    return "compiler/stage1_l0/tests/fixtures/semantics";
}

/**
 * Returns the temporary output path used by `--gen` tests.
 *
 * @return Output file path for generated C.
 */
func gen_output_path() -> string {
    return "compiler/stage1_l0/tests/.tmp-ok_main.c";
}

/**
 * Returns the temporary output path used by `--build` tests.
 *
 * @return Output executable path for build tests.
 */
func build_output_path() -> string {
    return "compiler/stage1_l0/tests/.tmp-build-ok_main";
}

/**
 * Returns the kept-C path used by `--build` tests.
 *
 * @return Output C path for build tests.
 */
func build_c_output_path() -> string {
    return "compiler/stage1_l0/tests/.tmp-build-ok_main.c";
}

/**
 * Returns the base output path used by `--run --keep-c` tests.
 *
 * @return Requested output base path for run tests.
 */
func run_keep_c_output_path() -> string {
    return "compiler/stage1_l0/tests/.tmp-run-kept";
}

/**
 * Returns the kept-C path used by `--run --keep-c` tests.
 *
 * @return Output C path for run tests.
 */
func run_keep_c_c_path() -> string {
    return "compiler/stage1_l0/tests/.tmp-run-kept.c";
}

/**
 * Tests test_check_ok.
 */
func test_check_ok() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--check");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--check should succeed for ok_main");
    }
}

