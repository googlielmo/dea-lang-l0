/**
 * Tests test_gen_ok_output_file.
 */
func test_gen_ok_output_file() {
    let out_path = gen_output_path();
    rt_delete_file(out_path);

    with (let argv = vs_create(10) => vs_free(argv)) {
        vs_push(argv, "--gen");
        vs_push(argv, "--no-line-directives");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--gen --output should succeed for ok_main");
    }

    let c_text = read_file(out_path);
    assert(c_text != null, "generated C output file should exist");
    assert(contains_s(c_text as string, "/* Generated by l1c, the Dea/L1 compiler. Do not edit. */"), "generated C header missing");
    assert(contains_s(c_text as string, "int main(int argc, char **argv)"), "generated C main wrapper missing");

    rt_delete_file(out_path);
}

/**
 * Tests test_gen_trace_defines.
 */
func test_gen_trace_defines() {
    let out_path = gen_output_path();
    rt_delete_file(out_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--gen");
        vs_push(argv, "--no-line-directives");
        vs_push(argv, "--trace-arc");
        vs_push(argv, "--trace-memory");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--gen with trace flags should succeed");
    }

    let c_text = read_file(out_path);
    assert(c_text != null, "generated C output file should exist for trace test");
    assert(contains_s(c_text as string, "#define DEA_TRACE_ARC 1"), "trace ARC define missing");
    assert(contains_s(c_text as string, "#define DEA_TRACE_MEMORY 1"), "trace memory define missing");

    rt_delete_file(out_path);
}

