/**
 * Tests integer bitwise lowering and execution in `--run --keep-c` mode.
 */
func test_run_bitwise_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "bitwise_main");

        let rc = run_with_argv(argv);
        assert(rc == 29, "--run --keep-c should compile and execute bitwise_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "bitwise_main kept C file should exist");
    assert(contains_s(c_text as string, "dea_byte inverted = ((dea_byte)((~base)));"),
        "bitwise_main unary bitwise-not lowering mismatch");
    assert(contains_s(c_text as string, "dea_int masked = (((dea_int)(inverted)) & 15);"),
        "bitwise_main bitwise-and widening mismatch");
    assert(contains_s(c_text as string, "dea_long shifted_left = (wide << ((dea_long)(count)));"),
        "bitwise_main left-shift widening mismatch");
    assert(contains_s(c_text as string, "dea_long shifted_right = (shifted_left >> ((dea_long)(count)));"),
        "bitwise_main right-shift widening mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests string equality and inequality execution in `--run --keep-c` mode.
 */
func test_run_string_equality_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "string_equality_main");

        let rc = run_with_argv(argv);
        assert(rc == 23, "--run --keep-c should compile and execute string_equality_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "string_equality_main kept C file should exist");
    assert(contains_s(c_text as string, "rt_string_equals(lit, same_lit)"),
        "string_equality_main equality lowering mismatch");
    assert(contains_s(c_text as string, "(!rt_string_equals(lit, different_lit))"),
        "string_equality_main inequality lowering mismatch");
    assert(contains_s(c_text as string, "rt_string_equals(built_a, built_b)"),
        "string_equality_main heap-string equality lowering mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests string relational execution in `--run --keep-c` mode.
 */
func test_run_string_relational_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "string_relational_main");

        let rc = run_with_argv(argv);
        assert(rc == 23, "--run --keep-c should compile and execute string_relational_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "string_relational_main kept C file should exist");
    assert(contains_s(c_text as string, "(rt_string_compare(short_value, longer_value) < 0)"),
        "string_relational_main less-than lowering mismatch");
    assert(contains_s(c_text as string, "(rt_string_compare(short_value, same_value) <= 0)"),
        "string_relational_main less-equal lowering mismatch");
    assert(contains_s(c_text as string, "(rt_string_compare(longer_value, short_value) > 0)"),
        "string_relational_main greater-than lowering mismatch");
    assert(contains_s(c_text as string, "(rt_string_compare(longer_value, same_value) >= 0)"),
        "string_relational_main greater-equal lowering mismatch");
    assert(contains_s(c_text as string, "(rt_string_compare(built_same, short_value) >= 0)"),
        "string_relational_main heap-string ordering lowering mismatch");

    rt_delete_file(out_path);
    rt_delete_file(c_path);
}

/**
 * Tests top-level `const` execution and `static const` C emission in `--run --keep-c` mode.
 */
func test_run_const_build_and_keep_c() {
    let out_path = run_keep_c_output_path();
    let c_path = run_keep_c_c_path();
    rt_delete_file(out_path);
    rt_delete_file(c_path);

    with (let argv = vs_create(12) => vs_free(argv)) {
        vs_push(argv, "--run");
        vs_push(argv, "--keep-c");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "--output");
        vs_push(argv, out_path);
        vs_push(argv, "const_main");

        let rc = run_with_argv(argv);
        assert(rc == 23, "--run --keep-c should compile and execute const_main");
    }

    let c_text = read_file(c_path);
    assert(c_text != null, "const_main kept C file should exist");
    assert(contains_s(c_text as string, "static const struct dea_const_main_Pair dea_const_main_pair = { .left = 1, .right = 2 };"),
        "const_main struct const lowering mismatch");
