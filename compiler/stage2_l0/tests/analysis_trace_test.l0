module analysis_trace_test;

import std.io;
import std.assert;

import analysis;
import sem_context;
import source_paths;
import util.log;

func fixture_root() -> string {
    return "compiler/stage2_l0/tests/fixtures/driver";
}

func make_paths() -> SourceSearchPaths* {
    let sp = sp_create();
    sp_add_project_root(sp, fixture_root());
    return sp;
}

func test_analysis_ok_main() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "ok_main", cfg);
        assert(!analysis_has_errors(result), "expected no analysis errors for ok_main");
        assert(analysis_diag_count(result) == 0, "expected zero diagnostics for ok_main");
        analysis_result_free(result);
    }
    sp_free(sp);
}

func main() {
    test_analysis_ok_main();
    printl_s("analysis_trace_test: all tests passed");
}
