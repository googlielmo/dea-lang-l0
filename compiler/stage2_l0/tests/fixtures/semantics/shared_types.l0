module shared_types;

type IntAlias = int;

struct Point {
    x: int;
    y: int;
}

enum OptionInt {
    None;
    Some(value: int);
}

func make_point(x: int, y: int) -> Point {
    return Point(x, y);
}

func make_some(v: int) -> OptionInt {
    return Some(v);
}

let default_point = Point(1, 2);
let default_count: IntAlias = 3;
