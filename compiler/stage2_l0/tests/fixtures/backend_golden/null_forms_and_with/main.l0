module main;

func value_none() -> int? {
    return null;
}

func ptr_none() -> int*? {
    return null;
}

func is_none_value(x: int?) -> bool {
    return x == null;
}

func is_none_ptr(x: int*?) -> bool {
    return x == null;
}

func helper() -> int {
    with (null) {
        null;
        return 1;
    } cleanup {
        return 2;
    }
}

func main() -> int {
    let x: int? = null;
    let p: int*? = null;
    if (is_none_value(x) && is_none_ptr(p) && value_none() == null && ptr_none() == null && helper() == 2) {
        return 0;
    }
    return 1;
}
