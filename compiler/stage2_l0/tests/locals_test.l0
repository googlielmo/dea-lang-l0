module locals_test;

import std.io;
import std.string;
import std.assert;
import std.vector;

import analysis;
import ast;
import locals;
import source_paths;
import util.log;

func fixture_root() -> string {
    return "compiler/stage2_l0/tests/fixtures/semantics";
}

func make_paths() -> SourceSearchPaths* {
    let sp = sp_create();
    sp_add_project_root(sp, fixture_root());
    return sp;
}

func nth_stmt_id(block: StmtNode*, index: int) -> StmtId {
    return id_vec_get(block.ids as VectorBase*, index);
}

func test_local_scope_construction() {
    let sp = make_paths();
    with (let cfg = log_config_create(LL_SILENT, false) => drop cfg) {
        let result = analysis_analyze_entry(sp, "ok_main", cfg);
        assert(!analysis_has_errors(result), "expected no semantic errors");

        let locals_opt = analysis_locals(result);
        assert(locals_opt != null, "expected locals result");
        let all_locals = locals_opt as LocalsResult*;
        let env_opt = locals_env_find(all_locals, "ok_main", "scope_demo");
        assert(env_opt != null, "expected scope_demo locals env");
        let env = env_opt as FunctionEnv*;

        let param = lc_scope_lookup(env.root_scope, "flag");
        assert(param != null, "parameter should be in root scope");
        assert(ord((param as LocalSymbol*).kind) == ord(LK_PARAM), "flag should be a parameter");

        let top = lc_scope_lookup(env.root_scope, "top");
        assert(top != null, "top-level let should be in root scope");
        assert(ord((top as LocalSymbol*).kind) == ord(LK_LOCAL), "top should be a local");

        let body_block = stmt_arena_get(env.stmt_arena, env.func_decl.body);

        let nested_block_id = nth_stmt_id(body_block, 1);
        let nested_scope = lc_func_env_get_block_scope(env, nested_block_id);
        assert(nested_scope != null, "expected nested block scope");
        assert(lc_scope_lookup(nested_scope, "inner") != null, "inner should be visible in block scope");
        assert(lc_scope_lookup(env.root_scope, "inner") == null, "inner must not leak to root scope");

        let while_stmt = stmt_arena_get(env.stmt_arena, nth_stmt_id(body_block, 2));
        let while_scope = lc_func_env_get_block_scope(env, while_stmt.stmt_a);
        assert(while_scope != null, "expected while body scope");
        assert(lc_scope_lookup(while_scope, "w") != null, "while local should be visible in while scope");

        let for_stmt = stmt_arena_get(env.stmt_arena, nth_stmt_id(body_block, 3));
        let for_scope = lc_func_env_get_block_scope(env, for_stmt.stmt_c);
        assert(for_scope != null, "expected for body scope");
        assert(lc_scope_lookup(for_scope, "loop_local") != null, "for local should be visible in for scope");

        let case_stmt = stmt_arena_get(env.stmt_arena, nth_stmt_id(body_block, 4));
        let case_arm = ptr_vec_get(case_stmt.case_arms as VectorBase*, 0) as CaseArm*;
        let case_scope = lc_func_env_get_block_scope(env, case_arm.body);
        assert(case_scope != null, "expected case arm scope");
        assert(lc_scope_lookup(case_scope, "case_local") != null, "case local should be visible in case arm scope");

        let case_else = case_stmt.case_else as CaseElse*;
        let case_else_scope = lc_func_env_get_block_scope(env, case_else.body);
        assert(case_else_scope != null, "expected case else scope");
        assert(lc_scope_lookup(case_else_scope, "case_else_local") != null, "case else local should be visible");

        let match_stmt = stmt_arena_get(env.stmt_arena, nth_stmt_id(body_block, 5));
        let match_arm = ptr_vec_get(match_stmt.match_arms as VectorBase*, 0) as MatchArm*;
        let match_scope = lc_func_env_get_match_arm_scope(env, match_arm);
        assert(match_scope != null, "expected match arm scope");
        assert(lc_scope_lookup(match_scope, "v") != null, "pattern variable should be visible in arm scope");
        assert(lc_scope_lookup(match_scope, "arm_local") != null, "arm local should be visible in arm scope");
        assert(ord((lc_scope_lookup(match_scope, "v") as LocalSymbol*).kind) == ord(LK_PATTERN_VAR),
            "pattern variable should be tagged as pattern local");

        let with_stmt = stmt_arena_get(env.stmt_arena, nth_stmt_id(body_block, 6));
        let with_body_scope = lc_func_env_get_block_scope(env, with_stmt.stmt_a);
        let with_cleanup_scope = lc_func_env_get_block_scope(env, with_stmt.stmt_b);
        assert(with_body_scope != null, "expected with body scope");
        assert(with_cleanup_scope != null, "expected with cleanup scope");
        assert(lc_scope_lookup(with_body_scope, "body_local") != null, "with body local should be visible");
        assert(lc_scope_lookup(with_cleanup_scope, "cleanup_local") != null, "with cleanup local should be visible");
        assert(lc_scope_lookup(with_body_scope, "header_local") != null, "with header local should flow to body scope");
        assert(lc_scope_lookup(with_cleanup_scope, "header_local") != null,
            "with header local should flow to cleanup scope");

        analysis_result_free(result);
    }
    sp_free(sp);
}

func main() {
    test_local_scope_construction();
    printl_s("locals_test: all tests passed");
}
