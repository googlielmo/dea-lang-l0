module l0c_test;

import std.io;
import std.assert;
import std.string;
import std.vector;

import l0c;

/**
 * Returns the root directory for test fixtures.
 *
 * @return The driver fixture directory used by command-line tests.
 */
func fixture_root() -> string {
    return "compiler/stage2_l0/tests/fixtures/driver";
}

/**
 * Returns the semantics fixture directory used by command-line tests.
 *
 * @return The semantics fixture directory for semantic failure cases.
 */
func semantics_fixture_root() -> string {
    return "compiler/stage2_l0/tests/fixtures/semantics";
}

/**
 * Tests test_check_ok.
 */
func test_check_ok() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--check");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--check should succeed for ok_main");
    }
}

/**
 * Tests test_check_cycle_fails.
 */
func test_check_cycle_fails() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--check");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "cycle_a");

        let rc = run_with_argv(argv);
        assert(rc == 1, "--check should fail for cycle_a");
    }
}

/**
 * Tests test_check_semantic_failure.
 */
func test_check_semantic_failure() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--check");
        vs_push(argv, "-P");
        vs_push(argv, semantics_fixture_root());
        vs_push(argv, "infer_fail_main");

        let rc = run_with_argv(argv);
        assert(rc == 1, "--check should fail for semantic errors");
    }
}

/**
 * Tests test_tok_ok.
 */
func test_tok_ok() {
    with (let argv = vs_create(10) => vs_free(argv)) {
        vs_push(argv, "--tok");
        vs_push(argv, "--include-eof");
        vs_push(argv, "-P");
        vs_push(argv, fixture_root());
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--tok should succeed for ok_main");
    }
}

/**
 * Tests test_parse_error_exit_code.
 */
func test_parse_error_exit_code() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--check");
        vs_push(argv, "--keep-c");
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 2, "CLI parse/validation errors should return 2");
    }
}

/**
 * Tests test_nyi_mode_exit_code.
 */
func test_nyi_mode_exit_code() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 1, "default --build mode is NYI and should return 1");
    }
}

/**
 * Tests test_merge_c_option_words_cli_last.
 */
func test_merge_c_option_words_cli_last() {
    with (let words = l0c_merge_c_option_words("-DENV_ONE   -DENV_TWO", "-DCLI_ONE -DCLI_TWO") => vs_free(words)) {
        assert(vs_size(words) == 4, "expected 4 merged C option words");
        assert(eq_s(vs_get(words, 0), "-DENV_ONE"), "env option #1 should come first");
        assert(eq_s(vs_get(words, 1), "-DENV_TWO"), "env option #2 should come before CLI options");
        assert(eq_s(vs_get(words, 2), "-DCLI_ONE"), "cli option #1 should come after env options");
        assert(eq_s(vs_get(words, 3), "-DCLI_TWO"), "cli option #2 should come last");
    }
}

/**
 * Tests test_merge_c_option_words_ignores_empty_inputs.
 */
func test_merge_c_option_words_ignores_empty_inputs() {
    with (let empty_words = l0c_merge_c_option_words("   \t  ", null) => vs_free(empty_words)) {
        assert(vs_size(empty_words) == 0, "blank env options should produce no words");
    }

    with (let cli_words = l0c_merge_c_option_words(null, "  -DCLI_ONLY\t") => vs_free(cli_words)) {
        assert(vs_size(cli_words) == 1, "single CLI option should be preserved");
        assert(eq_s(vs_get(cli_words, 0), "-DCLI_ONLY"), "CLI option text mismatch");
    }
}

/**
 * Tests test_type_ok.
 */
func test_type_ok() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--type");
        vs_push(argv, "-P");
        vs_push(argv, semantics_fixture_root());
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--type should succeed for ok_main");
    }
}

/**
 * Tests test_sym_ok.
 */
func test_sym_ok() {
    with (let argv = vs_create(8) => vs_free(argv)) {
        vs_push(argv, "--sym");
        vs_push(argv, "-P");
        vs_push(argv, semantics_fixture_root());
        vs_push(argv, "ok_main");

        let rc = run_with_argv(argv);
        assert(rc == 0, "--sym should succeed for ok_main");
    }
}

/**
 * Main entry point for the module.
 */
func main() {
    test_check_ok();
    test_check_cycle_fails();
    test_check_semantic_failure();
    test_tok_ok();
    test_parse_error_exit_code();
    test_nyi_mode_exit_code();
    test_merge_c_option_words_cli_last();
    test_merge_c_option_words_ignores_empty_inputs();
    test_type_ok();
    test_sym_ok();
    printl_s("l0c_test: all tests passed");
}
